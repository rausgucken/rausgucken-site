---
// src/components/EventCard.astro
const { event: ev } = Astro.props;
import FreshnessStamp from './FreshnessStamp.astro';

function formatDate(iso) {
  if (!iso) return null;
  const d = new Date(iso + "T12:00:00");
  return {
    day:     d.getDate(),
    month:   d.toLocaleDateString("de-DE", { month: "short" }),
    weekday: d.toLocaleDateString("de-DE", { weekday: "short" }),
    full:    d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" }),
  };
}

const TAG_LABELS = {
  Ausstellung: "Ausstellung",   Entertainment: "Entertainment",
  Familie:     "Familie",       Fest:          "Fest",
  Fuehrung:    "Führung",       Jugend:        "Jugend",
  Kinder:      "Kinder",        Kulinarik:     "Kulinarik",
  Lesung:      "Lesung",        Messe:         "Messe",
  Musik:       "Musik",         Outdoor:       "Outdoor",
  Sport:       "Sport",         Sprache:       "Sprache",
  Tanz:        "Tanz",          Theater:       "Theater",
  Vortrag:     "Vortrag",       Workshop:      "Workshop",
};

const dateObj    = formatDate(ev.date_start);
const isStanding = !ev.date_start;
const isSponsored = ev.sponsored === true;

const weekdayAttr = ev.weekdays ? ev.weekdays.join(",") : "";

// Share URLs — built at render time, no tracking
const eventUrl  = `https://rausgucken.de/ludwigsburg/events/${ev.slug}`;
const shareText = encodeURIComponent(`${ev.title} – ${eventUrl}`);
const waUrl     = `https://wa.me/?text=${shareText}`;
const tgUrl     = `https://t.me/share/url?url=${encodeURIComponent(eventUrl)}&text=${encodeURIComponent(ev.title)}`;
---

<article
  class:list={[
    "event-card",
    { "event-card--standing":  isStanding },
    { "event-card--new":       ev.is_new },
    { "event-card--sponsored": isSponsored },
  ]}
  data-tags={ev.tags.join(",")}
  data-source={ev.source}
  data-age-min={ev.age_min ?? ""}
  data-age-max={ev.age_max ?? ""}
  data-date={ev.date_start ?? ""}
  data-weekdays={weekdayAttr}
  data-location={ev.location ?? ""}
>
  
    href={`/ludwigsburg/events/${ev.slug}`}
    class="card-link"
    aria-label={`${ev.title}${dateObj ? `, ${dateObj.full}` : ""}`}
  >
    {dateObj ? (
      <div class="date-badge" aria-hidden="true">
        <span class="date-weekday">{dateObj.weekday}</span>
        <span class="date-day">{dateObj.day}</span>
        <span class="date-month">{dateObj.month}</span>
      </div>
    ) : (
      <div class="date-badge date-badge--standing" aria-hidden="true">
        <span class="date-infinity">∞</span>
        <span class="date-month">immer</span>
      </div>
    )}

    <div class="card-body">
      <div class="card-tags">
        {isSponsored && <span class="badge-sponsored" aria-label="Anzeige">Anzeige</span>}
        {ev.is_new && !isSponsored && <span class="badge-new">Neu</span>}
        {ev.tags.slice(0, 3).map(t => (
          <span class="tag">{TAG_LABELS[t] ?? t}</span>
        ))}
        {ev.age_min != null && (
          <span class="tag tag--age">
            ab {ev.age_min} J.{ev.age_max ? `–${ev.age_max}` : "+"}
          </span>
        )}
      </div>

      <h3 class="card-title">{ev.title}</h3>

      <div class="card-meta">
        {ev.time && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {ev.time} Uhr
          </span>
        )}
        {isStanding && !ev.time && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Regelmäßig
          </span>
        )}
        {ev.location && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {ev.location.replace("Residenzschloss Ludwigsburg", "Residenzschloss LB")}
          </span>
        )}
        {ev.price && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            {ev.price.split(" ").slice(0, 3).join(" ")}
          </span>
        )}
      </div>

      {ev.description && (
        <p class="card-desc">
          {ev.description.length > 110
            ? ev.description.slice(0, 110) + "…"
            : ev.description}
        </p>
      )}
    </div>
  </a>

  <!-- Share dropdown: native <details> — zero JS, keyboard accessible -->
  <div class="card-share" onclick="event.stopPropagation()">
    <details class="share-details">
      <summary class="share-toggle" aria-label={`${ev.title} teilen`}>
        <!-- Share icon -->
        <svg aria-hidden="true" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Teilen
      </summary>
      <ul class="share-menu" role="list">
        <li>
          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="share-item" aria-label="WhatsApp">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </li>
        <li>
          <a href={tgUrl} target="_blank" rel="noopener noreferrer" class="share-item" aria-label="Telegram">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Telegram
          </a>
        </li>
        <li class="share-divider" aria-hidden="true"></li>
        <li class="share-label">EU-Alternativen</li>
        <li>
          <a href={`https://wire.com/`} target="_blank" rel="noopener noreferrer" class="share-item share-item--eu" aria-label="Wire">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm.293 16.707a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L11 13.586V7a1 1 0 012 0v6.586l2.707-2.707a1 1 0 011.414 1.414l-4 4z"/></svg>
            Wire <span class="share-item-meta">DE/CH</span>
          </a>
        </li>
        <li>
          <a href={`https://threema.ch/`} target="_blank" rel="noopener noreferrer" class="share-item share-item--eu" aria-label="Threema">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1a11 11 0 100 22A11 11 0 0012 1zm0 2a9 9 0 110 18A9 9 0 0112 3zm-1 4v2H9v2h2v6h2v-6h2V9h-2V7h-2z"/></svg>
            Threema <span class="share-item-meta">CH</span>
          </a>
        </li>
        <li>
          <a href={`https://element.io/`} target="_blank" rel="noopener noreferrer" class="share-item share-item--eu" aria-label="Element">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-1 6h2v6h-2V6zm0 8h2v2h-2v-2z"/></svg>
            Element <span class="share-item-meta">Matrix</span>
          </a>
        </li>
        <li>
          <a href={`https://olvid.io/`} target="_blank" rel="noopener noreferrer" class="share-item share-item--eu" aria-label="Olvid">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm0 2a8 8 0 110 16A8 8 0 0112 4zm0 3a5 5 0 100 10A5 5 0 0012 7zm0 2a3 3 0 110 6 3 3 0 010-6z"/></svg>
            Olvid <span class="share-item-meta">FR</span>
          </a>
        </li>
        <li>
          <a href={`https://ginlo.net/`} target="_blank" rel="noopener noreferrer" class="share-item share-item--eu" aria-label="ginlo">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 110-16 8 8 0 010 16zm-1-5h2v2h-2zm0-8h2v6h-2z"/></svg>
            ginlo <span class="share-item-meta">DE</span>
          </a>
        </li>
      </ul>
    </details>
  </div>

  <!-- Card footer: SourceLink + FreshnessStamp + source attribution -->
  <div class="card-footer">
    
      href={ev.original_url}
      target="_blank"
      rel="noopener noreferrer"
      class="source-link"
      aria-label={`Originalseite für ${ev.title} öffnen (öffnet in neuem Tab)`}
      onclick="event.stopPropagation()"
    >
      Originalseite
      <svg aria-hidden="true" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
    <div class="footer-right">
      <FreshnessStamp scrapedAt={ev.scraped_at} size="sm" showTime={false} />
      {ev.source_label && (
        
          href={ev.original_url}
          target="_blank"
          rel="noopener noreferrer"
          class="source-attribution"
          onclick="event.stopPropagation()"
        >
          Quelle: {ev.source_label}
        </a>
      )}
    </div>
  </div>
</article>

<style>
  /* ── Card shell ──────────────────────────────────────────────────────────── */
  .event-card {
    background: var(--surface-card, var(--surface));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    position: relative;
    transition: transform 200ms cubic-bezier(0.4,0,0.2,1),
                box-shadow 200ms cubic-bezier(0.4,0,0.2,1),
                background 250ms ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .event-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-hover);
    }
  }

  .event-card:focus-within {
    outline: 2px solid var(--coral);
    outline-offset: 0px;
  }

  .event-card--standing  { border-left: 3px solid var(--coral); }
  .event-card--sponsored {
    border-left: 3px solid var(--sage);
    background: var(--sage-light);
  }

  /* ── Card link ──────────────────────────────────────────────────────────── */
  .card-link {
    display: flex;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-height: 0;
    outline: none;
  }
  .card-link:hover { text-decoration: none; }

  /* ── Date badge ─────────────────────────────────────────────────────────── */
  .date-badge {
    background: var(--coral);
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    flex-shrink: 0;
    padding: 0.75rem 0.4rem;
    gap: 0;
  }
  .date-badge--standing {
    background: var(--tag-bg);
    color: var(--text-60);
  }
  .date-weekday {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.75;
    margin-bottom: 1px;
  }
  .date-day {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1;
  }
  .date-month {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.80;
  }
  .date-infinity {
    font-size: 1.4rem;
    line-height: 1;
    opacity: 0.5;
  }

  /* ── Card body ──────────────────────────────────────────────────────────── */
  .card-body {
    padding: 0.85rem 1rem 0.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  /* ── Tags ───────────────────────────────────────────────────────────────── */
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }

  .tag {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .tag--age {
    background: var(--sage-light);
    color: var(--text);
    font-weight: 600;
  }
  .badge-new {
    background: var(--sage);
    color: var(--text);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .badge-sponsored {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid var(--border);
  }

  /* ── Title ──────────────────────────────────────────────────────────────── */
  .card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.97rem;
    color: var(--text);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Meta ───────────────────────────────────────────────────────────────── */
  .card-meta { display: flex; flex-direction: column; gap: 0.2rem; }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-60);
  }
  .meta-item svg { flex-shrink: 0; stroke: var(--coral); }

  /* ── Description ────────────────────────────────────────────────────────── */
  .card-desc {
    font-size: 0.8rem;
    color: var(--text-60);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.1rem;
  }

  /* ── Share dropdown ─────────────────────────────────────────────────────── */
  .card-share {
    padding: 0.4rem 1rem;
    border-top: 1px solid var(--border);
    position: relative; /* anchor for the dropdown */
  }

  /* <details> reset */
  .share-details { display: inline-block; position: relative; }
  .share-details[open] .share-toggle { color: var(--coral); }

  .share-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-60);
    cursor: pointer;
    list-style: none;         /* hide native triangle */
    padding: 0.3rem 0.5rem;
    border-radius: 20px;
    min-height: 32px;
    transition: color 150ms, background 150ms;
    user-select: none;
  }
  .share-toggle::-webkit-details-marker { display: none; }
  .share-toggle:hover { color: var(--coral); background: var(--tag-bg); }
  .share-toggle:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Dropdown menu */
  .share-menu {
    position: absolute;
    bottom: calc(100% + 6px); /* opens upward — cards near bottom of viewport */
    left: 0;
    z-index: 40;
    background: var(--surface-card, var(--surface));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0,0,0,0.14);
    padding: 0.35rem 0;
    min-width: 190px;
    list-style: none;
    margin: 0;
  }

  .share-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    transition: background 120ms;
    white-space: nowrap;
  }
  .share-item:hover { background: var(--tag-bg); }
  .share-item svg { flex-shrink: 0; opacity: 0.75; }

  /* EU alternatives: slightly muted vs main options */
  .share-item--eu { color: var(--text-60); }
  .share-item--eu:hover { color: var(--text); background: var(--tag-bg); }

  .share-item-meta {
    margin-left: auto;
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--text-60);
    opacity: 0.7;
  }

  .share-divider {
    height: 1px;
    background: var(--border);
    margin: 0.3rem 0;
  }

  .share-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-60);
    opacity: 0.6;
    padding: 0.2rem 0.9rem 0.1rem;
  }

  html.dark .share-menu {
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }

  /* ── Card footer ────────────────────────────────────────────────────────── */
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,0.02);
  }
  html.dark .card-footer {
    background: rgba(255,255,255,0.03);
  }

  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-60);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: color 150ms, text-decoration-color 150ms;
    min-height: 44px;
  }
  .source-link:hover {
    color: var(--coral);
    text-decoration-color: var(--coral);
  }
  .source-link:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
    border-radius: 2px;
  }
  html.dark .source-link       { color: var(--text-60); }
  html.dark .source-link:hover { color: var(--coral); }

  .freshness-stamp {
    font-size: 0.67rem;
    color: var(--text);
    opacity: 0.70;
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
    margin-left: auto;
  }
  .source-attribution {
    font-size: 0.72rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: var(--text-60);
    white-space: nowrap;
    padding-left: 0.6rem;
    border-left: 1px solid var(--border);
    margin-left: 0.6rem;
    text-decoration: none;
    transition: color 150ms;
  }
  .source-attribution:hover { color: var(--coral); }
  html.dark .source-attribution       { color: var(--text-60); }
