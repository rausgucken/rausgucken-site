---
// src/components/EventCard.astro
const { event: ev } = Astro.props;
const city = ev.city || "ludwigsburg";
import FreshnessStamp from './FreshnessStamp.astro';

function formatDate(iso) {
  if (!iso) return null;
  const d = new Date(iso + "T12:00:00");
  return {
    day:     d.getDate(),
    month:   d.toLocaleDateString("de-DE", { month: "short" }),
    weekday: d.toLocaleDateString("de-DE", { weekday: "short" }),
    full:    d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" }),
  };
}

const TAG_LABELS = {
  Ausstellung: "Ausstellung",   Entertainment: "Entertainment",
  Familie:     "Familie",       Fest:          "Fest",
  Fuehrung:    "Führung",       Jugend:        "Jugend",
  Kinder:      "Kinder",        Kulinarik:     "Kulinarik",
  Lesung:      "Lesung",        Messe:         "Messe",
  Musik:       "Musik",         Outdoor:       "Outdoor",
  Sport:       "Sport",         Sprache:       "Sprache",
  Tanz:        "Tanz",          Theater:       "Theater",
  Vortrag:     "Vortrag",       Workshop:      "Workshop",
};

const dateObj    = formatDate(ev.date_start);
const isStanding = !ev.date_start;
const isSponsored = ev.sponsored === true;

const weekdayAttr = ev.weekdays ? ev.weekdays.join(",") : "";


const showNew = ev.is_new && !isSponsored;
const showRegular = isStanding && !ev.time;
const _svgClock = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
const _svgCal = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>';
const _svgPin = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>';
const _svgEuro = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>';
const _locationShort = ev.location ? ev.location.replace("Residenzschloss Ludwigsburg", "Residenzschloss LB") : null;
const _timeHtml = ev.time ? _svgClock + ev.time : null;
const _regularHtml = showRegular ? (_svgCal + "Regelmäßig") : null;
const _locationHtml = _locationShort ? (_svgPin + _locationShort) : null;
const _priceHtml = ev.price ? (_svgEuro + ev.price.split(" ").slice(0,3).join(" ")) : null;

const showNew = ev.is_new && !isSponsored;
const showRegular = isStanding && !ev.time;
const showAge = ev.age_min != null;
const _ageDisplay = ev.age_min != null ? ("ab " + ev.age_min + " J." + (ev.age_max ? "–" + ev.age_max : "+")) : null;
const _svgClock = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
const _svgCal = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>';
const _svgPin = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>';
const _svgEuro = '<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>';
const _locationShort = ev.location ? ev.location.replace("Residenzschloss Ludwigsburg", "Residenzschloss LB") : null;
const _timeHtml = ev.time ? (_svgClock + ev.time) : null;
const _regularHtml = showRegular ? (_svgCal + "Regelmäßig") : null;
const _locationHtml = _locationShort ? (_svgPin + _locationShort) : null;
const _priceHtml = ev.price ? (_svgEuro + ev.price.split(" ").slice(0,3).join(" ")) : null;
const _tags = ev.tags.slice(0, 3);
const _tag0 = _tags[0] ? (TAG_LABELS[_tags[0]] || _tags[0]) : null;
const _tag1 = _tags[1] ? (TAG_LABELS[_tags[1]] || _tags[1]) : null;
const _tag2 = _tags[2] ? (TAG_LABELS[_tags[2]] || _tags[2]) : null;
---

<article
  class:list={[
    "event-card",
    { "event-card--standing":  isStanding },
    { "event-card--new":       ev.is_new },
    { "event-card--sponsored": isSponsored },
  ]}
  data-tags={ev.tags.join(",")}
  data-source={ev.source}
  data-age-min={ev.age_min ?? ""}
  data-age-max={ev.age_max ?? ""}
  data-date={ev.date_start ?? ""}
  data-weekdays={weekdayAttr}
  data-location={ev.location ?? ""}
>
  
  <a
    href={`/${city}/events/${ev.slug}`}
    class="card-link"
    aria-label={`${ev.title}${dateObj ? `, ${dateObj.full}` : ""}${ev.location ? ` – ${ev.location}` : ""}`}
  >
    {dateObj ? (
      <div class="date-badge" aria-hidden="true">
        <span class="date-weekday">{dateObj.weekday}</span>
        <span class="date-day">{dateObj.day}</span>
        <span class="date-month">{dateObj.month}</span>
      </div>
    ) : (
      <div class="date-badge date-badge--standing" aria-hidden="true">
        <span class="date-infinity">∞</span>
        <span class="date-month">immer</span>
      </div>
    )}

    <div class="card-body">
      <div class="card-tags">
        {isSponsored && <span class="badge-sponsored" aria-label="Anzeige">Anzeige</span>}
        {showNew && <span class="badge-new">Neu</span>}
        {_tag0 && <span class="tag">{_tag0}</span>}
        {_tag1 && <span class="tag">{_tag1}</span>}
        {_tag2 && <span class="tag">{_tag2}</span>}
        {showAge && <span class="tag tag--age">{_ageDisplay}</span>}
      </div>

      <h3 class="card-title">{ev.title}</h3>

      <div class="card-meta">
        {_timeHtml && <span class="meta-item" set:html={_timeHtml} />}
        {_regularHtml && <span class="meta-item" set:html={_regularHtml} />}
        {_locationHtml && <span class="meta-item" set:html={_locationHtml} />}
        {_priceHtml && <span class="meta-item" set:html={_priceHtml} />}
      </div>

      {ev.description && (
        <p class="card-desc">
          {ev.description.length > 110
            ? ev.description.slice(0, 110) + "…"
            : ev.description}
        </p>
      )}
    </div>
  </a>

  <!-- Card footer: single row. FreshnessStamp + Quelle left, Merken right -->
  <div class="card-footer">
    <div class="footer-left">
      <FreshnessStamp scrapedAt={ev.scraped_at} size="sm" showTime={false} />
      {ev.source_label && (
        
          href={ev.original_url}
          target="_blank"
          rel="noopener noreferrer"
          class="source-attribution"
          onclick="event.stopPropagation()"
        >
          Quelle: {ev.source_label}
        </a>
      )}
    </div>
    <button
      class="merken-btn"
      data-slug={ev.slug}
      aria-label={`Veranstaltung merken: ${ev.title}`}
      aria-pressed="false"
      title="Merken"
      onclick="event.stopPropagation()"
    >
      <svg class="merken-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
      <span class="merken-label">Merken</span>
    </button>
  </div>
</article>

<style>
  /* ── Card shell ──────────────────────────────────────────────────────────── */
  .event-card {
    background: var(--surface-card, var(--surface));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    position: relative;
    transition: transform 200ms cubic-bezier(0.4,0,0.2,1),
                box-shadow 200ms cubic-bezier(0.4,0,0.2,1),
                background 250ms ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .event-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-hover);
    }
  }

  .event-card:focus-within {
    outline: 2px solid var(--coral);
    outline-offset: 0px;
  }

  .event-card--standing  { border-left: 3px solid var(--coral); }
  .event-card--sponsored {
    border-left: 3px solid var(--sage);
    background: var(--sage-light);
  }

  /* ── Card link ──────────────────────────────────────────────────────────── */
  .card-link {
    display: flex;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-height: 0;
    outline: none;
  }
  .card-link:hover { text-decoration: none; }

  /* ── Date badge ─────────────────────────────────────────────────────────── */
  .date-badge {
    background: var(--coral);
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    flex-shrink: 0;
    padding: 0.75rem 0.4rem;
    gap: 0;
  }
  .date-badge--standing {
    background: var(--tag-bg);
    color: var(--text-60);
  }
  .date-weekday {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.75;
    margin-bottom: 1px;
  }
  .date-day {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1;
  }
  .date-month {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.80;
  }
  .date-infinity {
    font-size: 1.4rem;
    line-height: 1;
    opacity: 0.5;
  }

  /* ── Card body ──────────────────────────────────────────────────────────── */
  .card-body {
    padding: 0.85rem 1rem 0.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  /* ── Tags ───────────────────────────────────────────────────────────────── */
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }

  .tag {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .tag--age {
    background: var(--sage-light);
    color: var(--text);
    font-weight: 600;
  }
  .badge-new {
    background: var(--sage);
    color: var(--text);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .badge-sponsored {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid var(--border);
  }

  /* ── Title ──────────────────────────────────────────────────────────────── */
  .card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.97rem;
    color: var(--text);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Meta ───────────────────────────────────────────────────────────────── */
  .card-meta { display: flex; flex-direction: column; gap: 0.2rem; }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-60);
  }
  .meta-item svg { flex-shrink: 0; stroke: var(--coral); }

  /* ── Description ────────────────────────────────────────────────────────── */
  .card-desc {
    font-size: 0.8rem;
    color: var(--text-60);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.1rem;
  }



  /* ── Card footer ────────────────────────────────────────────────────────── */
  .card-footer {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem 0.3rem 0.75rem;
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,0.02);
    min-height: 38px;
  }
  html.dark .card-footer { background: rgba(255,255,255,0.03); }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    overflow: hidden;
    flex: 1;
  }

  .source-attribution {
    font-size: 0.72rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: var(--text-60);
    text-decoration: none;
    transition: color 150ms;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    border-left: 1px solid var(--border);
    padding-left: 0.5rem;
  }
  .source-attribution:hover { color: var(--coral); }
  html.dark .source-attribution { color: var(--text-60); }
  html.dark .source-attribution:hover { color: var(--coral); }

  .freshness-stamp {
    font-size: 0.67rem;
    color: var(--text);
    opacity: 0.70;
    flex-shrink: 0;
  }

  /* ── Merken button ───────────────────────────────────────────────────────── */
  .merken-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    min-height: 36px;
    border-radius: var(--radius-sm);
    color: var(--text-60);
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-body);
    transition: color 150ms, background 150ms;
    flex-shrink: 0;
  }
  .merken-btn:hover {
    color: var(--coral);
    background: var(--coral-light);
  }
  .merken-btn:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }
  .merken-btn[aria-pressed="true"] .merken-icon {
    fill: var(--coral);
    stroke: var(--coral);
  }
  .merken-btn[aria-pressed="true"] .merken-label {
    color: var(--coral);
  }
  .merken-btn[aria-pressed="true"] {
    color: var(--coral);
  }
</style>

<script is:inline>
(function() {
  // Merken: localStorage key 'rg-saved' → [{slug,title,date_start,city,url}]
  // Uses event delegation on document — works for all cards regardless of render order.
  // Guard: only register once even if EventCard is included multiple times.
  if (window.__rgMerkenInit) return;
  window.__rgMerkenInit = true;

  function getSaved() {
    try { return JSON.parse(localStorage.getItem('rg-saved') || '[]'); } catch { return []; }
  }
  function setSaved(arr) {
    try { localStorage.setItem('rg-saved', JSON.stringify(arr)); } catch {}
  }

  function syncBtn(btn) {
    var slug = btn.dataset.slug;
    var isSaved = getSaved().some(function(e) { return e.slug === slug; });
    btn.setAttribute('aria-pressed', String(isSaved));
    var label = btn.querySelector('.merken-label');
    if (label) label.textContent = isSaved ? 'Gemerkt' : 'Merken';
  }

  // Sync all buttons on load
  function syncAll() {
    document.querySelectorAll('.merken-btn').forEach(syncBtn);
  }

  // Event delegation: single listener on document
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.merken-btn');
    if (!btn) return;
    e.stopPropagation();

    var slug  = btn.dataset.slug;
    var card  = btn.closest('.event-card');
    var title = card ? (card.querySelector('.card-title') || {}).textContent || '' : '';
    title = title.trim();
    var date  = card ? card.dataset.date || null : null;
    var link  = card ? card.querySelector('.card-link') : null;
    var url   = link ? link.href : '';
    var parts = url.split('/');
    var city  = parts.length > 3 ? parts[3] : '';

    var arr     = getSaved();
    var idx     = arr.findIndex(function(e) { return e.slug === slug; });
    var nowSaved = idx === -1;
    if (nowSaved) { arr.push({ slug: slug, title: title, date_start: date, city: city, url: url }); }
    else { arr.splice(idx, 1); }
    setSaved(arr);

    btn.setAttribute('aria-pressed', String(nowSaved));
    var label = btn.querySelector('.merken-label');
    if (label) label.textContent = nowSaved ? 'Gemerkt' : 'Merken';

    window.dispatchEvent(new CustomEvent('rg:saved-changed', { detail: { slug: slug, saved: nowSaved } }));
  });

  // Sync on load and whenever saved state changes from /meine-events/
  syncAll();
  window.addEventListener('rg:saved-changed', syncAll);
})();
</script>
