---
// src/components/EventCard.astro
const { event: ev } = Astro.props;
const city = ev.city || "ludwigsburg";
import FreshnessStamp from './FreshnessStamp.astro';

function formatDate(iso) {
  if (!iso) return null;
  const d = new Date(iso + "T12:00:00");
  return {
    day:     d.getDate(),
    month:   d.toLocaleDateString("de-DE", { month: "short" }),
    weekday: d.toLocaleDateString("de-DE", { weekday: "short" }),
    full:    d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" }),
  };
}

const TAG_LABELS = {
  Ausstellung: "Ausstellung",  Entertainment: "Entertainment",
  Familie:     "Familie",       Fest:          "Fest",
  Fuehrung:    "Führung",       Jugend:        "Jugend",
  Kinder:      "Kinder",        Kulinarik:     "Kulinarik",
  Lesung:      "Lesung",        Messe:         "Messe",
  Musik:       "Musik",         Outdoor:       "Outdoor",
  Sport:       "Sport",         Sprache:       "Sprache",
  Tanz:        "Tanz",          Theater:       "Theater",
  Vortrag:     "Vortrag",       Workshop:      "Workshop",
};

const dateObj    = formatDate(ev.date_start);
const isStanding = !ev.date_start;
const isSponsored = ev.sponsored === true;

const weekdayAttr = ev.weekdays ? ev.weekdays.join(",") : "";

const _showNew    = ev.is_new && !isSponsored;
const _showAge    = ev.age_min != null;
const _ageText    = ev.age_min != null ? ("ab " + ev.age_min + " J." + (ev.age_max ? "–" + ev.age_max : "+")) : "";
const _tag0        = ev.tags[0] ? (TAG_LABELS[ev.tags[0]] || ev.tags[0]) : null;
const _tag1        = ev.tags[1] ? (TAG_LABELS[ev.tags[1]] || ev.tags[1]) : null;
const _tag2        = ev.tags[2] ? (TAG_LABELS[ev.tags[2]] || ev.tags[2]) : null;
const _locShort    = ev.location ? ev.location.replace("Residenzschloss Ludwigsburg", "Residenzschloss LB") : null;
const _showRegular = isStanding && !ev.time;

---

<article
  class:list={[
    "event-card",
    { "event-card--standing":  isStanding },
    { "event-card--new":       ev.is_new },
    { "event-card--sponsored": isSponsored },
  ]}
  data-tags={ev.tags.join(",")}
  data-source={ev.source}
  data-age-min={ev.age_min ?? ""}
  data-age-max={ev.age_max ?? ""}
  data-date={ev.date_start ?? ""}
  data-weekdays={weekdayAttr}
  data-location={ev.location ?? ""}
>

  <a
    href={`/${city}/events/${ev.slug}`}
    class="card-link"
    aria-label={`${ev.title}${dateObj ? `, ${dateObj.full}` : ""}${ev.location ? ` – ${ev.location}` : ""}`}
  >
    {dateObj ? (
      <div class="date-badge" aria-hidden="true">
        <span class="date-weekday">{dateObj.weekday}</span>
        <span class="date-day">{dateObj.day}</span>
        <span class="date-month">{dateObj.month}</span>
      </div>
    ) : (
      <div class="date-badge date-badge--standing" aria-hidden="true">
        <span class="date-infinity">∞</span>
        <span class="date-month">immer</span>
      </div>
    )}

    <div class="card-body">
      <div class="card-tags">
        {isSponsored && <span class="badge-sponsored" aria-label="Anzeige">Anzeige</span>}
        {_showNew && <span class="badge-new">Neu</span>}
        {_tag0 && <span class="tag">{_tag0}</span>}
        {_tag1 && <span class="tag">{_tag1}</span>}
        {_tag2 && <span class="tag">{_tag2}</span>}
        {_showAge && <span class="tag tag--age">{_ageText}</span>}
      </div>

      <h3 class="card-title">{ev.title}</h3>

      <div class="card-meta">
        {ev.time && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {ev.time}
          </span>
        )}
        {isStanding && !ev.time && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Regelmäßig
          </span>
        )}
        {ev.location && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {ev.location.replace("Residenzschloss Ludwigsburg", "Residenzschloss LB")}
          </span>
        )}
        {ev.price && (
          <span class="meta-item">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            {ev.price.split(" ").slice(0, 3).join(" ")}
          </span>
        )}
      </div>

      {ev.description && (
        <p class="card-desc">
          {ev.description.length > 110
            ? ev.description.slice(0, 110) + "…"
            : ev.description}
        </p>
      )}
    </div>
  </a>

  <div class="card-footer">
    <div class="footer-line1">
      <button
        class="merken-btn"
        data-slug={ev.slug}
        aria-label={`Veranstaltung merken: ${ev.title}`}
        aria-pressed="false"
        title="Merken"
        onclick="event.stopPropagation()"
      >
        <svg class="merken-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
        </svg>
        <span class="merken-label">Merken</span>
      </button>
      {ev.source_label && (
        <a
          href={ev.original_url}
          target="_blank"
          rel="noopener noreferrer"
          class="source-attribution"
          onclick="event.stopPropagation()"
        >
          Quelle: {ev.source_label}
        </a>
      )}
    </div>
    <div class="footer-line2">
      <FreshnessStamp scrapedAt={ev.scraped_at} size="sm" showTime={false} />
    </div>
  </div>
</article>

<style>
  /* ── Card shell ──────────────────────────────────────────────────────────── */
  .event-card {
    background: var(--surface-card, var(--surface));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    position: relative;
    transition: transform 200ms cubic-bezier(0.4,0,0.2,1),
                box-shadow 200ms cubic-bezier(0.4,0,0.2,1),
                background 250ms ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .event-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-hover);
    }
  }

  .event-card:focus-within {
    outline: 2px solid var(--coral);
    outline-offset: 0px;
  }

  .event-card--standing  { border-left: 3px solid var(--coral); }
  .event-card--sponsored {
    border-left: 3px solid var(--sage);
    background: var(--sage-light);
  }

  /* ── Card link ──────────────────────────────────────────────────────────── */
  .card-link {
    display: flex;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-height: 0;
    outline: none;
  }
  .card-link:hover { text-decoration: none; }

  /* ── Date badge ─────────────────────────────────────────────────────────── */
  .date-badge {
    background: var(--coral);
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    flex-shrink: 0;
    padding: 0.75rem 0.4rem;
    gap: 0;
  }
  .date-badge--standing {
    background: var(--tag-bg);
    color: var(--text-60);
  }
  .date-weekday {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.75;
    margin-bottom: 1px;
  }
  .date-day {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1;
  }
  .date-month {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.80;
  }
  .date-infinity {
    font-size: 1.4rem;
    line-height: 1;
    opacity: 0.5;
  }

  /* ── Card body ──────────────────────────────────────────────────────────── */
  .card-body {
    padding: 0.85rem 1rem 0.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  /* ── Tags ───────────────────────────────────────────────────────────────── */
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }

  .tag {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .tag--age {
    background: var(--sage-light);
    color: var(--text);
    font-weight: 600;
  }
  .badge-new {
    background: var(--sage);
    color: var(--text);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .badge-sponsored {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid var(--border);
  }

  /* ── Title ──────────────────────────────────────────────────────────────── */
  .card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.97rem;
    color: var(--text);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Meta ───────────────────────────────────────────────────────────────── */
  .card-meta { display: flex; flex-direction: column; gap: 0.2rem; }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-60);
  }
  .meta-item svg { flex-shrink: 0; stroke: var(--coral); }

  /* ── Description ────────────────────────────────────────────────────────── */
  .card-desc {
    font-size: 0.8rem;
    color: var(--text-60);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.1rem;
  }

  /* ── Card footer ────────────────────────────────────────────────────────── */
  .card-footer {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,0.02);
  }
  html.dark .card-footer { background: rgba(255,255,255,0.03); }

  .footer-line1 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3rem 0.6rem 0.2rem 0.4rem;
    min-height: 36px;
    gap: 0.4rem;
  }
  .footer-line2 {
    padding: 0 0.75rem 0.35rem 0.75rem;
  }

  .source-attribution {
    font-size: 0.72rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: var(--text-60);
    text-decoration: none;
    transition: color 150ms;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .source-attribution:hover { color: var(--coral); }
  html.dark .source-attribution { color: var(--text-60); }
  html.dark .source-attribution:hover { color: var(--coral); }

  .freshness-stamp {
    font-size: 0.67rem;
    color: var(--text);
    opacity: 0.70;
  }

  /* ── Merken button ───────────────────────────────────────────────────────── */
  .merken-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    min-height: 36px;
    border-radius: var(--radius-sm);
    color: var(--text-60);
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-body);
    transition: color 150ms, background 150ms;
    flex-shrink: 0;
  }
  .merken-btn:hover {
    color: var(--coral);
    background: var(--coral-light);
  }
  .merken-btn:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }
  .merken-btn[aria-pressed="true"] .merken-icon {
    fill: var(--coral);
    stroke: var(--coral);
  }
  .merken-btn[aria-pressed="true"] .merken-label {
    color: var(--coral);
  }
  .merken-btn[aria-pressed="true"] {
    color: var(--coral);
  }
</style>

<script is:inline>
  // Merken: save/unsave events in localStorage
  // Key: 'rg-saved' → JSON array of {slug, title, date_start, city, url}
  // Runs for each EventCard on page load to restore saved state.
  (function() {
    function getSaved() {
      try { return JSON.parse(localStorage.getItem('rg-saved') || '[]'); } catch { return []; }
    }
    function setSaved(arr) {
      try { localStorage.setItem('rg-saved', JSON.stringify(arr)); } catch {}
    }

    // Restore button state on load
    document.querySelectorAll('.merken-btn').forEach(btn => {
      const slug = btn.dataset.slug;
      const saved = getSaved();
      const isSaved = saved.some(e => e.slug === slug);
      btn.setAttribute('aria-pressed', String(isSaved));
      btn.querySelector('.merken-label').textContent = isSaved ? 'Gemerkt' : 'Merken';

      btn.addEventListener('click', function() {
        const slug = this.dataset.slug;
        const card = this.closest('.event-card');
        // Gather event data from card's data attributes + nearby DOM
        const title = card.querySelector('.card-title')?.textContent?.trim() || '';
        const date  = card.dataset.date || null;
        const city  = card.querySelector('.card-link')?.href?.split('/')[3] || '';
        const url   = card.querySelector('.card-link')?.href || '';

        let saved = getSaved();
        const idx = saved.findIndex(e => e.slug === slug);
        const nowSaved = idx === -1;

        if (nowSaved) {
          saved.push({ slug, title, date_start: date, city, url });

          // Notify native Capacitor code to subscribe to FCM hardware topic
          if (window.Capacitor) {
            window.dispatchEvent(new CustomEvent('fcm:subscribe', { detail: { topic: `event_${slug}` } }));
          } else {
            console.log(`Web simulation: Subscribed to topic event_${slug}`);
          }
        } else {
          saved.splice(idx, 1);

          // Notify native Capacitor code to unsubscribe from FCM hardware topic
          if (window.Capacitor) {
            window.dispatchEvent(new CustomEvent('fcm:unsubscribe', { detail: { topic: `event_${slug}` } }));
          } else {
            console.log(`Web simulation: Unsubscribed from topic event_${slug}`);
          }
        }
        setSaved(saved);

        this.setAttribute('aria-pressed', String(nowSaved));
        this.querySelector('.merken-label').textContent = nowSaved ? 'Gemerkt' : 'Merken';

        // Dispatch event so /meine-events/ page can react without reload
        window.dispatchEvent(new CustomEvent('rg:saved-changed', { detail: { slug, saved: nowSaved } }));
      });
    });
  })();
</script>
