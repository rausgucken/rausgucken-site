---
// src/components/ICSButton.astro
// Portable ICS export button. Usage: <ICSButton events={events} label={pageLabel} />
const { events, label } = Astro.props;
---

<button
  class="action-btn ics-btn"
  id="ics-export-btn"
  type="button"
  aria-label="Alle Veranstaltungen als Kalender exportieren"
  data-label={label}
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
  </svg>
  ICS
</button>

<script type="application/json" id="ics-events-data" aria-hidden="true" set:text={JSON.stringify(events)} />

<script type="module">
import { generateCollectionICS } from "/scripts/ics-export.js";
const btn = document.getElementById("ics-export-btn");
if (btn) {
  btn.addEventListener("click", () => {
    const dataEl = document.getElementById("ics-events-data");
    const events = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];
    const label  = btn.dataset.label || "Veranstaltungen";
    generateCollectionICS(events, label);
  });
}
</script>

<style>
  .ics-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 36px;
    padding: 0 0.85rem;
    background: var(--tag-bg);
    color: var(--text-60);
    border-radius: 20px;
    border: none;
    font-size: 0.82rem;
    font-weight: 500;
    font-family: inherit;
    white-space: nowrap;
    cursor: pointer;
    transition: background 150ms, color 150ms;
  }
  .ics-btn:hover {
    background: var(--coral-light);
    color: var(--coral);
  }
  .ics-btn:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }
</style>
