---
// src/components/FeaturedEvent.astro
const { event } = Astro.props;

const dateFormatted = event?.date_start
  ? new Date(event.date_start + "T00:00:00").toLocaleDateString("de-DE", {
      weekday: "long", day: "numeric", month: "long"
    })
  : null;
---

{event && event.slug && (
  <aside class="featured-event-aside" aria-label="Unser Tipp der Woche">
    <div class="featured-event-header">
      <span class="featured-dot" aria-hidden="true">●</span>
      <span class="featured-label">Unser Tipp der Woche</span>
    </div>

    <h3 class="featured-title">
      <a href={"/ludwigsburg/events/" + event.slug}>{event.title}</a>
    </h3>

    {dateFormatted && (
      <p class="featured-meta">
        {dateFormatted}{event.time ? " · " + event.time : ""}{event.location ? " · " + event.location : ""}
      </p>
    )}

    {event.editorial_tip && (
      <p class="featured-tip">{event.editorial_tip}</p>
    )}

    <a href={"/ludwigsburg/events/" + event.slug} class="featured-cta">
      Mehr erfahren →
    </a>
  </aside>
)}

<style>
  .featured-event-aside {
    background-color: var(--surface-card);
    border-left: 4px solid var(--coral, #FF6F61);
    border-radius: 0.75rem;
    padding: 0.9rem 0.85rem 0.85rem 0.85rem;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-card);
  }

  .featured-event-header {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.45rem;
  }

  .featured-dot {
    color: var(--coral, #FF6F61);
    font-size: 0.55rem;
    line-height: 1;
  }

  .featured-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--coral, #FF6F61);
  }

  .featured-title {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.3rem 0;
    color: var(--text);
  }

  .featured-title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-title a:hover {
    text-decoration: underline;
  }

  .featured-meta {
    font-size: 0.72rem;
    margin: 0 0 0.5rem 0;
    color: var(--text-60);
    line-height: 1.4;
  }

  .featured-tip {
    font-size: 0.75rem;
    line-height: 1.45;
    margin: 0 0 0.75rem 0;
    color: var(--text);
  }

  .featured-cta {
    display: inline-block;
    background-color: var(--coral, #FF6F61);
    color: var(--text-charcoal, #373F51);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 0.4rem;
    text-decoration: none;
    min-height: 32px;
    line-height: 1.8;
  }

  .featured-cta:hover { opacity: 0.88; }
</style>
