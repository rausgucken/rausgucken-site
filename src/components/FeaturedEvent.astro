---
// src/components/FeaturedEvent.astro
const { event } = Astro.props;

const dateFormatted = event?.date_start
  ? new Date(event.date_start + "T00:00:00").toLocaleDateString("de-DE", {
      weekday: "long", day: "numeric", month: "long"
    })
  : null;
---

{event && event.slug && (
  <aside class="featured-event-aside" aria-label="Unser Tipp der Woche">
    <div class="featured-event-header">
      <span class="featured-dot" aria-hidden="true">●</span>
      <span class="featured-label">Unser Tipp der Woche</span>
    </div>

    <h3 class="featured-title">
      <a href={"/ludwigsburg/events/" + event.slug}>{event.title}</a>
    </h3>

    {dateFormatted && (
      <p class="featured-meta">
        {dateFormatted}{event.time ? " · " + event.time : ""}{event.location ? " · " + event.location : ""}
      </p>
    )}

    {event.editorial_tip && (
      <p class="featured-tip">{event.editorial_tip}</p>
    )}

    <a href={"/ludwigsburg/events/" + event.slug} class="featured-cta">
      Mehr erfahren →
    </a>

    <p class="featured-source">
      Quelle: {event.source_label} —{" "}
      <a href={event.original_url} target="_blank" rel="noopener noreferrer" class="featured-source-link">
        Originalseite prüfen
      </a>
    </p>
  </aside>
)}

<style>
  .featured-event-aside {
    background-color: var(--surface-card);
    border-left: 4px solid var(--coral, #FF6F61);
    border-radius: 0.75rem;
    padding: 1.25rem 1rem 1rem 1rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-card);
  }

  .featured-event-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .featured-dot {
    color: var(--coral, #FF6F61);
    font-size: 0.6rem;
    line-height: 1;
  }

  .featured-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--coral, #FF6F61);
  }

  .featured-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.4rem 0;
    color: var(--text);
  }

  .featured-title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-title a:hover {
    text-decoration: underline;
  }

  .featured-meta {
    font-size: 0.78rem;
    margin: 0 0 0.75rem 0;
    color: var(--text-60);
  }

  .featured-tip {
    font-size: 0.875rem;
    line-height: 1.55;
    margin: 0 0 1rem 0;
    color: var(--text);
  }

  .featured-cta {
    display: inline-block;
    background-color: var(--coral, #FF6F61);
    color: var(--text-charcoal, #373F51);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.45rem 0.9rem;
    border-radius: 0.5rem;
    text-decoration: none;
    min-height: 44px;
    line-height: 2.4;
  }

  .featured-cta:hover { opacity: 0.88; }

  .featured-source {
    font-size: 0.7rem;
    margin: 0.75rem 0 0 0;
    color: var(--text-60);
  }

  .featured-source-link {
    color: inherit;
    text-decoration: underline;
  }
</style>
