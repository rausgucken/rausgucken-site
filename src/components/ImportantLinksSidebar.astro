---
import linksJson from "../../config/important-links.json";

type LinkEntry = {
  name: string;
  url: string | null;
  description: string | null;
  external: boolean;
  isHeading?: boolean;
};

const links: LinkEntry[] = linksJson as LinkEntry[];
const resolvedLinks = links.map((link, i) => ({
  ...link,
  resolvedUrl: link.url || '#',
  descId: `sidebar-desc-${i}`,
}));
---

<aside class="important-links-sidebar" aria-label="Wichtige Links">
  <h2 class="sidebar-heading">Wichtige Links</h2>
  <ul class="sidebar-list" role="list">
    {resolvedLinks.map((link) => {
      if (link.isHeading) {
        return <li class="sidebar-section-heading" role="presentation">{link.name}</li>;
      }

      const hasDesc = !!link.description;

      if (link.external) {
        return (
          <li class={`sidebar-item${hasDesc ? ' has-desc' : ''}`}>
            
              href={link.resolvedUrl}
              class="sidebar-link"
              target="_blank"
              rel="nofollow noopener noreferrer"
              aria-describedby={hasDesc ? link.descId : undefined}
            >
              {link.name}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="ext-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            {hasDesc && (
              <span class="sidebar-tooltip" id={link.descId} role="tooltip">{link.description}</span>
            )}
          </li>
        );
      }

      return (
        <li class={`sidebar-item${hasDesc ? ' has-desc' : ''}`}>
          
            href={link.resolvedUrl}
            class="sidebar-link sidebar-link--internal"
            aria-describedby={hasDesc ? link.descId : undefined}
          >
            {link.name} →
          </a>
          {hasDesc && (
            <span class="sidebar-tooltip" id={link.descId} role="tooltip">{link.description}</span>
          )}
        </li>
      );
    })}
  </ul>
</aside>

<style>
  .important-links-sidebar {
    display: none;
  }
  .sidebar-heading {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-60);
    font-family: var(--font-body);
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sidebar-section-heading {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-60);
    font-family: var(--font-body);
    padding: 0.65rem 0 0.3rem;
    border-top: 1px solid var(--border);
    opacity: 0.6;
    margin-top: 0.15rem;
  }
  .sidebar-list > li.sidebar-section-heading:first-child {
    border-top: none;
    padding-top: 0;
  }
  .sidebar-item {
    position: relative;
    display: block;
  }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    line-height: 1.3;
    padding: 0.3rem 0;
    transition: color 150ms;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .sidebar-link:hover,
  .sidebar-link:focus-visible { color: var(--coral); }
  .sidebar-link--internal { color: var(--coral); }
  .sidebar-link--internal:hover { opacity: 0.8; }
  .ext-icon {
    flex-shrink: 0;
    opacity: 0.45;
  }
  .sidebar-tooltip {
    display: none;
    position: absolute;
    right: calc(100% + 10px);
    top: 0;
    width: 180px;
    background: var(--surface-card, #2a2f3a);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.55rem 0.7rem;
    font-size: 0.75rem;
    line-height: 1.45;
    color: var(--text);
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    pointer-events: none;
    z-index: 100;
    white-space: normal;
  }
  .sidebar-tooltip::after {
    content: '';
    position: absolute;
    top: 10px;
    right: -6px;
    width: 10px;
    height: 10px;
    background: var(--surface-card, #2a2f3a);
    border-right: 1px solid var(--border);
    border-top: 1px solid var(--border);
    transform: rotate(45deg);
  }
  .sidebar-item.has-desc:hover .sidebar-tooltip,
  .sidebar-item.has-desc:focus-within .sidebar-tooltip {
    display: block;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sidebar-tooltip {
      opacity: 0;
      transform: translateX(4px);
      transition: opacity 140ms ease, transform 140ms ease;
      display: block;
      pointer-events: none;
    }
    .sidebar-item.has-desc:hover .sidebar-tooltip,
    .sidebar-item.has-desc:focus-within .sidebar-tooltip {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
    }
  }
</style>
