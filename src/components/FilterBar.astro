---
// src/components/FilterBar.astro
// Collapsed by default. Toggle button always visible with active-filter badge.
// Temporal pills are first row inside the bar (real <a> links, crawlable).
---

<div class="filter-wrapper" id="filter-wrapper">

  <!-- Toggle button — always visible, shows active filter count when set -->
  <button class="filter-toggle-btn" id="filter-toggle-btn"
          aria-expanded="false" aria-controls="filter-bar"
          type="button">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
      <line x1="4" y1="6" x2="20" y2="6"/>
      <line x1="4" y1="12" x2="20" y2="12"/>
      <line x1="4" y1="18" x2="20" y2="18"/>
    </svg>
    <span class="toggle-label">Filter &amp; Zeitraum</span>
    <span class="filter-active-badge" id="filter-active-badge" hidden>0</span>
    <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>

  <div class="filter-bar" id="filter-bar" role="search" aria-label="Veranstaltungen filtern" hidden>

    <!-- Temporal shortcut pills — first row, real <a> links for SEO -->
    <div class="filter-shortcuts" aria-label="Schnellauswahl">
      <a href="/ludwigsburg/heute"             class="shortcut-pill" title="Veranstaltungen in Ludwigsburg heute">Heute</a>
      <a href="/ludwigsburg/morgen"            class="shortcut-pill" title="Veranstaltungen in Ludwigsburg morgen">Morgen</a>
      <a href="/ludwigsburg/dieses-wochenende" class="shortcut-pill" title="Events Ludwigsburg dieses Wochenende">Wochenende</a>
      <a href="/ludwigsburg/naechste-woche"    class="shortcut-pill" title="Events Ludwigsburg nächste Woche">Nächste Woche</a>
      <a href="/ludwigsburg/kinder"            class="shortcut-pill shortcut-pill--sage" title="Kinderveranstaltungen Ludwigsburg" aria-label="Kinderveranstaltungen Ludwigsburg"><span class="dual-dot" aria-hidden="true">● ·</span> Kinder &amp; Familie</a>
    </div>

    <div class="filter-controls">
      <!-- 1. DATE FROM -->
      <div class="filter-group">
        <label for="date-from">Von</label>
        <input type="date" id="date-from" aria-label="Datum von" />
      </div>

      <!-- 2. DATE TO -->
      <div class="filter-group">
        <label for="date-to">Bis</label>
        <input type="date" id="date-to" aria-label="Datum bis" />
      </div>

      <!-- 3. LOCATION -->
      <div class="filter-group">
        <label for="location-filter">Ort</label>
        <select id="location-filter" aria-label="Ort filtern">
          <option value="">Alle Orte</option>
        </select>
      </div>

      <!-- 4. CATEGORY -->
      <div class="filter-group">
        <label for="tag-filter">Kategorie</label>
        <select id="tag-filter" aria-label="Kategorie filtern">
          <option value="">Alle Kategorien</option>
          <option value="Ausstellung">Ausstellung</option>
          <option value="Entertainment">Entertainment</option>
          <option value="Familie">● · Familie</option>
          <option value="Fest">Fest</option>
          <option value="Fuehrung">Führung</option>
          <option value="Jugend">Jugend</option>
          <option value="Kinder">Kinder</option>
          <option value="Kulinarik">Kulinarik</option>
          <option value="Lesung">Lesung</option>
          <option value="Messe">Messe</option>
          <option value="Messe">Messe</option>
          <option value="Musik">Musik</option>
          <option value="Outdoor">Outdoor</option>
          <option value="Sprache">Sprache</option>
          <option value="Sprache">Sprache</option>
          <option value="Sport">Sport</option>
          <option value="Tanz">Tanz</option>
          <option value="Theater">Theater</option>
          <option value="Vortrag">Vortrag</option>
          <option value="Workshop">Workshop</option>
        </select>
      </div>

      <!-- 5. AGE GROUP -->
      <div class="filter-group">
        <label for="age-filter">Altersgruppe</label>
        <select id="age-filter" aria-label="Altersgruppe filtern">
          <option value="0-99">Alle Altersgruppen</option>
          <option value="0-3">0–3 Jahre</option>
          <option value="3-6">3–6 Jahre</option>
          <option value="6-12">6–12 Jahre</option>
          <option value="12-17">12–17 Jahre</option>
          <option value="18-99">Erwachsene (18+)</option>
        </select>
      </div>

      <button id="filter-reset" class="filter-reset" type="button" aria-label="Alle Filter zurücksetzen">
        ✕ Zurücksetzen
      </button>

      <span class="filter-count" id="filter-count" aria-live="polite" aria-atomic="true"></span>
    </div>

  </div>
</div>

<style>
  .filter-wrapper {
    position: sticky;
    top: 64px;
    z-index: 10;
    background: var(--bg);
    padding: 0.6rem 0 0;
    margin-bottom: 1.25rem;
    transition: background 250ms ease;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Toggle button — always visible ──────────────────────────────────────── */
  .filter-toggle-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.6rem 1rem;
    background: var(--surface-card);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    transition: border-color 150ms, background 150ms;
    min-height: 44px;
    box-shadow: var(--shadow-card);
  }
  .filter-toggle-btn:hover { border-color: var(--coral); }
  .filter-toggle-btn:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .filter-toggle-btn[aria-expanded="true"] { border-color: var(--coral); border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom-color: transparent; }

  .toggle-label { flex: 1; }

  .chevron { margin-left: auto; transition: transform 200ms ease; flex-shrink: 0; }
  .filter-toggle-btn[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  /* Active filter badge on toggle button */
  .filter-active-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    background: var(--coral);
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 20px;
    flex-shrink: 0;
  }

  /* ── Filter bar — hidden by default, opens downward ──────────────────────── */
  .filter-bar {
    background: var(--surface-card);
    border: 1.5px solid var(--coral);
    border-top: none;
    border-bottom-left-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
    padding: 0.85rem 1rem 1rem;
    box-shadow: var(--shadow-card);
    transition: background 250ms ease;
  }
  /* [hidden] from Base.astro globals handles display:none */

  /* ── Temporal shortcut pills ──────────────────────────────────────────────── */
  .filter-shortcuts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }
  .shortcut-pill {
    display: inline-flex;
    align-items: center;
    height: 34px;
    min-height: 44px;
    padding: 0 0.85rem;
    background: var(--coral);
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 20px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 150ms, transform 150ms;
  }
  .shortcut-pill:hover { background: var(--coral-dark); transform: translateY(-1px); text-decoration: none; }
  .shortcut-pill:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .shortcut-pill--sage { background: var(--sage); color: var(--text); }
  .shortcut-pill--sage:hover { background: #7aaa58; }

  /* ── Filter controls row ─────────────────────────────────────────────────── */
  .filter-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 0.85rem;
    align-items: flex-end;
  }

  .filter-group { display: flex; flex-direction: column; gap: 0.3rem; }

  label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-60);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  select, input[type="date"] {
    height: 44px;
    padding: 0 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    transition: border-color 150ms, background 250ms, color 250ms;
    appearance: auto;
    -webkit-appearance: auto;
    min-width: 0;
  }
  select             { min-width: 140px; max-width: 210px; }
  #location-filter   { max-width: 175px; }
  input[type="date"] { width: 148px; padding: 0 0.6rem; box-sizing: border-box; }

  select:focus, input[type="date"]:focus {
    outline: none; border-color: var(--coral); box-shadow: 0 0 0 3px var(--coral-light);
  }
  select:hover, input[type="date"]:hover { border-color: var(--coral); }
  html.dark input[type="date"] { color-scheme: dark; }

  .filter-reset {
    height: 44px; padding: 0 1rem;
    background: transparent; border: 1.5px solid var(--border);
    border-radius: var(--radius-sm); font-family: var(--font-body);
    font-size: 0.82rem; font-weight: 600; color: var(--text-60);
    cursor: pointer; transition: border-color 150ms, color 150ms, background 150ms;
    align-self: flex-end; white-space: nowrap;
  }
  .filter-reset:hover { border-color: var(--coral); color: var(--coral); background: var(--coral-light); }
  .filter-reset:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }

  .filter-count {
    font-size: 0.82rem; font-weight: 500; color: var(--text-60);
    align-self: flex-end; padding-bottom: 0.6rem; white-space: nowrap;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .filter-wrapper { top: 64px; }
    .filter-controls { gap: 0.55rem; }
    .filter-group { flex: 1 1 calc(50% - 0.55rem); min-width: 0; overflow: hidden; }
    select { min-width: 0; width: 100%; max-width: 100%; }
    input[type="date"] { width: 100%; min-width: 0; max-width: 100%; box-sizing: border-box; }
    .filter-reset { width: 100%; }
  }
  @media (max-width: 380px) {
    .filter-group { flex: 1 1 100%; }
  }

  /* ── Dual-dot icon — Familie / Kinder pill ──────────────────────────────── */
  /* Dot Doctrine: dual-dot = shared presence (family, community) */
  .dual-dot {
    font-size: 0.65em;
    letter-spacing: 0.05em;
    opacity: 0.85;
    margin-right: 0.2em;
    flex-shrink: 0;
  }
</style>
