---
/**
 * src/components/SEOHead.astro
 * ─────────────────────────────
 * Drop this into every page's <head>.
 * Handles: canonical, hreflang, lang, OG tags, Twitter card, OG image.
 *
 * OG images are generated by generate_og_images.py and served from
 * /og/{city}/{slug}.jpg  (Cloudflare Pages static asset).
 *
 * Usage examples:
 *
 *   <!-- City page -->
 *   <SEOHead
 *     title="Veranstaltungen in Ludwigsburg | rausgucken.de"
 *     description="142 aktuelle Events in Ludwigsburg. Kinder, Kultur, kostenlos."
 *     canonical="https://rausgucken.de/ludwigsburg/"
 *     ogImage="/og/ludwigsburg/city.jpg"
 *   />
 *
 *   <!-- Temporal intent page -->
 *   <SEOHead
 *     title={`Events Ludwigsburg heute (${todayFormatted}) | rausgucken.de`}
 *     description="Was ist heute in Ludwigsburg los?"
 *     canonical="https://rausgucken.de/ludwigsburg/heute/"
 *     ogImage="/og/ludwigsburg/heute.jpg"
 *   />
 *
 *   <!-- Per-event page -->
 *   <SEOHead
 *     title={`${event.title} | rausgucken.de`}
 *     description={event.description?.slice(0, 155)}
 *     canonical={`https://rausgucken.de/ludwigsburg/events/${event.slug}/`}
 *     ogImage={`/og/ludwigsburg/${event.slug}.jpg`}
 *   />
 */

interface Props {
  title: string;
  description?: string;
  canonical: string;
  ogImage?: string;        // e.g. "/og/ludwigsburg/heute.jpg"
  noindex?: boolean;
  schemaJson?: string;     // pre-serialised JSON-LD string
}

const {
  title,
  description = "Aktuelle Veranstaltungen, Events und Ausstellungen auf rausgucken.de.",
  canonical,
  ogImage,
  noindex = false,
  schemaJson,
} = Astro.props;

const SITE_URL = "https://rausgucken.de";

// Resolve OG image: prefer provided, fallback to city default, then global fallback
const resolvedOgImage = ogImage
  ? `${SITE_URL}${ogImage}`
  : `${SITE_URL}/og/default.jpg`;
---

<!-- Language -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Canonical & hreflang -->
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="de" href={canonical} />
<!-- Add x-default only when non-German content exists -->

<!-- Primary SEO -->
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, follow" />}

<!-- Open Graph (Facebook, WhatsApp, Telegram, LinkedIn) -->
<meta property="og:type"        content="website" />
<meta property="og:url"         content={canonical} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={resolvedOgImage} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt"   content={title} />
<meta property="og:locale"      content="de_DE" />
<meta property="og:site_name"   content="rausgucken.de" />

<!-- Twitter Card (also used by many other platforms) -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={resolvedOgImage} />

<!-- Structured Data (JSON-LD) injected by parent page -->
{schemaJson && <script type="application/ld+json" set:html={schemaJson} />}
