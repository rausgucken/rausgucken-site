---
// src/components/QRExportModal.astro
// QR export/import for rg-saved localStorage events.
// Export: encodes saved array as QR. Import: camera scan → preview → confirm.
// No server, no accounts, no GDPR surface.
---

<!-- Export/Import trigger bar -->
<div class="qr-transfer-bar">
  <button class="qr-transfer-btn" id="qr-export-open" type="button" aria-label="Gespeicherte Events als QR-Code exportieren">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="5" y="5" width="3" height="3" fill="currentColor" stroke="none"/>
      <rect x="16" y="5" width="3" height="3" fill="currentColor" stroke="none"/>
      <rect x="5" y="16" width="3" height="3" fill="currentColor" stroke="none"/>
      <circle cx="17.5" cy="17.5" r="1.5" fill="currentColor" stroke="none"/>
      <rect x="14" y="14" width="3" height="3" fill="currentColor" stroke="none"/>
    </svg>
    Auf neues Gerät übertragen
  </button>
  <button class="qr-transfer-btn qr-transfer-btn--secondary" id="qr-import-open" type="button" aria-label="Events von anderem Gerät importieren">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
      <circle cx="12" cy="13" r="3"/>
    </svg>
    QR-Code scannen
  </button>
</div>

<!-- ── EXPORT MODAL ─────────────────────────────────────────────────────── -->
<div id="qr-export-modal" class="qr-tm-modal" role="dialog" aria-modal="true" aria-labelledby="qr-export-title" hidden>
  <div class="qr-tm-backdrop" id="qr-export-backdrop"></div>
  <div class="qr-tm-box">
    <div class="qr-tm-header">
      <span id="qr-export-title" class="qr-tm-title">Events übertragen</span>
      <button class="qr-tm-close" id="qr-export-close" aria-label="Schließen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

        <p class="qr-tm-desc">
      Scanne diesen QR-Code mit der Kamera deines neuen Geräts.
      Die Meine-Events-Seite öffnet sich automatisch mit einer Importvorschau.
    </p>

    <div class="qr-tm-canvas-wrap" id="qr-export-canvas"></div>

    <p class="qr-tm-hint" id="qr-export-hint"></p>

    <p class="qr-tm-note">Keine persönlichen Daten, kein Account erforderlich.</p>
  </div>
</div>

<!-- ── IMPORT MODAL ─────────────────────────────────────────────────────── -->
<div id="qr-import-modal" class="qr-tm-modal" role="dialog" aria-modal="true" aria-labelledby="qr-import-title" hidden>
  <div class="qr-tm-backdrop" id="qr-import-backdrop"></div>
  <div class="qr-tm-box">
    <div class="qr-tm-header">
      <span id="qr-import-title" class="qr-tm-title">QR-Code scannen</span>
      <button class="qr-tm-close" id="qr-import-close" aria-label="Schließen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Camera view -->
    <div id="qr-scanner-wrap" class="qr-scanner-wrap">
      <video id="qr-video" class="qr-video" playsinline muted autoplay></video>
      <canvas id="qr-scan-canvas" class="qr-scan-canvas" aria-hidden="true"></canvas>
      <div class="qr-scan-overlay">
        <div class="qr-scan-frame"></div>
      </div>
      <p class="qr-scan-hint">Halte die Kamera auf den QR-Code</p>
    </div>

    <!-- Preview (shown after successful decode, before confirm) -->
    <div id="qr-import-preview" class="qr-import-preview" hidden>
      <div class="qr-preview-counts" id="qr-preview-counts"></div>
      <div class="qr-preview-list" id="qr-preview-list"></div>
      <div class="qr-preview-actions">
        <button class="qr-preview-confirm" id="qr-import-confirm" type="button">
          Importieren
        </button>
        <button class="qr-preview-cancel" id="qr-import-retry" type="button">
          Erneut scannen
        </button>
      </div>
    </div>

    <!-- Success state -->
    <div id="qr-import-success" class="qr-import-success" hidden>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#90BE6D" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      <p id="qr-import-success-msg"></p>
    </div>

    <!-- Error state -->
    <p id="qr-import-error" class="qr-import-error" hidden></p>
  </div>
</div>

<script>

// ── localStorage helpers ─────────────────────────────────────────────────────
const STORAGE_KEY = 'rg-saved';
function getSaved() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
}
function setSaved(arr) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr)); } catch {}
}

// ── Date helpers ─────────────────────────────────────────────────────────────
function isExpired(dateStr) {
  if (!dateStr) return false;
  return new Date(dateStr + 'T23:59:59') < new Date();
}
function formatDateShort(iso) {
  if (!iso) return 'Regelmäßig';
  return new Date(iso + 'T12:00:00').toLocaleDateString('de-DE', { day: 'numeric', month: 'short' });
}
function sanitise(str) {
  const d = document.createElement('div');
  d.appendChild(document.createTextNode(str || ''));
  return d.innerHTML;
}

// ── Payload: real HTTPS URL so phone camera opens browser directly ───────────
// Format: https://www.rausgucken.de/meine-events/?import=city|slug,city|slug
const BASE_URL   = 'https://www.rausgucken.de/meine-events/';
const CHUNK_SIZE = 10;

function encodePages(saved) {
  const upcoming = saved.filter(ev => !isExpired(ev.date_start));
  if (!upcoming.length) return [];
  const pages = [];
  for (let i = 0; i < upcoming.length; i += CHUNK_SIZE) {
    const pairs = upcoming.slice(i, i + CHUNK_SIZE)
      .map(ev => (ev.city || 'ludwigsburg') + '|' + ev.slug);
    pages.push(BASE_URL + '?import=' + encodeURIComponent(pairs.join(',')));
  }
  return pages;
}

function decodeImportParam(raw) {
  if (!raw) return null;
  try {
    return raw.split(',').map(pair => {
      const sep = pair.indexOf('|');
      if (sep === -1) return null;
      const city = pair.slice(0, sep).trim();
      const slug = pair.slice(sep + 1).trim();
      if (!city || !slug) return null;
      return { slug, title: slug, date_start: null, city, url: '/' + city + '/events/' + slug };
    }).filter(Boolean);
  } catch { return null; }
}

// ── Load libraries via script tag (reliable in Astro, no ESM issues) ─────────
function loadScript(src) {
  return new Promise((resolve, reject) => {
    if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src; s.onload = resolve; s.onerror = reject;
    document.head.appendChild(s);
  });
}

// qrcode.js CDN — renders to <canvas> when given a canvas element
const QRCODEJS_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
// jsQR CDN — pure browser build, no ESM/CJS issues
const JSQR_CDN     = 'https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js';

// ── EXPORT ───────────────────────────────────────────────────────────────────
const exportOpenBtn  = document.getElementById('qr-export-open');
const exportModal    = document.getElementById('qr-export-modal');
const exportBackdrop = document.getElementById('qr-export-backdrop');
const exportClose    = document.getElementById('qr-export-close');
const exportCanvas   = document.getElementById('qr-export-canvas');
const exportHint     = document.getElementById('qr-export-hint');

let qrPages   = [];
let qrPageIdx = 0;

function renderQRPage(idx) {
  exportCanvas.innerHTML = '';

  // Create a dedicated canvas element for qrcode.js
  const canvas = document.createElement('canvas');
  exportCanvas.appendChild(canvas);

  new window.QRCode(canvas, {
    text:         qrPages[idx],
    width:        260,
    height:       260,
    colorDark:    '#000000',
    colorLight:   '#ffffff',
    correctLevel: window.QRCode.CorrectLevel.M,
  });

  const total = qrPages.length;
  if (total > 1) {
    exportHint.innerHTML =
      `<button id="qr-prev" style="background:none;border:none;cursor:pointer;color:var(--coral);font-size:1.2rem;padding:0 8px;opacity:${idx===0?0.3:1}" ${idx===0?'disabled':''}>&#9664;</button>` +
      `<span style="font-size:0.82rem;color:var(--text-60)">Seite&nbsp;${idx+1}&nbsp;von&nbsp;${total}</span>` +
      `<button id="qr-next" style="background:none;border:none;cursor:pointer;color:var(--coral);font-size:1.2rem;padding:0 8px;opacity:${idx===total-1?0.3:1}" ${idx===total-1?'disabled':''}>&#9654;</button>`;
    document.getElementById('qr-prev').addEventListener('click', () => {
      if (qrPageIdx > 0) { qrPageIdx--; renderQRPage(qrPageIdx); }
    });
    document.getElementById('qr-next').addEventListener('click', () => {
      if (qrPageIdx < qrPages.length - 1) { qrPageIdx++; renderQRPage(qrPageIdx); }
    });
  } else {
    exportHint.textContent = '';
  }
}

async function openExportModal() {
  const saved    = getSaved();
  const upcoming = saved.filter(ev => !isExpired(ev.date_start));

  if (!upcoming.length) {
    alert(saved.length
      ? 'Alle gespeicherten Events sind vergangen — nichts zu übertragen.'
      : 'Keine gespeicherten Events zum Übertragen.');
    return;
  }

  exportModal.hidden = false;
  document.body.style.overflow = 'hidden';
  exportClose.focus();
  exportCanvas.innerHTML = '';
  exportHint.textContent = '';

  qrPages   = encodePages(saved);
  qrPageIdx = 0;

  await loadScript(QRCODEJS_CDN);
  renderQRPage(0);
}

function closeExportModal() {
  exportModal.hidden = true;
  document.body.style.overflow = '';
  exportOpenBtn.focus();
}

exportOpenBtn.addEventListener('click',  openExportModal);
exportClose.addEventListener('click',   closeExportModal);
exportBackdrop.addEventListener('click', closeExportModal);

// ── IMPORT via URL ?import= param (phone camera scan) ────────────────────────
function handleImportParam() {
  const params = new URLSearchParams(window.location.search);
  const raw    = params.get('import');
  if (!raw) return;
  const events = decodeImportParam(decodeURIComponent(raw));
  if (!events || !events.length) return;
  window.history.replaceState({}, '', window.location.pathname);
  openImportPreview(events);
}

function openImportPreview(events) {
  decodedEvents = events;
  importModal.hidden = false;
  document.body.style.overflow = 'hidden';
  scannerWrap.hidden = true;
  errorEl.hidden     = true;
  successEl.hidden   = true;
  retryBtn.hidden    = true;
  renderPreview(events);
  previewEl.hidden = false;
}

// ── IMPORT via in-app camera ──────────────────────────────────────────────────
const importOpenBtn  = document.getElementById('qr-import-open');
const importModal    = document.getElementById('qr-import-modal');
const importBackdrop = document.getElementById('qr-import-backdrop');
const importClose    = document.getElementById('qr-import-close');
const scannerWrap    = document.getElementById('qr-scanner-wrap');
const videoEl        = document.getElementById('qr-video');
const scanCanvas     = document.getElementById('qr-scan-canvas');
const previewEl      = document.getElementById('qr-import-preview');
const previewCounts  = document.getElementById('qr-preview-counts');
const previewList    = document.getElementById('qr-preview-list');
const confirmBtn     = document.getElementById('qr-import-confirm');
const retryBtn       = document.getElementById('qr-import-retry');
const successEl      = document.getElementById('qr-import-success');
const successMsg     = document.getElementById('qr-import-success-msg');
const errorEl        = document.getElementById('qr-import-error');

let stream        = null;
let scanRAF       = 0;
let decodedEvents = null;
let jsQRfn        = null; // window.jsQR after CDN load

function resetImportUI(keepAccumulated) {
  scannerWrap.hidden = false;
  previewEl.hidden   = true;
  successEl.hidden   = true;
  errorEl.hidden     = true;
  retryBtn.hidden    = false;
  retryBtn.textContent = 'Weitere Seite scannen';
  if (!keepAccumulated) decodedEvents = null;
}

async function startCamera() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 480 } }
    });
    videoEl.srcObject = stream;
    await videoEl.play();
    scanLoop();
  } catch (err) {
    showImportError('Kamera nicht verfügbar: ' + (err.message || err));
  }
}

function stopCamera() {
  cancelAnimationFrame(scanRAF);
  if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
  videoEl.srcObject = null;
}

function scanLoop() {
  // jsQR loaded via CDN script tag → available as window.jsQR
  if (!window.jsQR || videoEl.readyState < videoEl.HAVE_ENOUGH_DATA) {
    scanRAF = requestAnimationFrame(scanLoop);
    return;
  }
  const ctx = scanCanvas.getContext('2d', { willReadFrequently: true });
  scanCanvas.width  = videoEl.videoWidth;
  scanCanvas.height = videoEl.videoHeight;
  ctx.drawImage(videoEl, 0, 0);
  const img  = ctx.getImageData(0, 0, scanCanvas.width, scanCanvas.height);
  const code = window.jsQR(img.data, img.width, img.height);

  if (code?.data) {
    try {
      const url    = new URL(code.data);
      const raw    = url.searchParams.get('import');
      const decoded = raw ? decodeImportParam(decodeURIComponent(raw)) : null;
      if (decoded && decoded.length) {
        stopCamera();
        const existing   = decodedEvents || [];
        const existSlugs = new Set(existing.map(e => e.slug));
        const merged     = [...existing, ...decoded.filter(e => !existSlugs.has(e.slug))];
        renderPreview(merged);
        scannerWrap.hidden = true;
        previewEl.hidden   = false;
        return;
      }
    } catch {}
  }
  scanRAF = requestAnimationFrame(scanLoop);
}

function renderPreview(events) {
  decodedEvents = events;
  const upcoming = events.filter(ev => !isExpired(ev.date_start));
  const expired  = events.filter(ev => ev.date_start && isExpired(ev.date_start));

  previewCounts.innerHTML =
    `<div class="qr-preview-stat qr-preview-stat--upcoming">
       <span class="qr-preview-num">${upcoming.length}</span>
       <span class="qr-preview-label">bevorstehend</span>
     </div>` +
    (expired.length
      ? `<div class="qr-preview-stat qr-preview-stat--expired">
           <span class="qr-preview-num">${expired.length}</span>
           <span class="qr-preview-label">vergangen</span>
         </div>` : '');

  previewList.innerHTML = [...upcoming, ...expired].slice(0, 8).map(ev =>
    `<div class="qr-preview-item${isExpired(ev.date_start) ? ' qr-preview-item--past' : ''}">
       <span class="qr-preview-date">${formatDateShort(ev.date_start)}</span>
       <span class="qr-preview-title">${sanitise(ev.title)}</span>
     </div>`
  ).join('') +
  (events.length > 8 ? `<div class="qr-preview-more">+ ${events.length - 8} weitere</div>` : '');

  confirmBtn.textContent = `${upcoming.length} Event${upcoming.length !== 1 ? 's' : ''} übernehmen`;
}

function showImportError(msg) {
  stopCamera();
  scannerWrap.hidden  = true;
  errorEl.textContent = msg;
  errorEl.hidden      = false;
}

function doImport() {
  if (!decodedEvents) return;
  const existing   = getSaved();
  const existSlugs = new Set(existing.map(e => e.slug));
  const toAdd      = decodedEvents.filter(ev => !existSlugs.has(ev.slug));
  setSaved([...existing, ...toAdd]);
  window.dispatchEvent(new CustomEvent('rg:saved-changed'));
  previewEl.hidden = true;
  successMsg.textContent = toAdd.length
    ? `${toAdd.length} neues Event${toAdd.length !== 1 ? 's' : ''} importiert.`
    : 'Alle Events bereits gespeichert.';
  successEl.hidden = false;
}

async function openImportModal() {
  importModal.hidden = false;
  document.body.style.overflow = 'hidden';
  importClose.focus();
  resetImportUI(false);
  // Load jsQR via script tag — avoids ESM/CJS dynamic import issues in Astro
  await loadScript(JSQR_CDN).catch(() => showImportError('jsQR konnte nicht geladen werden.'));
  await startCamera();
}

function closeImportModal() {
  stopCamera();
  importModal.hidden = true;
  document.body.style.overflow = '';
  importOpenBtn.focus();
  resetImportUI(false);
}

importOpenBtn.addEventListener('click',  openImportModal);
importClose.addEventListener('click',   closeImportModal);
importBackdrop.addEventListener('click', closeImportModal);
confirmBtn.addEventListener('click', doImport);
retryBtn.addEventListener('click', async () => {
  resetImportUI(true);
  await startCamera();
});
document.addEventListener('keydown', e => {
  if (e.key !== 'Escape') return;
  if (!exportModal.hidden) closeExportModal();
  if (!importModal.hidden) closeImportModal();
});

// Run on page load — handles phone camera scan → browser open → auto import
handleImportParam();
</script>

<style>
  /* ── Transfer bar ──────────────────────────────────────────────────────── */
  .qr-transfer-bar {
    max-width: 720px;
    margin: 0 auto 1.5rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .qr-transfer-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    height: 40px;
    padding: 0 1rem;
    background: var(--tag-bg);
    color: var(--text-60);
    border: 1.5px solid var(--border);
    border-radius: 20px;
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 150ms, color 150ms, border-color 150ms;
    min-height: 44px;
  }
  .qr-transfer-btn:hover {
    background: var(--coral-light);
    color: var(--coral);
    border-color: var(--coral);
  }
  .qr-transfer-btn:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .qr-transfer-btn--secondary { background: transparent; }

  /* ── Shared modal chrome ───────────────────────────────────────────────── */
  .qr-tm-modal {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .qr-tm-modal[hidden] { display: none; }

  .qr-tm-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(2px);
  }

  .qr-tm-box {
    position: relative;
    background: var(--surface-card);
    border-radius: var(--radius, 12px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    padding: 1.5rem;
    width: 100%;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-height: 90vh;
    overflow-y: auto;
  }

  .qr-tm-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .qr-tm-title {
    font-family: var(--font-heading, inherit);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }
  .qr-tm-close {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    background: var(--tag-bg); border: none; border-radius: 50%;
    color: var(--text-60); cursor: pointer; transition: background 150ms;
    flex-shrink: 0;
  }
  .qr-tm-close:hover { background: var(--coral-light); color: var(--coral); }
  .qr-tm-close:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }

  .qr-tm-desc {
    font-size: 0.84rem;
    color: var(--text-60);
    text-align: center;
    line-height: 1.5;
    margin: 0;
    width: 100%;
  }
  .qr-tm-hint {
    font-size: 0.82rem;
    color: var(--coral);
    font-weight: 600;
    margin: 0;
  }
  .qr-tm-note {
    font-size: 0.75rem;
    color: var(--text-30);
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Export canvas ─────────────────────────────────────────────────────── */
  .qr-tm-canvas-wrap {
    width: 260px; height: 260px;
    border-radius: 12px; overflow: hidden;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
  }
  .qr-tm-canvas-wrap canvas { display: block; width: 260px !important; height: 260px !important; }

  /* ── Scanner ───────────────────────────────────────────────────────────── */
  .qr-scanner-wrap {
    position: relative;
    width: 100%;
    max-width: 300px;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }
  .qr-video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .qr-scan-canvas { display: none; } /* off-screen processing */

  .qr-scan-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .qr-scan-frame {
    width: 60%; aspect-ratio: 1;
    border: 2.5px solid var(--coral);
    border-radius: 8px;
    box-shadow: 0 0 0 9999px rgba(0,0,0,0.35);
  }
  .qr-scan-hint {
    position: absolute; bottom: 0.75rem; left: 0; right: 0;
    text-align: center;
    font-size: 0.78rem; color: rgba(255,255,255,0.85);
    margin: 0;
  }

  /* ── Import preview ────────────────────────────────────────────────────── */
  .qr-import-preview { width: 100%; }

  .qr-preview-counts {
    display: flex; gap: 0.75rem; justify-content: center;
    margin-bottom: 1rem;
  }
  .qr-preview-stat {
    display: flex; flex-direction: column; align-items: center;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm, 8px);
    border: 1px solid var(--border);
    min-width: 90px;
  }
  .qr-preview-stat--upcoming { background: var(--sage-light); border-color: var(--sage); }
  .qr-preview-stat--expired  { background: var(--tag-bg); }
  .qr-preview-num   { font-size: 1.6rem; font-weight: 800; font-family: var(--font-heading); color: var(--text); line-height: 1; }
  .qr-preview-label { font-size: 0.72rem; color: var(--text-60); margin-top: 0.2rem; }

  .qr-preview-list {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm, 8px);
    overflow: hidden;
    margin-bottom: 1rem;
