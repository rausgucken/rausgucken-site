---
// src/components/QRExportModal.astro
// QR export/import for rg-saved localStorage events.
// Export: encodes saved array as QR. Import: camera scan → preview → confirm.
// No server, no accounts, no GDPR surface.
---

<!-- Export/Import trigger bar -->
<div class="qr-transfer-bar">
  <button class="qr-transfer-btn" id="qr-export-open" type="button" aria-label="Gespeicherte Events als QR-Code exportieren">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="5" y="5" width="3" height="3" fill="currentColor" stroke="none"/>
      <rect x="16" y="5" width="3" height="3" fill="currentColor" stroke="none"/>
      <rect x="5" y="16" width="3" height="3" fill="currentColor" stroke="none"/>
      <circle cx="17.5" cy="17.5" r="1.5" fill="currentColor" stroke="none"/>
      <rect x="14" y="14" width="3" height="3" fill="currentColor" stroke="none"/>
    </svg>
    Auf neues Gerät übertragen
  </button>

</div>

<!-- ── EXPORT MODAL ─────────────────────────────────────────────────────── -->
<div id="qr-export-modal" class="qr-tm-modal" role="dialog" aria-modal="true" aria-labelledby="qr-export-title" hidden>
  <div class="qr-tm-backdrop" id="qr-export-backdrop"></div>
  <div class="qr-tm-box">
    <div class="qr-tm-header">
      <span id="qr-export-title" class="qr-tm-title">Events übertragen</span>
      <button class="qr-tm-close" id="qr-export-close" aria-label="Schließen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

        <p class="qr-tm-desc">
      Scanne diesen QR-Code mit der Kamera deines neuen Geräts.
      Die Meine-Events-Seite öffnet sich automatisch mit einer Importvorschau.
    </p>

    <div class="qr-tm-canvas-wrap"><canvas id="qr-export-canvas" width="256" height="256"></canvas></div>

    <p class="qr-tm-hint" id="qr-export-hint"></p>

    <!-- 6-digit transfer code -->
    <div class="qr-code-display">
      <span class="qr-code-label">oder Code eingeben</span>
      <span class="qr-code-number" id="qr-export-code">……</span>
      <span class="qr-code-ttl" id="qr-export-status"></span>
    </div>

    <p class="qr-tm-note">Keine persönlichen Daten, kein Account erforderlich.</p>
  </div>
</div>

<!-- ── IMPORT MODAL ─────────────────────────────────────────────────────── -->
<div id="qr-import-modal" class="qr-tm-modal" role="dialog" aria-modal="true" aria-labelledby="qr-import-title" hidden>
  <div class="qr-tm-backdrop" id="qr-import-backdrop"></div>
  <div class="qr-tm-box">
    <div class="qr-tm-header">
      <span id="qr-import-title" class="qr-tm-title">QR-Code scannen</span>
      <button class="qr-tm-close" id="qr-import-close" aria-label="Schließen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Camera view -->
    <div id="qr-scanner-wrap" class="qr-scanner-wrap">
      <video id="qr-video" class="qr-video" playsinline muted autoplay></video>
      <canvas id="qr-scan-canvas" class="qr-scan-canvas" aria-hidden="true"></canvas>
      <div class="qr-scan-overlay">
        <div class="qr-scan-frame"></div>
      </div>
      <p class="qr-scan-hint">Halte die Kamera auf den QR-Code</p>
    </div>

    <!-- Preview (shown after successful decode, before confirm) -->
    <div id="qr-import-preview" class="qr-import-preview" hidden>
      <div class="qr-preview-counts" id="qr-preview-counts"></div>
      <div class="qr-preview-list" id="qr-preview-list"></div>
      <div class="qr-preview-actions">
        <button class="qr-preview-confirm" id="qr-import-confirm" type="button">
          Importieren
        </button>
        <button class="qr-preview-cancel" id="qr-import-retry" type="button">
          Erneut scannen
        </button>
      </div>
    </div>

    <!-- Success state -->
    <div id="qr-import-success" class="qr-import-success" hidden>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#90BE6D" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      <p id="qr-import-success-msg"></p>
    </div>

    <!-- Error state -->
    <p id="qr-import-error" class="qr-import-error" hidden></p>

    <!-- Manual code entry fallback -->
    <div id="qr-code-entry" class="qr-code-entry" hidden>
      <p class="qr-code-entry-label">Code vom anderen Gerät eingeben:</p>
      <div class="qr-code-entry-row">
        <input id="qr-code-input" class="qr-code-input" type="text"
               inputmode="numeric" maxlength="7" placeholder="000 000"
               autocomplete="off" />
        <button id="qr-code-submit" class="qr-code-submit" type="button">Bestätigen</button>
      </div>
      <p id="qr-code-error" class="qr-code-error" hidden></p>
    </div>
  </div>
</div>

<script>
// ── Config ───────────────────────────────────────────────────────────────────
const PUSH_URL    = 'https://push.rausgucken.de';
const BASE_URL    = 'https://www.rausgucken.de/meine-events/';
const CHUNK_SIZE  = 10;
const STORAGE_KEY = 'rg-saved';

// ── localStorage ─────────────────────────────────────────────────────────────
function getSaved() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
}
function setSaved(arr) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr)); } catch {}
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function isExpired(dateStr) {
  if (!dateStr) return false;
  return new Date(dateStr + 'T23:59:59') < new Date();
}
function formatDateShort(iso) {
  if (!iso) return 'Regelmäßig';
  return new Date(iso + 'T12:00:00').toLocaleDateString('de-DE', { day: 'numeric', month: 'short' });
}
function sanitise(str) {
  const d = document.createElement('div');
  d.appendChild(document.createTextNode(str || ''));
  return d.innerHTML;
}

// ── Payload encoding ──────────────────────────────────────────────────────────
// "city|slug,city|slug,..." — upcoming events only, chunked
function buildPayloadChunks(saved) {
  const upcoming = saved.filter(ev => !isExpired(ev.date_start));
  if (!upcoming.length) return [];
  const chunks = [];
  for (let i = 0; i < upcoming.length; i += CHUNK_SIZE) {
    chunks.push(
      upcoming.slice(i, i + CHUNK_SIZE)
        .map(ev => (ev.city || 'ludwigsburg') + '|' + ev.slug)
        .join(',')
    );
  }
  return chunks;
}

function decodePayloadString(raw) {
  if (!raw) return null;
  try {
    return raw.split(',').map(pair => {
      const sep = pair.indexOf('|');
      if (sep === -1) return null;
      const city = pair.slice(0, sep).trim();
      const slug = pair.slice(sep + 1).trim();
      if (!city || !slug) return null;
      return { slug, title: slug, date_start: null, city, url: '/' + city + '/events/' + slug };
    }).filter(Boolean);
  } catch { return null; }
}

// ── Script loader ─────────────────────────────────────────────────────────────
function loadScript(src) {
  return new Promise((resolve, reject) => {
    if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src; s.onload = resolve; s.onerror = reject;
    document.head.appendChild(s);
  });
}

// ── QR generation: qrcode-generator (matrix data) + custom canvas drawing ───
const QR_CDN = 'https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.js';

// ── Custom branded QR renderer ───────────────────────────────────────────────
// Uses qrcode-generator for the data matrix, then draws everything manually
// on canvas: coral rounded dots, charcoal extra-rounded corner squares,
// and the rausgucken mark (L-corner + 2 dots) painted into the center zone.

const CORAL    = '#FF6F61';
const CHARCOAL = '#373F51';
const BG       = '#ffffff';
const SIZE     = 256;

// Draw a rounded rectangle path
function rrect(ctx, x, y, w, h, r) {
  r = Math.min(r, w / 2, h / 2);
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.arcTo(x + w, y, x + w, y + r, r);
  ctx.lineTo(x + w, y + h - r);
  ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
  ctx.lineTo(x + r, y + h);
  ctx.arcTo(x, y + h, x, y + h - r, r);
  ctx.lineTo(x, y + r);
  ctx.arcTo(x, y, x + r, y, r);
  ctx.closePath();
}

// Draw the 3 finder patterns (corner squares) in charcoal
function drawFinder(ctx, col, row, cellSize) {
  const x = col * cellSize;
  const y = row * cellSize;
  const outer = cellSize * 7;
  const inner = cellSize * 3;
  const gap   = cellSize;

  // Outer square
  ctx.fillStyle = CHARCOAL;
  rrect(ctx, x, y, outer, outer, cellSize * 1.5);
  ctx.fill();

  // White cutout
  ctx.fillStyle = BG;
  rrect(ctx, x + gap, y + gap, outer - gap * 2, outer - gap * 2, cellSize * 0.8);
  ctx.fill();

  // Inner dot
  ctx.fillStyle = CHARCOAL;
  rrect(ctx, x + gap * 2, y + gap * 2, inner, inner, cellSize * 0.8);
  ctx.fill();
}

// Draw rausgucken mark into center zone
// mark fits within a square of size markSize at offset (ox, oy)
function drawBrand(ctx, ox, oy, markSize) {
  const s = markSize / 160; // scale factor — logo viewBox is 0 0 160 160

  ctx.save();
  ctx.translate(ox, oy);

  // White background circle so dots behind are hidden
  ctx.fillStyle = BG;
  ctx.beginPath();
  ctx.arc(markSize / 2, markSize / 2, markSize / 2, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = CORAL;
  ctx.strokeStyle = CORAL;

  // Large circle (cx=62 cy=98 r=32)
  ctx.beginPath();
  ctx.arc(62 * s, 98 * s, 32 * s, 0, Math.PI * 2);
  ctx.fill();

  // Small circle (cx=114 cy=114 r=16)
  ctx.beginPath();
  ctx.arc(114 * s, 114 * s, 16 * s, 0, Math.PI * 2);
  ctx.fill();

  // L-corner path: M75,36 L124,36 L124,85
  ctx.lineWidth   = 12 * s;
  ctx.lineCap     = 'round';
  ctx.lineJoin    = 'round';
  ctx.strokeStyle = CORAL;
  ctx.beginPath();
  ctx.moveTo(75 * s, 36 * s);
  ctx.lineTo(124 * s, 36 * s);
  ctx.lineTo(124 * s, 85 * s);
  ctx.stroke();

  ctx.restore();
}

function renderQRToCanvas(text, canvasEl) {
  return new Promise(resolve => {
    try {
      // Generate QR matrix using qrcode-generator
      const qr = window.qrcode(0, 'H'); // type 0 = auto, H = high error correction
      qr.addData(text);
      qr.make();

      const modules   = qr.getModuleCount(); // e.g. 33 for a typical URL
      const padding   = 2;                   // quiet zone in cells
      const totalCells = modules + padding * 2;
      const cellSize  = SIZE / totalCells;

      const ctx = canvasEl.getContext('2d');
      canvasEl.width  = SIZE;
      canvasEl.height = SIZE;

      // Background
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, SIZE, SIZE);

      // Finder pattern positions (top-left col/row in module coords)
      const finderPositions = [
        [0, 0],
        [modules - 7, 0],
        [0, modules - 7],
      ];
      const finderCells = new Set();
      for (const [fc, fr] of finderPositions) {
        for (let dr = 0; dr < 7; dr++) {
          for (let dc = 0; dc < 7; dc++) {
            finderCells.add((fr + dr) + ',' + (fc + dc));
          }
        }
      }

      // Center logo zone — skip dots here, draw brand instead
      const logoSize   = Math.floor(modules * 0.28); // 28% of matrix
      const logoStart  = Math.floor((modules - logoSize) / 2);
      const logoEnd    = logoStart + logoSize;
      const logoCells  = new Set();
      for (let r = logoStart; r < logoEnd; r++) {
        for (let c = logoStart; c < logoEnd; c++) {
          logoCells.add(r + ',' + c);
        }
      }

      // Draw regular dots
      ctx.fillStyle = CORAL;
      for (let row = 0; row < modules; row++) {
        for (let col = 0; col < modules; col++) {
          if (!qr.isDark(row, col)) continue;
          const key = row + ',' + col;
          if (finderCells.has(key)) continue; // drawn separately
          if (logoCells.has(key))   continue; // logo zone

          const x = (col + padding) * cellSize;
          const y = (row + padding) * cellSize;
          const r = cellSize * 0.38;
          rrect(ctx, x + 0.5, y + 0.5, cellSize - 1, cellSize - 1, r);
          ctx.fill();
        }
      }

      // Draw finder patterns
      for (const [fc, fr] of finderPositions) {
        drawFinder(ctx, fc + padding, fr + padding, cellSize);
      }

      // Draw brand mark in center zone
      const logoPixelX = (logoStart + padding) * cellSize;
      const logoPixelY = (logoStart + padding) * cellSize;
      const logoPixelSize = logoSize * cellSize;
      drawBrand(ctx, logoPixelX, logoPixelY, logoPixelSize);

      resolve();
    } catch(e) {
      console.warn('[QR] custom render failed:', e);
      resolve();
    }
  });
}

// ── EXPORT modal ──────────────────────────────────────────────────────────────
const exportOpenBtn  = document.getElementById('qr-export-open');
const exportModal    = document.getElementById('qr-export-modal');
const exportBackdrop = document.getElementById('qr-export-backdrop');
const exportClose    = document.getElementById('qr-export-close');
const exportCanvas   = document.getElementById('qr-export-canvas');
const exportCodeEl   = document.getElementById('qr-export-code');
const exportHint     = document.getElementById('qr-export-hint');
const exportStatus   = document.getElementById('qr-export-status');

let qrChunks  = [];
let qrPageIdx = 0;

async function renderExportPage(idx) {
  exportCanvas.style.opacity = '0.3';
  exportCodeEl.textContent   = '……';
  exportStatus.textContent   = '';

  const chunk = qrChunks[idx];
  const total = qrChunks.length;

  // 1. Get/create a transfer code from push backend
  let code = null;
  let qrUrl = BASE_URL + '?import=' + encodeURIComponent(chunk);
  try {
    const res = await fetch(PUSH_URL + '/transfer/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ payload: chunk }),
    });
    if (res.ok) {
      const data = await res.json();
      code  = data.code;
      qrUrl = BASE_URL + '?code=' + code;
    } else {
      console.warn('[QR] transfer/create returned', res.status);
      exportStatus.textContent = 'Offline-Modus — QR direkt scannen';
    }
  } catch(e) {
    console.warn('[QR] transfer/create failed:', e);
    exportStatus.textContent = 'Offline-Modus — QR direkt scannen';
  }

  // 2. Render QR
  await renderQRToCanvas(qrUrl, exportCanvas);
  exportCanvas.style.opacity = '1';

  // 3. Show code
  exportCodeEl.textContent = code
    ? code.slice(0,3) + ' ' + code.slice(3)
    : '—';

  // 4. Page nav
  if (total > 1) {
    exportHint.innerHTML =
      `<button id="qr-prev" style="background:none;border:none;cursor:pointer;color:var(--coral);font-size:1.1rem;padding:0 8px;opacity:${idx===0?0.3:1}" ${idx===0?'disabled':''}>&#9664;</button>` +
      `Seite&nbsp;${idx+1}&nbsp;von&nbsp;${total}` +
      `<button id="qr-next" style="background:none;border:none;cursor:pointer;color:var(--coral);font-size:1.1rem;padding:0 8px;opacity:${idx===total-1?0.3:1}" ${idx===total-1?'disabled':''}>&#9654;</button>`;
    document.getElementById('qr-prev')?.addEventListener('click', () => {
      if (qrPageIdx > 0) { qrPageIdx--; renderExportPage(qrPageIdx); }
    });
    document.getElementById('qr-next')?.addEventListener('click', () => {
      if (qrPageIdx < qrChunks.length - 1) { qrPageIdx++; renderExportPage(qrPageIdx); }
    });
  } else {
    exportHint.textContent = 'Gültig für 10 Minuten';
  }
}

async function openExportModal() {
  const saved    = getSaved();
  const upcoming = saved.filter(ev => !isExpired(ev.date_start));
  if (!upcoming.length) {
    alert(saved.length
      ? 'Alle gespeicherten Events sind vergangen.'
      : 'Keine gespeicherten Events zum Übertragen.');
    return;
  }

  exportModal.hidden = false;
  document.body.style.overflow = 'hidden';
  exportClose.focus();
  exportCanvas.style.opacity = '0.3';
  exportCodeEl.textContent   = '……';
  exportHint.textContent     = '';
  exportStatus.textContent   = '';

  qrChunks  = buildPayloadChunks(saved);
  qrPageIdx = 0;

  await loadScript(QR_CDN);
  await renderExportPage(0);
}

function closeExportModal() {
  exportModal.hidden = true;
  document.body.style.overflow = '';
  exportOpenBtn.focus();
}

exportOpenBtn.addEventListener('click',  openExportModal);
exportClose.addEventListener('click',   closeExportModal);
exportBackdrop.addEventListener('click', closeExportModal);

// ── IMPORT via URL params (phone camera or code entry) ────────────────────────
async function handleImportParams() {
  const params = new URLSearchParams(window.location.search);
  window.history.replaceState({}, '', window.location.pathname);

  // Short code path: ?code=482931
  const code = params.get('code');
  if (code) {
    try {
      const res = await fetch(PUSH_URL + '/transfer/' + code);
      if (res.ok) {
        const data   = await res.json();
        const events = decodePayloadString(data.payload);
        if (events?.length) { openImportPreview(events); return; }
      } else {
        // Show code entry with error
        openCodeEntry('Code nicht gefunden oder abgelaufen.');
        return;
      }
    } catch {
      openCodeEntry('Verbindung fehlgeschlagen.');
      return;
    }
  }

  // Direct payload path: ?import=city|slug,...  (fallback for offline)
  const raw = params.get('import');
  if (raw) {
    const events = decodePayloadString(decodeURIComponent(raw));
    if (events?.length) { openImportPreview(events); return; }
  }
}

function openImportPreview(events) {
  decodedEvents      = events;
  importModal.hidden = false;
  document.body.style.overflow = 'hidden';
  scannerWrap.hidden  = true;
  codeEntryEl.hidden  = true;
  errorEl.hidden      = true;
  successEl.hidden    = true;
  retryBtn.hidden     = true;
  renderPreview(events);
  previewEl.hidden = false;
}

function openCodeEntry(errorMsg) {
  importModal.hidden = false;
  document.body.style.overflow = 'hidden';
  scannerWrap.hidden  = true;
  previewEl.hidden    = true;
  successEl.hidden    = true;
  errorEl.hidden      = true;
  codeEntryEl.hidden  = false;
  if (errorMsg) {
    codeErrorEl.textContent = errorMsg;
    codeErrorEl.hidden = false;
  }
}

// ── IMPORT modal ──────────────────────────────────────────────────────────────
const importOpenBtn  = document.getElementById('qr-import-open');
const importModal    = document.getElementById('qr-import-modal');
const importBackdrop = document.getElementById('qr-import-backdrop');
const importClose    = document.getElementById('qr-import-close');
const scannerWrap    = document.getElementById('qr-scanner-wrap');
const videoEl        = document.getElementById('qr-video');
const scanCanvas     = document.getElementById('qr-scan-canvas');
const previewEl      = document.getElementById('qr-import-preview');
const previewCounts  = document.getElementById('qr-preview-counts');
const previewList    = document.getElementById('qr-preview-list');
const confirmBtn     = document.getElementById('qr-import-confirm');
const retryBtn       = document.getElementById('qr-import-retry');
const successEl      = document.getElementById('qr-import-success');
const successMsg     = document.getElementById('qr-import-success-msg');
const errorEl        = document.getElementById('qr-import-error');
const codeEntryEl    = document.getElementById('qr-code-entry');
const codeInputEl    = document.getElementById('qr-code-input');
const codeSubmitEl   = document.getElementById('qr-code-submit');
const codeErrorEl    = document.getElementById('qr-code-error');

let stream        = null;
let scanRAF       = 0;
let decodedEvents = null;

function resetImportUI(keepAccumulated) {
  scannerWrap.hidden  = false;
  previewEl.hidden    = true;
  successEl.hidden    = true;
  errorEl.hidden      = true;
  codeEntryEl.hidden  = true;
  retryBtn.hidden     = false;
  if (!keepAccumulated) decodedEvents = null;
}

async function startCamera() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 480 } }
    });
    videoEl.srcObject = stream;
    await videoEl.play();
    scanLoop();
  } catch (err) {
    // Camera failed — show code entry as fallback
    scannerWrap.hidden = true;
    codeEntryEl.hidden = false;
  }
}

function stopCamera() {
  cancelAnimationFrame(scanRAF);
  if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
  videoEl.srcObject = null;
}

const JSQR_CDN = 'https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js';

function scanLoop() {
  if (!window.jsQR || videoEl.readyState < videoEl.HAVE_ENOUGH_DATA) {
    scanRAF = requestAnimationFrame(scanLoop);
    return;
  }
  const ctx = scanCanvas.getContext('2d', { willReadFrequently: true });
  scanCanvas.width  = videoEl.videoWidth;
  scanCanvas.height = videoEl.videoHeight;
  ctx.drawImage(videoEl, 0, 0);
  const img  = ctx.getImageData(0, 0, scanCanvas.width, scanCanvas.height);
  const code = window.jsQR(img.data, img.width, img.height);

  if (code?.data) {
    try {
      const url = new URL(code.data);
      // Handle both ?code= and ?import= in scanned URL
      const shortCode = url.searchParams.get('code');
      const rawImport = url.searchParams.get('import');
      if (shortCode || rawImport) {
        stopCamera();
        // Re-use handleImportParams logic via URL push
        window.history.pushState({}, '', '?code=' + (shortCode || '') + (rawImport ? '&import=' + rawImport : ''));
        handleImportParams();
        return;
      }
    } catch {}
  }
  scanRAF = requestAnimationFrame(scanLoop);
}

function renderPreview(events) {
  decodedEvents = events;
  const upcoming = events.filter(ev => !isExpired(ev.date_start));
  const expired  = events.filter(ev => ev.date_start && isExpired(ev.date_start));

  previewCounts.innerHTML =
    `<div class="qr-preview-stat qr-preview-stat--upcoming">
       <span class="qr-preview-num">${upcoming.length}</span>
       <span class="qr-preview-label">bevorstehend</span>
     </div>` +
    (expired.length
      ? `<div class="qr-preview-stat qr-preview-stat--expired">
           <span class="qr-preview-num">${expired.length}</span>
           <span class="qr-preview-label">vergangen</span>
         </div>` : '');

  previewList.innerHTML = [...upcoming, ...expired].slice(0, 8).map(ev =>
    `<div class="qr-preview-item${isExpired(ev.date_start) ? ' qr-preview-item--past' : ''}">
       <span class="qr-preview-date">${formatDateShort(ev.date_start)}</span>
       <span class="qr-preview-title">${sanitise(ev.title)}</span>
     </div>`
  ).join('') +
  (events.length > 8 ? `<div class="qr-preview-more">+ ${events.length - 8} weitere</div>` : '');

  confirmBtn.textContent = `${upcoming.length} Event${upcoming.length !== 1 ? 's' : ''} übernehmen`;
}

async function doImport() {
  if (!decodedEvents) return;
  confirmBtn.disabled = true;
  confirmBtn.textContent = '…';

  // Enrich: fetch real event data so date_start, title etc. are correct
  const enriched = await enrichEvents(decodedEvents);

  const existing   = getSaved();
  const existSlugs = new Set(existing.map(e => e.slug));
  const toAdd      = enriched.filter(ev => !existSlugs.has(ev.slug));
  setSaved([...existing, ...toAdd]);
  window.dispatchEvent(new CustomEvent('rg:saved-changed'));
  previewEl.hidden = true;
  successMsg.textContent = toAdd.length
    ? `${toAdd.length} neues Event${toAdd.length !== 1 ? 's' : ''} importiert.`
    : 'Alle Events bereits gespeichert.';
  successEl.hidden = false;
  confirmBtn.disabled = false;
}

// Fetch real event objects from events-current.json for each slug+city pair
async function enrichEvents(events) {
  // Group by city to minimise fetches
  const byCitySlug = {};
  for (const ev of events) {
    const city = ev.city || 'ludwigsburg';
    if (!byCitySlug[city]) byCitySlug[city] = {};
    byCitySlug[city][ev.slug] = ev;
  }

  const enriched = [];
  for (const [city, slugMap] of Object.entries(byCitySlug)) {
    try {
      const res = await fetch(`/data/${city}/events-current.json`);
      if (!res.ok) throw new Error('fetch failed');
      const data = await res.json();
      // Support both array and landkreis wrapper {events:[...]}
      const evList = Array.isArray(data) ? data : (data.events || []);
      const bySlug = {};
      for (const ev of evList) { bySlug[ev.slug] = ev; }
      for (const [slug, fallback] of Object.entries(slugMap)) {
        const real = bySlug[slug];
        if (real) {
          // Build a complete saved-event object from real data
          enriched.push({
            slug:         real.slug,
            title:        real.title,
            date_start:   real.date_start   || null,
            date_end:     real.date_end      || null,
            time:         real.time          || null,
            location:     real.location      || null,
            price:        real.price         || null,
            tags:         real.tags          || [],
            source_label: real.source_label  || null,
            city:         real.city          || city,
            url:          `/${real.city || city}/events/${real.slug}`,
          });
        } else {
          // Not found in current JSON (may have expired) — keep fallback
          enriched.push(fallback);
        }
      }
    } catch {
      // Fetch failed — keep originals for this city
      for (const ev of Object.values(slugMap)) enriched.push(ev);
    }
  }
  return enriched;
}

async function submitCode() {
  const code = (codeInputEl.value || '').replace(/\s/g, '').trim();
  if (code.length !== 6) {
    codeErrorEl.textContent = 'Bitte 6-stelligen Code eingeben.';
    codeErrorEl.hidden = false;
    return;
  }
  codeSubmitEl.disabled   = true;
  codeSubmitEl.textContent = '…';
  codeErrorEl.hidden       = true;
  try {
    const res = await fetch(PUSH_URL + '/transfer/' + code);
    if (!res.ok) throw new Error('not found');
    const data   = await res.json();
    const events = decodePayloadString(data.payload);
    if (!events?.length) throw new Error('empty');
    codeEntryEl.hidden = true;
    openImportPreview(events);
  } catch {
    codeErrorEl.textContent = 'Code nicht gefunden oder abgelaufen.';
    codeErrorEl.hidden      = false;
  } finally {
    codeSubmitEl.disabled    = false;
    codeSubmitEl.textContent = 'Bestätigen';
  }
}

async function openImportModal() {
  importModal.hidden = false;
  document.body.style.overflow = 'hidden';
  importClose.focus();
  resetImportUI(false);
  await loadScript(JSQR_CDN).catch(() => {
    scannerWrap.hidden = true;
    codeEntryEl.hidden = false;
  });
  await startCamera();
}

function closeImportModal() {
  stopCamera();
  importModal.hidden = true;
  document.body.style.overflow = '';
  importOpenBtn.focus();
  resetImportUI(false);
}

importOpenBtn.addEventListener('click',  openImportModal);
importClose.addEventListener('click',   closeImportModal);
importBackdrop.addEventListener('click', closeImportModal);
confirmBtn.addEventListener('click', doImport);
retryBtn.addEventListener('click', async () => {
  resetImportUI(true);
  await startCamera();
});
codeSubmitEl?.addEventListener('click', submitCode);
codeInputEl?.addEventListener('keydown', e => { if (e.key === 'Enter') submitCode(); });
document.addEventListener('keydown', e => {
  if (e.key !== 'Escape') return;
  if (!exportModal?.hidden) closeExportModal();
  if (!importModal?.hidden) closeImportModal();
});

handleImportParams();
</script>

