---
// src/layouts/Base.astro
const { title, description, city } = Astro.props;
const siteUrl = "https://rausgucken.de";
const canonical = city ? `${siteUrl}/${city}/` : `${siteUrl}/`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_DE" />
  <link rel="sitemap" href="/sitemap.xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #f9f8f6;
      --color-surface: #ffffff;
      --color-border: #e2e0dc;
      --color-text: #1a1a1a;
      --color-text-muted: #6b6867;
      --color-accent: #c8541a;
      --color-accent-light: #fdf1eb;
      --color-tag-bg: #eeecea;
      --font-sans: system-ui, -apple-system, "Segoe UI", sans-serif;
      --radius: 10px;
      --shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    body {
      font-family: var(--font-sans);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.6;
    }

    a { color: var(--color-accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .site-header {
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 0 1.5rem;
    }
    .site-header-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .site-logo {
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--color-text);
      letter-spacing: -0.02em;
    }
    .site-logo span { color: var(--color-accent); }

    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .site-footer {
      background: var(--color-surface);
      border-top: 1px solid var(--color-border);
      padding: 2rem 1.5rem;
      margin-top: 4rem;
      font-size: 0.82rem;
      color: var(--color-text-muted);
      text-align: center;
    }
    .site-footer a { color: var(--color-text-muted); }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">raus<span>gucken</span>.de</a>
      <nav>
        <a href="/about" style="font-size:0.9rem;color:var(--color-text-muted)">Über uns</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>
      Alle Angaben ohne Gewähr. Veranstaltungsdaten werden automatisch gesammelt. 
      Bitte prüfen Sie alle Infos auf der jeweiligen Originalseite. &nbsp;·&nbsp;
      <a href="/about">Datenschutz &amp; Impressum</a>
    </p>
  </footer>
</body>
</html>
