---
// src/pages/markgroeningen/[date]/index.astro
// AUTO-GENERATED by tools/create_city.py — DO NOT EDIT MANUALLY.
// Update src/components/DateArchivePage.astro to change all city date pages.
// Regenerate: python tools/create_city.py --regen-date-pages
import { readFileSync } from "fs";
import { join }         from "path";
import DateArchivePage   from "../../../components/DateArchivePage.astro";

export async function getStaticPaths() {
  // Window: past 7 days + next 30 days.
  // Past pages stay alive (no 404) but get noindex once date has passed.
  // This prevents Google from hitting 404s on previously indexed pages.
  const today  = new Date();
  const todayStr = today.toISOString().split("T")[0];
  const window: string[] = [];
  for (let i = -7; i < 30; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() + i);
    window.push(d.toISOString().split("T")[0]);
  }

  const eventsPath = join(process.cwd(), "public", "data", "markgroeningen", "events-current.json");
  let allEvents: any[] = [];
  try {
    const raw = JSON.parse(readFileSync(eventsPath, "utf-8"));
    allEvents = Array.isArray(raw) ? raw : (raw.events ?? []);
  } catch {
    return []; // events file not yet present — no pages generated
  }

  const metaPath = join(process.cwd(), "public", "data", "markgroeningen", "meta.json");
  let scrapedAt  = new Date().toISOString();
  try { scrapedAt = JSON.parse(readFileSync(metaPath, "utf-8")).scraped_at ?? scrapedAt; } catch {}

  // Load important-links for sidebar — fail silently if not yet created
  let links: any[] = [];
  try {
    const linksPath = join(process.cwd(), "config", "important-links-markgroeningen.json");
    links = JSON.parse(readFileSync(linksPath, "utf-8"));
  } catch {}

  return window
    .filter(dateStr =>
      allEvents.some((ev: any) => {
        if (!ev.date_start) return false;
        const end = ev.date_end ?? ev.date_start;
        return ev.date_start <= dateStr && dateStr <= end;
      })
    )
    .map(dateStr => ({
      params: { date: dateStr },
      props:  { allEvents, scrapedAt, links, isPast: dateStr < todayStr },
    }));
}

const { date }                               = Astro.params;
const { allEvents, scrapedAt, links, isPast } = Astro.props;
---

<DateArchivePage
  cityId="markgroeningen"
  cityName="Markgröningen"
  dateStr={date}
  events={allEvents}
  scrapedAt={scrapedAt}
  links={links}
  noindex={isPast}
/>
