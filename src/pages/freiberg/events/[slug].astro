---
import Base from "../../../layouts/Base.astro";
import eventsData from "../../../../public/data/freiberg/events-current.json";
import tipsData from "../../../../src/data/editorial-tips.json";

export async function getStaticPaths() {
  const seen = new Set<string>();
  return eventsData
    .filter(ev => {
      if (seen.has(ev.slug)) return false;
      seen.add(ev.slug);
      return true;
    })
    .map(ev => ({
      params: { slug: ev.slug },
      props:  { event: ev },
    }));
}

const { event: ev } = Astro.props;
const editorialTip: string | undefined = (() => {
  if (!tipsData || typeof tipsData !== "object") return undefined;
  const tips = tipsData as Record<string, unknown>;
  const val = tips[ev.slug];
  if (!val || typeof val !== "object") return undefined;
  const tip = (val as Record<string, unknown>).tip;
  return typeof tip === "string" && tip.length > 0 ? tip : undefined;
})();
const siteUrl = "https://www.rausgucken.de";

function formatDateDE(iso) {
  if (!iso) return "Dauerhaft verfügbar";
  const d = new Date(iso + "T12:00:00");
  return d.toLocaleDateString("de-DE", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
}
function formatDateShort(iso) {
  if (!iso) return null;
  const d = new Date(iso + "T12:00:00");
  return d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" });
}

const today        = new Date().toISOString().slice(0, 10);
const isExpired    = !!(ev.date_start && ev.date_start < today);
const scrapedFormatted = ev.scraped_at
  ? new Date(ev.scraped_at).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })
  : null;

const canonical   = `${siteUrl}/freiberg/events/${ev.slug}/`;
const ogImage     = `/og/freiberg/${ev.slug}.jpg`;
const detailImage = `/og/detail/freiberg/${ev.slug}.webp`;

const MAX = 45;
const truncated = ev.title.length > MAX ? ev.title.slice(0, MAX).trimEnd() + "…" : ev.title;
const dateLabel = ev.date_start ? formatDateShort(ev.date_start) : "Dauerveranstaltung";
const seoTitle  = `${truncated} Freiberg am Neckar ${dateLabel} | rausgucken.de`;
const metaDesc  = ev.description
  ? ev.description.slice(0, 150) + (ev.description.length > 150 ? "…" : "")
  : `${ev.title} – Veranstaltung in Freiberg am Neckar${ev.date_start ? ` am ${dateLabel}` : ""}. Alle Details und Originalseite auf rausgucken.de.`;

const TAG_LABELS = {
  Ausstellung: "Ausstellung", Entertainment: "Entertainment", Familie: "Familie",
  Fest: "Fest", Fuehrung: "Führung", Jugend: "Jugend", Kinder: "Kinder",
  Kulinarik: "Kulinarik", Lesung: "Lesung", Messe: "Messe", Musik: "Musik",
  Outdoor: "Outdoor", Sport: "Sport", Sprache: "Sprache", Tanz: "Tanz",
  Theater: "Theater", Vortrag: "Vortrag", Workshop: "Workshop",
};

function normalisePrice(priceStr) {
  if (!priceStr) return null;
  const s = String(priceStr).trim().toLowerCase();
  if (["kostenlos", "frei", "eintritt frei", "0", "gratis", "kostenfrei"].includes(s))
    return { price: "0", currency: "EUR" };
  const m2 = s.match(/(\d+)[,.](\d{2})/);
  if (m2) return { price: `${m2[1]}.${m2[2]}`, currency: "EUR" };
  const m1 = s.match(/(\d+)/);
  if (m1) return { price: `${m1[1]}.00`, currency: "EUR" };
  return null;
}

const organizer = {
  name: ev.location || "Stadt Freiberg am Neckar",
  url: ev.original_url || siteUrl,
};

const priceData = normalisePrice(ev.price);

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": ev.title,
  ...(ev.description ? { "description": ev.description } : {}),
  "inLanguage": "de-DE",
  ...(ev.date_start ? { "startDate": ev.time ? `${ev.date_start}T${ev.time}` : ev.date_start } : {}),
  ...(ev.date_start ? { "endDate": ev.date_end || ev.date_start } : {}),
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "image": `${siteUrl}${ogImage}`,
  "url": canonical,
  "location": {
    "@type": "Place",
    "name": ev.location || "Freiberg am Neckar",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Freiberg am Neckar",
      "postalCode": "71691",
      "addressRegion": "Baden-Württemberg",
      "addressCountry": "DE",
    },
  },
  "organizer": { "@type": "Organization", "name": organizer.name, "url": organizer.url },
  "performer": { "@type": "PerformingGroup", "name": organizer.name },
  ...(priceData ? {
    "offers": {
      "@type": "Offer",
      "price": priceData.price,
      "priceCurrency": priceData.currency,
      "validFrom": ev.scraped_at,
      "availability": "https://schema.org/InStock",
      "url": ev.original_url || canonical,
    },
  } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Freiberg am Neckar", "item": `${siteUrl}/freiberg/` },
    { "@type": "ListItem", "position": 3, "name": ev.title, "item": canonical },
  ],
};

const relatedEvents = isExpired
  ? eventsData
      .filter(e =>
        e.slug !== ev.slug &&
        e.date_start && e.date_start >= today &&
        Array.isArray(e.tags) && Array.isArray(ev.tags) &&
        e.tags.some(t => ev.tags.includes(t))
      )
      .slice(0, 3)
  : [];

function buildGoogleCalendarUrl(ev) {
  if (!ev || !ev.date_start) return '';
  const base = 'https://calendar.google.com/calendar/render?action=TEMPLATE';
  const fmt = (iso, time) => {
    if (!iso) return '';
    const m = time ? time.match(/(\d{1,2}):(\d{2})/) : null;
    if (!m) return iso.replace(/-/g, '');
    return iso.replace(/-/g, '') + 'T' + m[1].padStart(2,'0') + m[2] + '00';
  };
  const endM = ev.time ? ev.time.match(/\d{1,2}:\d{2}\s*[-–]\s*(\d{1,2}):(\d{2})/) : null;
  const endTime = endM ? `${endM[1].padStart(2,'0')}${endM[2]}00` : null;
  const start = fmt(ev.date_start, ev.time);
  const endBase = ev.date_end || ev.date_start;
  const end = endTime ? endBase.replace(/-/g,'') + 'T' + endTime : start;
  const params = new URLSearchParams({
    text: ev.title || '',
    dates: `${start}/${end}`,
    location: ev.location || 'Freiberg am Neckar',
    details: [ev.description || '', ev.original_url ? `Originalseite: ${ev.original_url}` : '', 'Alle Angaben ohne Gewähr.'].filter(Boolean).join('\n\n'),
  });
  return `${base}&${params.toString()}`;
}

function buildOutlookUrl(ev) {
  const fmt = (iso, time) => {
    if (!iso) return '';
    const m = time ? time.match(/(\d{1,2}):(\d{2})/) : null;
    if (!m) return iso + 'T00:00:00';
    return `${iso}T${m[1].padStart(2,'0')}:${m[2]}:00`;
  };
  const endM = ev.time ? ev.time.match(/\d{1,2}:\d{2}\s*[-–]\s*(\d{1,2}):(\d{2})/) : null;
  const endTime = endM ? `${endM[1].padStart(2,'0')}:${endM[2]}:00` : null;
  const start = fmt(ev.date_start, ev.time);
  const endBase = ev.date_end || ev.date_start;
  const end = endTime ? `${endBase}T${endTime}` : start;
  const params = new URLSearchParams({
    path: '/calendar/action/compose', rru: 'addevent',
    subject: ev.title || '', startdt: start, enddt: end,
    location: ev.location || 'Freiberg am Neckar',
    body: [ev.description || '', ev.original_url ? `Originalseite: ${ev.original_url}` : ''].filter(Boolean).join('\n\n'),
  });
  return `https://outlook.live.com/calendar/0/action/compose?${params.toString()}`;
}

const googleCalUrl  = buildGoogleCalendarUrl(ev);
const outlookCalUrl = buildOutlookUrl(ev);
const icsUrl        = `/freiberg/events/${ev.slug}.ics`;
const shareEventUrl = `https://www.rausgucken.de/freiberg/events/${ev.slug}/`;
const shareText     = encodeURIComponent(`${ev.title} – ${shareEventUrl}`);
const waShareUrl    = `https://wa.me/?text=${shareText}`;
const tgShareUrl    = `https://t.me/share/url?url=${encodeURIComponent(shareEventUrl)}&text=${encodeURIComponent(ev.title)}`;
---

<Base
  title={seoTitle}
  description={metaDesc}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  schema={[eventSchema, breadcrumbSchema]}
>

  {isExpired && (
    <div class="expired-banner" role="alert" aria-live="polite">
      <span class="expired-icon" aria-hidden="true">⏰</span>
      <div>
        <strong>Diese Veranstaltung hat bereits stattgefunden.</strong>
        {relatedEvents.length > 0
          ? " Ähnliche aktuelle Veranstaltungen findest du hier:"
          : " Schau dir aktuelle Veranstaltungen in Freiberg am Neckar an."}
      </div>
    </div>
  )}

  {isExpired && relatedEvents.length > 0 && (
    <div class="related-events" aria-label="Ähnliche aktuelle Veranstaltungen">
      {relatedEvents.map(r => (
        <a href={`/freiberg/events/${r.slug}`} class="related-card">
          <div class="related-card-body">
            <span class="related-title">{r.title}</span>
            {r.location && <span class="related-location">{r.location}</span>}
          </div>
          <span class="related-date">{formatDateShort(r.date_start)}</span>
        </a>
      ))}
    </div>
  )}

  {isExpired && relatedEvents.length === 0 && (
    <div class="expired-cta">
      <a href="/freiberg" class="btn-cta">Alle aktuellen Veranstaltungen →</a>
    </div>
  )}

  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/freiberg">Freiberg am Neckar</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">{ev.title}</span>
  </nav>

  <article class="event-detail">
    <header class="event-header">
      <div class="event-tags" aria-label="Kategorien">
        {Array.isArray(ev.tags) && ev.tags.map(t => (
          <a href="/freiberg" class={`tag${t === "Kinder" || t === "Familie" ? " tag--sage" : ""}`}>
            {TAG_LABELS[t] ?? t}
          </a>
        ))}
        {ev.age_min != null && (
          <span class="tag tag--age">
            ab {ev.age_min} J.{ev.age_max ? ` bis ${ev.age_max} J.` : "+"}
          </span>
        )}
      </div>
      <h1>{ev.title}</h1>
    </header>

    <div class="event-hero">
      <img
        src={detailImage}
        alt={`${ev.title} – ${ev.location || "Freiberg am Neckar"}`}
        width="720" height="380"
        loading="eager" decoding="async"
        class="hero-img"
        onerror="this.closest('.event-hero').style.display='none'"
      />
    </div>

    <dl class="meta-grid">
      <div class="meta-item">
        <dt class="meta-label">Datum</dt>
        <dd class="meta-value">{formatDateDE(ev.date_start)}</dd>
      </div>
      {ev.date_end && ev.date_end !== ev.date_start && (
        <div class="meta-item">
          <dt class="meta-label">Bis</dt>
          <dd class="meta-value">{formatDateShort(ev.date_end)}</dd>
        </div>
      )}
      {ev.time && (
        <div class="meta-item">
          <dt class="meta-label">Uhrzeit</dt>
          <dd class="meta-value">{ev.time} Uhr</dd>
        </div>
      )}
      {ev.location && (
        <div class="meta-item">
          <dt class="meta-label">Ort</dt>
          <dd class="meta-value">{ev.location}</dd>
        </div>
      )}
      {ev.price != null && (
        <div class="meta-item">
          <dt class="meta-label">Preis</dt>
          <dd class="meta-value">{ev.price || "Kostenlos"}</dd>
        </div>
      )}
    </dl>

    {ev.description && (
      <div class="event-description">
        <h2>Beschreibung</h2>
        <p>{ev.description}</p>
      </div>
    )}

    {editorialTip && (
      <div class="editorial-tip" role="note" aria-label="Redaktionstipp">
        <span class="tip-label" aria-hidden="true">💡 Unser Tipp</span>
        <p class="tip-text">{editorialTip}</p>
      </div>
    )}

    <div class="source-box" aria-label="Quellenangabe">
      <div class="source-info">
        <p class="source-label">Quelle &amp; Aktualität</p>
        <p class="source-name">{organizer.name}</p>
        {scrapedFormatted && <p class="freshness-stamp">Erfasst am: {scrapedFormatted}</p>}
        <p class="source-disclaimer">Alle Angaben ohne Gewähr — bitte Originalseite prüfen.</p>
      </div>
      {ev.original_url && (
        <a href={ev.original_url} target="_blank" rel="noopener noreferrer"
           class="btn-original" aria-label={`Originalseite für ${ev.title} öffnen`}>
          Zur Originalseite →
        </a>
      )}
      <details class="share-dropdown">
        <summary class="btn-share" aria-label={`${ev.title} teilen`}>
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Teilen
        </summary>
        <ul class="share-menu" role="list">
          <li><a href={waShareUrl} target="_blank" rel="noopener noreferrer" class="share-item">WhatsApp</a></li>
          <li><a href={tgShareUrl} target="_blank" rel="noopener noreferrer" class="share-item">Telegram</a></li>
          <li><button class="share-item share-copy-btn" data-url={shareEventUrl}
            onclick="navigator.clipboard.writeText(this.dataset.url).then(()=>{var o=this.textContent;this.textContent='Kopiert!';setTimeout(()=>{this.textContent=o},2000)})">
            Link kopieren
          </button></li>
        </ul>
      </details>
      <div class="cal-dropdown">
        <button class="btn-ics" aria-haspopup="true" aria-expanded="false" id="cal-btn">
          📅 Zum Kalender ▾
        </button>
        <ul class="cal-menu" role="menu" aria-labelledby="cal-btn">
          <li role="none"><a href={googleCalUrl} target="_blank" rel="noopener noreferrer" role="menuitem">Google Calendar</a></li>
          <li role="none"><a href={outlookCalUrl} target="_blank" rel="noopener noreferrer" role="menuitem">Outlook</a></li>
          <li role="none"><a href={icsUrl} download rel="nofollow" role="menuitem">Apple / ICS-Datei</a></li>
        </ul>
      </div>
    </div>

    <nav class="related-pages" aria-label="Weitere Veranstaltungen in Freiberg am Neckar">
      <p class="related-pages-label">Weitere Veranstaltungen in Freiberg am Neckar</p>
      <div class="related-pages-links">
        <a href="/freiberg">Alle Veranstaltungen</a>
        <a href="/ludwigsburg">Ludwigsburg entdecken</a>
      </div>
    </nav>

    <a href="/freiberg" class="back-link">← Zurück zu allen Veranstaltungen</a>
  </article>

<style>
  .event-hero { margin-bottom: 1.75rem; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); height: 220px; background: var(--tag-bg); }
  .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; filter: brightness(0.95); }
  .expired-banner { display: flex; align-items: flex-start; gap: 0.75rem; background: var(--tag-bg); border: 1px solid var(--border); border-left: 3px solid var(--coral); border-radius: var(--radius-sm); padding: 0.9rem 1.25rem; font-size: 0.9rem; color: var(--text); margin-bottom: 1rem; max-width: 720px; }
  .expired-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.1rem; }
  .related-events { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; max-width: 720px; }
  .related-card { display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; padding: 0.65rem 1rem; background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius-sm); text-decoration: none; color: var(--text); font-size: 0.88rem; transition: border-color 150ms; }
  .related-card:hover { border-color: var(--coral); text-decoration: none; }
  .related-card-body { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .related-title { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .related-location { font-size: 0.78rem; color: var(--text-60); }
  .related-date { font-size: 0.8rem; color: var(--text-60); white-space: nowrap; flex-shrink: 0; }
  .expired-cta { margin-bottom: 1.5rem; }
  .breadcrumb { font-size: 0.82rem; color: var(--text-60); margin-bottom: 1.5rem; max-width: 720px; display: flex; flex-wrap: wrap; align-items: center; gap: 0.1rem; }
  .breadcrumb a { color: var(--text-60); }
  .breadcrumb a:hover { color: var(--coral); text-decoration: none; }
  .event-detail { max-width: 720px; }
  .event-header { margin-bottom: 1.5rem; }
  .event-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.75rem; }
  .tag { background: var(--tag-bg); color: var(--text-60); font-size: 0.75rem; font-weight: 500; padding: 3px 10px; border-radius: 20px; text-decoration: none; transition: background 150ms, color 150ms; }
  .tag:hover { background: var(--coral-light); color: var(--coral); }
  .tag--sage { background: var(--sage-light); color: var(--text); font-weight: 600; }
  .tag--age { background: var(--sage-light); color: var(--text); font-weight: 600; cursor: default; }
  h1 { font-size: clamp(1.4rem, 4vw, 2rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 0; }
  .meta-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 1rem; background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 2rem; box-shadow: var(--shadow-card); }
  .meta-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .meta-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-60); font-family: var(--font-body); }
  .meta-value { font-size: 0.95rem; color: var(--text); font-weight: 500; }
  .event-description { margin-bottom: 2rem; }
  .event-description h2 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.65rem; color: var(--text); }
  .event-description p { line-height: 1.75; color: var(--text-60); }
  .source-box { margin-top: 2rem; background: var(--coral-light); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .source-info { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; min-width: 0; }
  .source-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); font-family: var(--font-body); }
  .source-name { font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .freshness-stamp { font-size: 0.78rem; color: var(--text); opacity: 0.70; }
  .source-disclaimer { font-size: 0.75rem; color: var(--text); opacity: 0.55; margin-top: 0.15rem; }
  .btn-original { display: inline-flex; align-items: center; background: var(--coral); color: var(--text); padding: 0.65rem 1.25rem; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 600; white-space: nowrap; text-decoration: none; min-height: 44px; transition: background 150ms; flex-shrink: 0; }
  .btn-original:hover { background: var(--coral-dark); text-decoration: none; }
  .cal-dropdown { position: relative; flex-shrink: 0; }
  .btn-ics { display: inline-flex; align-items: center; gap: 0.35rem; background: var(--surface-card); color: var(--text); border: 1.5px solid var(--border); padding: 0.65rem 1rem; border-radius: var(--radius-sm); font-size: 0.85rem; font-weight: 600; white-space: nowrap; cursor: pointer; min-height: 44px; transition: border-color 150ms; font-family: var(--font-body); }
  .btn-ics:hover { border-color: var(--coral); background: var(--coral-light); }
  .cal-menu { display: none; position: absolute; bottom: calc(100% + 6px); right: 0; background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius-sm); box-shadow: var(--shadow-card); list-style: none; padding: 0.35rem 0; margin: 0; min-width: 170px; z-index: 40; }
  .cal-menu.open { display: block; }
  .cal-menu a { display: flex; align-items: center; gap: 0.55rem; padding: 0.55rem 1rem; font-size: 0.88rem; color: var(--text); text-decoration: none; white-space: nowrap; }
  .cal-menu a:hover { background: var(--coral-light); color: var(--coral); }
  .btn-cta { display: inline-flex; align-items: center; background: var(--coral); color: var(--text); padding: 0.65rem 1.25rem; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 600; text-decoration: none; min-height: 44px; transition: background 150ms; }
  .btn-cta:hover { background: var(--coral-dark); text-decoration: none; }
  .related-pages { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .related-pages-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); margin-bottom: 0.65rem; font-family: var(--font-body); }
  .related-pages-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .related-pages-links a { display: inline-flex; align-items: center; padding: 0.4rem 0.9rem; background: var(--tag-bg); color: var(--text-60); border-radius: 20px; font-size: 0.82rem; font-weight: 500; text-decoration: none; min-height: 36px; transition: background 150ms, color 150ms; }
  .related-pages-links a:hover { background: var(--coral-light); color: var(--coral); text-decoration: none; }
  .back-link { display: inline-block; margin-top: 2rem; font-size: 0.88rem; color: var(--text-60); text-decoration: none; transition: color 150ms; }
  .back-link:hover { color: var(--coral); }
  .editorial-tip { display: flex; flex-direction: column; gap: 0.35rem; background: var(--sage-light); border: 1px solid var(--border); border-left: 3px solid var(--sage); border-radius: var(--radius-sm); padding: 0.9rem 1.1rem; margin-bottom: 2rem; max-width: 720px; }
  .tip-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); font-family: var(--font-body); }
  .tip-text { font-size: 0.9rem; line-height: 1.65; color: var(--text); margin: 0; }
  .share-dropdown { position: relative; flex-shrink: 0; }
  .btn-share { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--surface-card); color: var(--text); border: 1.5px solid var(--border); padding: 0.65rem 1rem; border-radius: var(--radius-sm); font-size: 0.85rem; font-weight: 600; white-space: nowrap; cursor: pointer; min-height: 44px; list-style: none; user-select: none; transition: border-color 150ms; font-family: var(--font-body); }
  .btn-share::-webkit-details-marker { display: none; }
  .btn-share:hover { border-color: var(--coral); color: var(--coral); background: var(--coral-light); }
  .share-copy-btn { width: 100%; background: none; border: none; cursor: pointer; text-align: left; font-family: var(--font-body); color: var(--text); }
  .share-dropdown .share-menu { position: absolute; bottom: calc(100% + 6px); right: 0; background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius-sm); box-shadow: 0 8px 24px rgba(0,0,0,0.14); list-style: none; padding: 0.35rem 0; margin: 0; min-width: 180px; z-index: 40; }
