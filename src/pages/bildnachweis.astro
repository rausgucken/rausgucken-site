---
// src/pages/bildnachweis.astro
import Base from "../layouts/Base.astro";
---

<Base
  title="Bildnachweis | rausgucken.de"
  description="Bildquellen und Lizenzen der auf rausgucken.de verwendeten Veranstaltungsort-Fotos."
  canonical="/bildnachweis"
  noindex={true}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Bildnachweis</span>
  </nav>

  <div class="page-header">
    <h1>Bildnachweis</h1>
    <p class="page-subtitle">Fotos der Veranstaltungsorte, die in unseren Vorschaubildern verwendet werden.</p>
  </div>

  <div class="credits-grid">

    <div class="credit-card">
      <img src="/og/venues/schloss.jpg" alt="Residenzschloss Ludwigsburg" class="credit-thumb" />
      <div class="credit-info">
        <strong>Residenzschloss Ludwigsburg</strong>
        <span>Auch verwendet als: Hub-Vorschaubild Ludwigsburg</span>
        <span>Foto: <a href="https://commons.wikimedia.org/wiki/File:Ludwigsburg_Palace_11.jpg" target="_blank" rel="noopener">Llez</a> / Wikimedia Commons / CC BY-SA</span>
      </div>
    </div>

    <div class="credit-card">
      <img src="/og/venues/karlskaserne.jpg" alt="Kunstzentrum Karlskaserne Ludwigsburg" class="credit-thumb" />
      <div class="credit-info">
        <strong>Kunstzentrum Karlskaserne</strong>
        <span>Auch verwendet für: Kunstschule Labyrinth</span>
        <span>Foto: <a href="https://commons.wikimedia.org/wiki/File:LudwigsburgKarlskaserneHauptgeb%C3%A4ude_2023-02.jpg" target="_blank" rel="noopener">Mussklprozz</a> / Wikimedia Commons / CC BY-SA 4.0</span>
      </div>
    </div>

    <div class="credit-card">
      <img src="/og/venues/stadtbibliothek.jpg" alt="Stadtbibliothek Ludwigsburg" class="credit-thumb" />
      <div class="credit-info">
        <strong>Stadtbibliothek Ludwigsburg</strong>
        <span>Foto: <a href="https://commons.wikimedia.org/wiki/File:Sachthemen_und_Romane.jpg" target="_blank" rel="noopener">T.stierle</a> / Wikimedia Commons / CC BY-SA 4.0</span>
      </div>
    </div>

    <div class="credit-card">
      <img src="/og/venues/stadtmuseum.jpg" alt="Stadtmuseum im MIK Ludwigsburg" class="credit-thumb" />
      <div class="credit-info">
        <strong>Stadtmuseum im MIK</strong>
        <span>Auch verwendet für: Kunstverein Ludwigsburg</span>
        <span>Foto: <a href="https://commons.wikimedia.org/wiki/File:MIK_Ludwigsburg_2013-05.jpg" target="_blank" rel="noopener">Mussklprozz</a> / Wikimedia Commons / CC BY-SA 3.0</span>
      </div>
    </div>

  </div>

</Base>

<style>
  .credits-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 720px;
  }

  .credit-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: var(--shadow-card);
  }

  .credit-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .credit-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.88rem;
    color: var(--text-60);
  }

  .credit-info strong {
    font-size: 0.95rem;
    color: var(--text);
    font-family: var(--font-heading);
  }

  .credit-info a {
    color: var(--coral);
  }
</style>
