---
// src/pages/bildnachweis.astro
// Credits are auto-generated by pipeline/generate_bildnachweis.py from config/sources.json.
// Do NOT edit the credits array here — edit sources.json instead.
import Base from "../layouts/Base.astro";
import creditsData from "../data/bildnachweis-credits.json";

const credits = creditsData;
---
<Base
  title="Bildnachweis | rausgucken.de"
  description="Bildquellen und Lizenzen der auf rausgucken.de verwendeten Veranstaltungsort-Fotos."
  canonical="/bildnachweis"
  noindex={true}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">Bildnachweis</span>
  </nav>
  <div class="page-header">
    <h1>Bildnachweis</h1>
    <p class="page-subtitle">Fotos der Veranstaltungsorte, die in unseren Vorschaubildern verwendet werden. Alle Bilder stammen von Wikimedia Commons.</p>
  </div>
  <div class="credits-grid">
    {credits.map(c => (
      <div class="credit-card">
        <img src={`/og/venues/${c.file}`} alt={c.label} class="credit-thumb" />
        <div class="credit-info">
          <strong>{c.label}</strong>
          <span class="credit-note">{c.note}</span>
          <span>
            Foto: <a href={c.url} target="_blank" rel="noopener">{c.author}</a>
            {" "}/ Wikimedia Commons / {c.license}
          </span>
        </div>
      </div>
    ))}
  </div>
</Base>
<style>
  .credits-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 720px;
  }
  .credit-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: var(--shadow-card);
  }
  .credit-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }
  .credit-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.88rem;
    color: var(--text-60);
  }
  .credit-info strong {
    font-size: 0.95rem;
    color: var(--text);
    font-family: var(--font-heading);
  }
  .credit-note {
    font-style: italic;
    font-size: 0.82rem;
  }
  .credit-info a {
    color: var(--coral);
  }
</style>
