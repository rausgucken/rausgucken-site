          </li>
        </ul>
      </div>
    </div>

    <!-- ── Related pages nav ───────────────────────────────────────────────── -->
    <nav class="related-pages" aria-label={`Weitere Veranstaltungen in ${cityDisplay}`}>
      <p class="related-pages-label">Weitere Veranstaltungen in {cityDisplay}</p>
      <div class="related-pages-links">
        <a href={`/${city}/`}>Alle Veranstaltungen in {cityDisplay}</a>
        <a href="/ludwigsburg/">Landkreis Ludwigsburg</a>
      </div>
    </nav>

    <a href={`/${city}/`} class="back-link">← Zurück zu allen Veranstaltungen</a>
  </article>

<style>
  .event-hero { margin-bottom: 1.75rem; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); height: 220px; background: var(--tag-bg); }
