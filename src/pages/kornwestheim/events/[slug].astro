  .event-description { margin-bottom: 2rem; }
  .event-description h2 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.65rem; color: var(--text); }
  .event-description p { line-height: 1.75; color: var(--text-60); }

  .editorial-tip { display: flex; flex-direction: column; gap: 0.35rem; background: var(--sage-light, #f0f7ea); border: 1px solid var(--border); border-left: 3px solid var(--sage, #90BE6D); border-radius: var(--radius-sm, 6px); padding: 0.9rem 1.1rem; margin-bottom: 2rem; max-width: 720px; }
  .tip-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); font-family: var(--font-body); }
  .tip-text { font-size: 0.9rem; line-height: 1.65; color: var(--text); margin: 0; }

  .source-box { margin-top: 2rem; background: var(--coral-light); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .source-info { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; min-width: 0; }
  .source-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); font-family: var(--font-body); }
  .source-name { font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .freshness-stamp { font-size: 0.78rem; color: var(--text); opacity: 0.70; }
  .source-disclaimer { font-size: 0.75rem; color: var(--text); opacity: 0.55; margin-top: 0.15rem; }
  .btn-original { display: inline-flex; align-items: center; background: var(--coral); color: var(--text); padding: 0.65rem 1.25rem; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 600; white-space: nowrap; text-decoration: none; min-height: 44px; transition: background 150ms; flex-shrink: 0; }
  .btn-original:hover { background: var(--coral-dark); text-decoration: none; }
  .btn-original:focus-visible { outline: 2px solid var(--text); outline-offset: 2px; }

  .share-dropdown { position: relative; flex-shrink: 0; }
  .share-dropdown[open] .btn-share { border-color: var(--coral); color: var(--coral); background: var(--coral-light); }
  .btn-share { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--surface-card); color: var(--text); border: 1.5px solid var(--border); padding: 0.65rem 1rem; border-radius: var(--radius-sm); font-size: 0.85rem; font-weight: 600; white-space: nowrap; cursor: pointer; min-height: 44px; list-style: none; user-select: none; transition: border-color 150ms, background 150ms, color 150ms; font-family: var(--font-body); }
  .btn-share::-webkit-details-marker { display: none; }
  .btn-share:hover { border-color: var(--coral); color: var(--coral); background: var(--coral-light); }
  .share-copy-btn { width: 100%; background: none; border: none; cursor: pointer; text-align: left; font-family: var(--font-body); color: var(--text); }
  .share-dropdown .share-menu { position: absolute; bottom: calc(100% + 6px); right: 0; background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius-sm); box-shadow: 0 8px 24px rgba(0,0,0,0.14); list-style: none; padding: 0.35rem 0; margin: 0; min-width: 200px; z-index: 40; }
  html.dark .share-dropdown .share-menu { box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
  .share-item { display: flex; align-items: center; gap: 0.55rem; padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 500; color: var(--text); text-decoration: none; white-space: nowrap; transition: background 120ms; }
  .share-item:hover { background: var(--tag-bg); text-decoration: none; }

  .cal-dropdown { position: relative; flex-shrink: 0; }
  .btn-ics { display: inline-flex; align-items: center; gap: 0.35rem; background: var(--surface-card); color: var(--text); border: 1.5px solid var(--border); padding: 0.65rem 1rem; border-radius: var(--radius-sm); font-size: 0.85rem; font-weight: 600; white-space: nowrap; cursor: pointer; min-height: 44px; transition: border-color 150ms, background 150ms; font-family: var(--font-body); }
  .btn-ics:hover { border-color: var(--coral); background: var(--coral-light); }
  .btn-ics:focus-visible { outline: 2px solid var(--text); outline-offset: 2px; }
  .cal-menu { display: none; position: absolute; bottom: calc(100% + 6px); right: 0; background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius-sm); box-shadow: var(--shadow-card); list-style: none; padding: 0.35rem 0; margin: 0; min-width: 170px; z-index: 40; }
  .cal-menu.open { display: block; }
  .cal-menu li { padding: 0; }
  .cal-menu a { display: flex; align-items: center; gap: 0.55rem; padding: 0.55rem 1rem; font-size: 0.88rem; color: var(--text); text-decoration: none; white-space: nowrap; }
  .cal-menu a:hover { background: var(--coral-light); color: var(--coral); }

  .btn-cta { display: inline-flex; align-items: center; background: var(--coral); color: var(--text); padding: 0.65rem 1.25rem; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 600; text-decoration: none; min-height: 44px; transition: background 150ms; }
  .btn-cta:hover { background: var(--coral-dark); text-decoration: none; }

  .related-pages { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .related-pages-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); margin-bottom: 0.65rem; font-family: var(--font-body); }
  .related-pages-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .related-pages-links a { display: inline-flex; align-items: center; padding: 0.4rem 0.9rem; background: var(--tag-bg); color: var(--text-60); border-radius: 20px; font-size: 0.82rem; font-weight: 500; text-decoration: none; min-height: 36px; transition: background 150ms, color 150ms; }
  .related-pages-links a:hover { background: var(--coral-light); color: var(--coral); text-decoration: none; }

  .back-link { display: inline-block; margin-top: 2rem; font-size: 0.88rem; color: var(--text-60); text-decoration: none; transition: color 150ms; }
  .back-link:hover { color: var(--coral); }
</style>

<script>
  const btn = document.getElementById('cal-btn');
  const menu = btn && btn.nextElementSibling;
  if (btn && menu) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', () => {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        menu.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
</Base>
