  .related-card-body { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .related-title { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .related-location { font-size: 0.78rem; color: var(--text-60); }
  .related-date { font-size: 0.8rem; color: var(--text-60); white-space: nowrap; flex-shrink: 0; }
  .expired-cta { margin-bottom: 1.5rem; }

  .breadcrumb { font-size: 0.82rem; color: var(--text-60); margin-bottom: 1.5rem; max-width: 720px; display: flex; flex-wrap: wrap; align-items: center; gap: 0.1rem; }
