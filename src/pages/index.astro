---
// src/pages/ludwigsburg/index.astro
// Runs at BUILD TIME on Cloudflare Pages — generates static HTML.
// All event data is baked into the HTML at build time → fully Google-indexable.

import Base from "../../layouts/Base.astro";
import EventCard from "../../components/EventCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import { readFileSync } from "fs";
import { fileURLToPath } from "url";
import path from "path";

const __dirname = path.dirname(fileURLToPath(import.meta.url));

let events = [];
let meta = {};

try {
  const evPath   = path.resolve(__dirname, "../../../public/data/ludwigsburg/events-current.json");
  const metaPath = path.resolve(__dirname, "../../../public/data/ludwigsburg/meta.json");
  events = JSON.parse(readFileSync(evPath, "utf-8"));
  meta   = JSON.parse(readFileSync(metaPath, "utf-8"));
} catch (e) {
  console.warn("[ludwigsburg/index.astro] Could not read data files:", e.message);
}

const scrapedDate = meta.scraped_at
  ? new Date(meta.scraped_at).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })
  : "–";

// Separate dated events and standing tours
const dated    = events.filter(e => e.date_start);
const standing = events.filter(e => !e.date_start);

// Schema.org JSON-LD for the page
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Veranstaltungen in Ludwigsburg",
  "url": "https://rausgucken.de/ludwigsburg/",
  "numberOfItems": events.length,
  "itemListElement": dated.slice(0, 10).map((ev, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Event",
      "name": ev.title,
      "startDate": ev.date_start,
      "location": {
        "@type": "Place",
        "name": ev.location || "Ludwigsburg",
      },
      "url": `https://rausgucken.de/ludwigsburg/events/${ev.slug}`,
    }
  }))
};
---

<Base
  title="Veranstaltungen in Ludwigsburg | rausgucken.de"
  description={`Alle Events, Führungen, Konzerte und Ausstellungen in Ludwigsburg – ${events.length} Veranstaltungen im Überblick.`}
  city="ludwigsburg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-header">
    <h1>Veranstaltungen in Ludwigsburg</h1>
    <p class="page-subtitle">
      {events.length} Veranstaltungen · Stand: {scrapedDate}
    </p>
  </div>

  <aside class="disclaimer-box">
    <strong>Hinweis:</strong> {meta.disclaimer_note || "Alle Angaben ohne Gewähr. Bitte prüfen Sie Infos auf der jeweiligen Originalseite."}
    <a href="/about">Mehr Informationen</a>
  </aside>

  <FilterBar />

  {dated.length > 0 && (
    <section>
      <h2 class="section-heading">Kommende Veranstaltungen</h2>
      <div class="event-grid" id="event-grid">
        {dated.map(ev => (
          <EventCard event={ev} />
        ))}
      </div>
    </section>
  )}

  {standing.length > 0 && (
    <section style="margin-top: 3rem;">
      <h2 class="section-heading">Dauerveranstaltungen & Führungen</h2>
      <p class="section-note">Diese Angebote finden regelmäßig statt. Termine auf der Originalseite prüfen.</p>
      <div class="event-grid">
        {standing.map(ev => (
          <EventCard event={ev} />
        ))}
      </div>
    </section>
  )}

  {events.length === 0 && (
    <div class="empty-state">
      <p>Aktuell keine Veranstaltungen verfügbar. Bitte später wieder vorbeischauen.</p>
    </div>
  )}

  <script src="/scripts/app.js"></script>
</Base>

<style>
  .page-header { margin-bottom: 1.25rem; }
  h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: 0.35rem;
  }

  .disclaimer-box {
    background: var(--color-accent-light);
    border: 1px solid #f0cdb8;
    border-radius: var(--radius);
    padding: 0.85rem 1.25rem;
    font-size: 0.85rem;
    color: #7a3b18;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  .disclaimer-box a { color: #7a3b18; font-weight: 600; margin-left: 0.35rem; }

  .section-heading {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .section-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    margin-top: -0.5rem;
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    .event-grid { grid-template-columns: 1fr; }
  }
</style>
