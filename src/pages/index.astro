---
// src/pages/index.astro
// rausgucken.de — Homepage
// Search-first interface. Static shell — no event data baked in.
// Leaflet loaded from CDN (no npm install). Cities from /data/cities.json fetched client-side.
// SEO: page is intentionally content-free — all SEO value is on city/temporal/venue pages.
import Base from "../layouts/Base.astro";
---

<Base
  title="rausgucken.de — Was ist los in deiner Stadt?"
  description="Veranstaltungen, Konzerte, Ausstellungen und mehr in deiner Stadt und Umgebung — täglich aktuell."
>
  <div class="home-shell">

    <!-- ── Hero ─────────────────────────────────────────────────────────── -->
    <header class="hero">
      <h1>Was ist los in deiner Stadt?</h1>

      <!-- Search bar -->
      <div class="search-wrap">
        <div class="search-box" id="search-box">
          <svg class="search-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/>
            <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <input
            id="city-search"
            type="text"
            placeholder="Stadt oder Landkreis…"
            autocomplete="off"
            aria-label="Stadt suchen"
            aria-autocomplete="list"
            aria-controls="search-suggestions"
            aria-expanded="false"
          />
          <button id="search-clear" class="search-clear" hidden aria-label="Suche leeren">✕</button>
          <button id="search-submit" class="search-submit" aria-label="Suchen">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/>
              <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <ul id="search-suggestions" class="search-suggestions" role="listbox" hidden></ul>
        <button id="locate-btn" class="locate-btn" type="button">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="3" fill="currentColor"/>
            <path d="M10 2v2M10 16v2M2 10h2M16 10h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Standort erkennen
        </button>
      </div>
    </header>

    <!-- ── Map section (revealed after city selection) ───────────────────── -->
    <section id="map-section" class="map-section" hidden aria-label="Karte mit Veranstaltungsorten">

      <div class="map-header">
        <div class="map-header-left">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="pin-icon">
            <circle cx="10" cy="8" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M10 12v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span id="map-city-label" class="map-city-label">—</span>
        </div>
        <span id="map-count-badge" class="map-count-badge"></span>
      </div>

      <!-- Leaflet map container -->
      <div id="leaflet-map" class="leaflet-map" aria-label="Karte" aria-hidden="true"></div>

      <!-- Radius slider -->
      <div class="radius-row">
        <label for="radius-slider" class="radius-label">
          Umkreis: <strong id="radius-val" class="radius-val">15 km</strong>
        </label>
        <input
          id="radius-slider"
          type="range"
          min="2"
          max="60"
          value="15"
          step="1"
          class="radius-slider"
          aria-label="Umkreis in Kilometern"
        />
      </div>

      <!-- City list below map -->
      <div id="city-list" class="city-list"></div>

    </section>

    <!-- ── Default: covered cities (no selection yet) ────────────────────── -->
    <div id="covered-list" class="covered-list">
      <p class="section-label">Städte mit Veranstaltungen</p>
      <div id="covered-cities"></div>
    </div>

  </div>
</Base>

<!-- Leaflet CSS from CDN -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"
  integrity="sha512-h9FcoyWjHcOcmEVkxOfTLnmZFWIH0iZhZT1H2TbOq55xssQGEJHEaIm+PgoUaZbRvQTNTLSeB68ARYJipY1SQ=="
  crossorigin="anonymous"
/>

<!-- Leaflet JS from CDN -->
<script
  src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"
  integrity="sha512-puJW3E/qXDqYp9IfhAI54BJEaWIfloJ7JWoFvW8V8+FBfLpTHkS8sON5uIz9TjV8YmLjsHJUJMpIFdGExQv3Q=="
  crossorigin="anonymous"
  defer
></script>

<script>
// Homepage map — vanilla JS, no framework
// Cities loaded from /data/cities.json at mount time

import { dist, normalize } from "../scripts/map-utils.js";

let CITIES = [];
let map = null;
let radiusCircle = null;
let markers = {};
let selectedCity = null;

// ── DOM refs ─────────────────────────────────────────────────────────────────
const searchInput    = document.getElementById("city-search");
const searchClear    = document.getElementById("search-clear");
const searchSubmit   = document.getElementById("search-submit");
const suggestionsEl  = document.getElementById("search-suggestions");
const locateBtn      = document.getElementById("locate-btn");
const mapSection     = document.getElementById("map-section");
const mapCityLabel   = document.getElementById("map-city-label");
const mapCountBadge  = document.getElementById("map-count-badge");
const slider         = document.getElementById("radius-slider");
const radiusValEl    = document.getElementById("radius-val");
const cityListEl     = document.getElementById("city-list");
const coveredList    = document.getElementById("covered-list");
const coveredCities  = document.getElementById("covered-cities");

// ── Load cities + render default covered list ─────────────────────────────────
async function init() {
  try {
    const res = await fetch("/data/cities.json");
    CITIES = await res.json();
  } catch(e) {
    console.warn("[homepage] Failed to load cities.json", e);
    return;
  }
  renderCoveredList();
}

function renderCoveredList() {
  const covered = CITIES.filter(c => c.covered && c.event_count > 0)
    .sort((a, b) => b.event_count - a.event_count);
  coveredCities.innerHTML = covered.map(c =>
    `<div class="city-row">
      <a href="${c.url}">${c.name}</a>
      <span class="city-row-meta">${c.event_count} Events</span>
    </div>`
  ).join("");
}

// ── City selection ────────────────────────────────────────────────────────────
function selectCity(city) {
  selectedCity = city;

  // Update header
  mapCityLabel.textContent = city.name + (city.type ? ` · ${city.type}` : "");

  // Show map section, hide default covered list
  mapSection.hidden = false;
  coveredList.hidden = true;

  // Smooth scroll
  mapSection.scrollIntoView({ behavior: "smooth", block: "start" });

  // Init or move map
  if (!map) {
    initMap(city);
  } else {
    map.setView([city.lat, city.lng], 11);
  }

  updateRadius();
  searchInput.value = "";
  suggestionsEl.hidden = true;
  searchClear.hidden = true;
  searchInput.setAttribute("aria-expanded", "false");
}

// ── Leaflet map init ──────────────────────────────────────────────────────────
function initMap(city) {
  // Wait for Leaflet to be available (loaded via defer)
  if (!window.L) {
    setTimeout(() => initMap(city), 100);
    return;
  }
  const L = window.L;

  map = L.map("leaflet-map", {
    center: [city.lat, city.lng],
    zoom: 11,
    zoomControl: true,
    scrollWheelZoom: false,
  });

  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 17,
  }).addTo(map);

  // Add markers for all covered cities
  CITIES.filter(c => c.covered).forEach(c => {
    const isSelected = c.id === city.id;
    const marker = L.circleMarker([c.lat, c.lng], {
      radius: isSelected ? 12 : 8,
      fillColor: isSelected ? "#FF6F61" : "#373F51",
      color: "#fff",
      weight: 2,
      opacity: 1,
      fillOpacity: 1,
    }).addTo(map);

    if (c.event_count > 0 || isSelected) {
      marker.bindTooltip(c.name, {
        permanent: true,
        direction: "top",
        offset: [0, -10],
        className: "city-tooltip",
      });
    }

    marker.on("click", () => selectCity(c));
    markers[c.id] = marker;
  });
}

function updateMarkers(inRadiusIds) {
  if (!map || !window.L) return;
  const L = window.L;
  CITIES.filter(c => c.covered).forEach(c => {
    const m = markers[c.id];
    if (!m) return;
    const isSelected = selectedCity && c.id === selectedCity.id;
    const inRange = inRadiusIds.has(c.id);
    m.setStyle({
      radius: isSelected ? 12 : 8,
      fillColor: isSelected ? "#FF6F61" : (inRange ? "#373F51" : "#373F51"),
      fillOpacity: inRange || isSelected ? 1 : 0.2,
      opacity: inRange || isSelected ? 1 : 0.2,
    });
  });
}

// ── Radius logic ──────────────────────────────────────────────────────────────
function updateRadius() {
  if (!selectedCity) return;
  const radius = parseInt(slider.value, 10);
  radiusValEl.textContent = radius + " km";

  // Draw / update radius circle
  if (map && window.L) {
    if (radiusCircle) radiusCircle.remove();
    radiusCircle = window.L.circle([selectedCity.lat, selectedCity.lng], {
      radius: radius * 1000,
      color: "#FF6F61",
      weight: 1.5,
      opacity: 0.5,
      fillColor: "#FF6F61",
      fillOpacity: 0.06,
    }).addTo(map);
  }

  // Cities in radius
  const inRadius = CITIES
    .map(c => ({ ...c, _d: dist(selectedCity.lat, selectedCity.lng, c.lat, c.lng) }))
    .filter(c => c.covered && c._d <= radius && c.id !== selectedCity.id)
    .sort((a, b) => a._d - b._d);

  const inRadiusIds = new Set([selectedCity.id, ...inRadius.map(c => c.id)]);
  updateMarkers(inRadiusIds);

  // Update badge
  const covInRadius = inRadius.filter(c => c.event_count > 0);
  const total = (selectedCity.event_count || 0) + covInRadius.reduce((s, c) => s + c.event_count, 0);
  mapCountBadge.textContent = covInRadius.length + 1 > 1
    ? `${covInRadius.length + 1} Städte im Umkreis`
    : "";

  // Render city list
  const rows = [selectedCity, ...inRadius].map(c => {
    const isSelected = c.id === selectedCity.id;
    const dist_str = isSelected ? "" : ` · ${c._d ? c._d.toFixed(1) + " km" : ""}`;
    const evtStr = c.event_count > 0 ? `${c.event_count} Events` : "demnächst";
    return `<div class="city-row${isSelected ? " city-row--selected" : ""}">
      <a href="${c.url}">${c.name}</a>
      <span class="city-row-meta">${evtStr}${dist_str}</span>
    </div>`;
  });

  if (total > (selectedCity.event_count || 0) && covInRadius.length > 0) {
    rows.push(`<a href="/ludwigsburg/" class="combined-btn">Alle ${total} Events im Umkreis →</a>`);
  }

  cityListEl.innerHTML = rows.join("");
  if (selectedCity.url) {
    mapCountBadge.innerHTML = selectedCity.event_count > 0
      ? `<a href="${selectedCity.url}" class="go-btn">Alle ${selectedCity.event_count} Events →</a>`
      : "";
  }
}

slider.addEventListener("input", updateRadius);

// ── Search ────────────────────────────────────────────────────────────────────
searchInput.addEventListener("input", () => {
  const q = searchInput.value.trim();
  searchClear.hidden = q.length === 0;
  searchInput.setAttribute("aria-expanded", q.length > 0 ? "true" : "false");
  if (q.length < 1) { suggestionsEl.hidden = true; return; }
  const nq = normalize(q);
  const matches = CITIES
    .filter(c => normalize(c.name).includes(nq))
    .sort((a, b) => {
      const aS = normalize(a.name).startsWith(nq);
      const bS = normalize(b.name).startsWith(nq);
      return aS === bS ? a.name.localeCompare(b.name) : (aS ? -1 : 1);
    })
    .slice(0, 8);
  if (matches.length === 0) { suggestionsEl.hidden = true; return; }
  suggestionsEl.innerHTML = matches.map(c =>
    `<li role="option" data-id="${c.id}">
      <span class="sug-name">${c.name}<span class="sug-type"> · ${c.type}</span></span>
      ${c.covered && c.event_count > 0
        ? `<span class="city-badge">${c.event_count} Events</span>`
        : `<span class="sug-soon">demnächst</span>`}
    </li>`
  ).join("");
  suggestionsEl.hidden = false;
});

searchInput.addEventListener("keydown", e => {
  if (e.key === "Escape") { suggestionsEl.hidden = true; searchInput.setAttribute("aria-expanded", "false"); }
  if (e.key === "Enter") {
    const first = suggestionsEl.querySelector("li");
    if (first) pickSuggestion(first.dataset.id);
  }
});

searchSubmit.addEventListener("click", () => {
  const first = suggestionsEl.querySelector("li");
  if (first) pickSuggestion(first.dataset.id);
});

suggestionsEl.addEventListener("click", e => {
  const li = e.target.closest("li");
  if (li) pickSuggestion(li.dataset.id);
});

function pickSuggestion(id) {
  const city = CITIES.find(c => c.id === id);
  if (!city) return;
  suggestionsEl.hidden = true;
  searchInput.setAttribute("aria-expanded", "false");
  selectCity(city);
}

searchClear.addEventListener("click", () => {
  searchInput.value = "";
  searchClear.hidden = true;
  suggestionsEl.hidden = true;
  searchInput.focus();
});

document.addEventListener("click", e => {
  if (!e.target.closest(".search-wrap")) suggestionsEl.hidden = true;
});

// ── Geolocation ───────────────────────────────────────────────────────────────
locateBtn.addEventListener("click", () => {
  if (!navigator.geolocation) return;
  locateBtn.disabled = true;
  locateBtn.textContent = "…";
  navigator.geolocation.getCurrentPosition(
    pos => {
      const { latitude: lat, longitude: lng } = pos.coords;
      // Find nearest covered city
      const nearest = CITIES
        .filter(c => c.covered)
        .map(c => ({ ...c, _d: dist(lat, lng, c.lat, c.lng) }))
        .sort((a, b) => a._d - b._d)[0];
      locateBtn.disabled = false;
      locateBtn.innerHTML = `<svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="3" fill="currentColor"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5"/></svg> Standort erkennen`;
      if (nearest) selectCity(nearest);
    },
    () => {
      locateBtn.disabled = false;
      locateBtn.innerHTML = `<svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="3" fill="currentColor"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5"/></svg> Standort erkennen`;
    }
  );
});

// ── Boot ──────────────────────────────────────────────────────────────────────
init();
</script>

<style>
  .home-shell { max-width: 720px; margin: 0 auto; padding: 0; }

  /* Hero */
  .hero { text-align: center; margin-bottom: 2rem; }
  .hero h1 {
    font-family: var(--font-heading); font-weight: 800;
    font-size: clamp(1.8rem, 5vw, 2.6rem); color: var(--text);
    letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1.5rem;
  }

  /* Search */
  .search-wrap { position: relative; max-width: 520px; margin: 0 auto; }
  .search-box {
    display: flex; align-items: center;
    border: 2px solid var(--border); border-radius: 14px;
    background: var(--surface); padding: 0 0.5rem 0 0.9rem;
    transition: border-color 150ms;
    box-shadow: var(--shadow-card);
  }
  .search-box:focus-within { border-color: var(--coral); }
  .search-icon { width: 18px; height: 18px; color: var(--text-60); flex-shrink: 0; margin-right: 0.5rem; }
  .search-box input {
    flex: 1; border: none; outline: none; background: transparent;
    font-size: 1rem; color: var(--text); padding: 0.75rem 0; font-family: var(--font-body);
  }
  .search-box input::placeholder { color: var(--text-60); }
  .search-clear {
    border: none; background: none; cursor: pointer;
    color: var(--text-60); font-size: 0.9rem; padding: 0.3rem 0.4rem;
    line-height: 1;
  }
  .search-submit {
    width: 40px; height: 40px; flex-shrink: 0;
    background: var(--coral); border: none; border-radius: 10px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 150ms;
  }
  .search-submit:hover { background: var(--coral-dark); }
  .search-submit svg { width: 18px; height: 18px; color: #fff; }

  .search-suggestions {
    position: absolute; top: calc(100% + 6px); left: 0; right: 0;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    z-index: 50; max-height: 280px; overflow-y: auto;
    list-style: none; margin: 0; padding: 0.4rem 0;
  }
  .search-suggestions li {
    padding: 0.55rem 1rem; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    gap: 0.5rem;
  }
  .search-suggestions li:hover { background: var(--coral-light); }
  .sug-name { font-size: 0.9rem; color: var(--text); }
  .sug-type { font-size: 0.78rem; color: var(--text-60); }
  .sug-soon { font-size: 0.72rem; color: var(--text-60); }
  .city-badge {
    flex-shrink: 0; font-size: 0.72rem; background: var(--coral); color: #fff;
    border-radius: 4px; padding: 0.1rem 0.45rem; font-weight: 600;
  }

  /* Locate button — below search box */
  .locate-btn {
    display: flex; align-items: center; gap: 0.4rem;
    margin: 0.6rem auto 0; background: none; border: none;
    color: var(--text-60); font-size: 0.85rem; font-family: var(--font-body);
    cursor: pointer; padding: 0.2rem 0.4rem; border-radius: 6px;
    transition: color 150ms;
  }
  .locate-btn:hover { color: var(--coral); }
  .locate-btn svg { width: 16px; height: 16px; }
  .locate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Map section */
  .map-section { margin-top: 2.5rem; }

  .map-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem;
  }
  .map-header-left { display: flex; align-items: center; gap: 0.5rem; }
  .pin-icon { width: 18px; height: 18px; color: var(--coral); flex-shrink: 0; }
  .map-city-label { font-family: var(--font-heading); font-weight: 700; font-size: 1.05rem; color: var(--text); }

  .go-btn {
    display: inline-block; background: var(--coral); color: #fff !important;
    font-weight: 700; font-size: 0.82rem; padding: 0.35rem 0.85rem;
    border-radius: 8px; text-decoration: none !important; white-space: nowrap;
    transition: background 150ms;
  }
  .go-btn:hover { background: var(--coral-dark); text-decoration: none !important; }

  /* Leaflet map */
  .leaflet-map {
    height: 340px; border-radius: var(--radius);
    border: 1px solid var(--border); overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  /* Leaflet tooltip override */
  :global(.city-tooltip) {
    background: var(--surface) !important; border: 1px solid var(--border) !important;
    color: var(--text) !important; font-family: var(--font-body) !important;
    font-size: 0.75rem !important; font-weight: 600 !important;
    padding: 0.2rem 0.5rem !important; border-radius: 6px !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12) !important;
    white-space: nowrap !important;
  }
  :global(.leaflet-tooltip-top.city-tooltip::before) { border-top-color: var(--border) !important; }

  /* Radius */
  .radius-row { display: flex; align-items: center; gap: 1rem; margin-top: 1rem; }
  .radius-label { font-size: 0.85rem; color: var(--text-60); white-space: nowrap; flex-shrink: 0; }
  .radius-val { color: var(--coral); }
  .radius-slider { flex: 1; accent-color: var(--coral); cursor: pointer; }

  /* City list */
  .city-list { margin-top: 1rem; }
  .city-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.55rem 0; border-bottom: 1px solid var(--border); font-size: 0.9rem;
  }
  .city-row a { color: var(--coral); font-weight: 600; text-decoration: none; }
  .city-row a:hover { text-decoration: underline; }
  .city-row--selected a { color: var(--text); }
  .city-row-meta { font-size: 0.78rem; color: var(--text-60); }
  .combined-btn {
    display: block; margin-top: 0.75rem; text-align: center;
    background: var(--coral); color: #fff !important;
    font-weight: 700; font-size: 0.88rem; padding: 0.6rem 1rem;
    border-radius: 10px; text-decoration: none !important;
    transition: background 150ms;
  }
  .combined-btn:hover { background: var(--coral-dark); }

  /* Default covered list */
  .covered-list { margin-top: 2rem; }
  .section-label {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-60); margin-bottom: 0.75rem;
  }

  @media (max-width: 600px) {
    .leaflet-map { height: 260px; }
    .radius-row { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
    .radius-slider { width: 100%; }
  }
</style>
