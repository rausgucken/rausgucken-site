---
import Base from "../layouts/Base.astro";
import { readFileSync } from "fs";
import { resolve } from "path";

let svgMap = "";
try {
  svgMap = readFileSync(resolve("src/assets/landkreis-map.svg"), "utf-8");
} catch (e) {
  console.warn("[index.astro] landkreis-map.svg not found");
}

let municipalities = [];
try {
  const raw = readFileSync(resolve("public/data/landkreis-ludwigsburg/distances.json"), "utf-8");
  municipalities = JSON.parse(raw).municipalities;
} catch (e) {
  console.warn("[index.astro] distances.json not found");
}

const municipalitiesJson = JSON.stringify(municipalities);
---

<Base
  title="rausgucken.de — Veranstaltungen im Landkreis Ludwigsburg"
  description="Entdecke Events im Landkreis Ludwigsburg — wähle deine Stadt und deinen Umkreis."
>
  <div class="hero">
    <div class="hero-text">
      <h1>Was ist los in deiner Stadt?</h1>
      <p class="hero-sub">Wähle eine Stadt und sieh, welche Events in deiner Nähe stattfinden.</p>
    </div>

    <!-- Search bar -->
    <div class="search-wrap">
      <div class="search-box">
        <svg class="search-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/>
          <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <input
          id="city-search"
          type="text"
          placeholder="Stadt suchen… z.B. Ludwigsburg"
          autocomplete="off"
          aria-label="Stadt suchen"
        />
        <button id="search-clear" class="search-clear" hidden aria-label="Suche leeren">&#x2715;</button>
      </div>
      <ul id="search-suggestions" class="search-suggestions" role="listbox" hidden></ul>
    </div>

    <div class="map-and-panel">

      <!-- Left: map -->
      <div class="map-col">
        <div class="map-container" id="map-container">
          {svgMap
            ? <Fragment set:html={svgMap} />
            : <div class="map-placeholder">Karte nicht verfügbar</div>
          }
          <div id="map-tooltip" class="map-tooltip" hidden></div>
        </div>
      </div>

      <!-- Right: panel -->
      <div class="side-col">

        <div id="no-selection-hint" class="hint-box">
          <div class="hint-arrow">&#8592;</div>
          <p>Klicke auf eine Stadt in der Karte oder suche oben.</p>
        </div>

        <div id="selected-city-box" class="selected-box" hidden>
          <p class="selected-label">Ausgewählte Stadt</p>
          <h2 id="selected-city-name" class="selected-name">&#8212;</h2>
          <a id="selected-city-link" href="#" class="go-btn">Alle Events anzeigen &#8594;</a>
        </div>

        <div id="radius-section" class="radius-section" hidden>
          <label class="slider-label" for="radius-slider">
            Umkreis: <strong id="radius-label" class="radius-val">0 km</strong>
          </label>
          <input id="radius-slider" type="range" min="0" max="55" value="0" step="1"
                 class="radius-slider" aria-label="Umkreis in Kilometern" />
          <div class="slider-ticks"><span>1 km</span><span>55 km</span></div>
        </div>

        <div id="radius-cities" class="radius-cities" hidden>
          <p class="section-title">Städte im Umkreis mit Events</p>
          <div id="radius-city-list"></div>
          <a id="radius-combined-link" href="#" class="combined-btn" hidden>Alle Events dieser Städte →</a>
        </div>

        <div id="covered-list" class="covered-list">
          <p class="section-title">Städte mit Veranstaltungen</p>
          <div id="covered-cities"></div>
        </div>

      </div>
    </div>
  </div>
</Base>

<style>
  @import "../styles/homepage.css";
</style>

<style is:global>
  .map-container svg#landkreis-map { width: 100%; height: auto; display: block; }
  .map-container .muni.selected {
    fill: #FF6F61 !important;
    stroke: #c94030 !important;
    stroke-width: 2.5px !important;
    opacity: 1 !important;
    filter: none !important;
  }
  .map-container .muni { fill: #CBD5E0; }
  html.dark .map-container .muni { fill: #444857; }
  .map-container .muni.dimmed { opacity: 0.25 !important; }
  .map-container .muni.covered { cursor: pointer; fill-rule: nonzero !important; }
  .map-container .muni.in-range.not-covered { fill: #B0BEC8; }
  html.dark .map-container .muni.in-range.not-covered { fill: #556070; }
  .map-container .muni.in-range.covered {
    fill: #A8B8C8 !important; opacity: 1 !important;
    stroke: #FF6F61 !important; stroke-width: 1.5px !important;
  }
  html.dark .map-container .muni.in-range.covered { fill: #6B7A8D !important; }
  .map-container .muni.covered.in-radius {
    fill: #8FA8C0 !important; opacity: 1 !important;
    stroke: #FF6F61 !important; stroke-width: 3px !important;
  }
  html.dark .map-container .muni.covered.in-radius { fill: #5C6B80 !important; }
  .map-container .city-label { fill: #4A5568 !important; font-size: 5.5px !important; }
  html.dark .map-container .city-label { fill: rgba(255,255,255,0.75) !important; }
  .map-container .muni.in-radius ~ .city-label,
  .map-container .muni.covered .city-label { fill: #ffffff !important; }
  .city-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.45rem 0; border-bottom: 1px solid var(--border); font-size: 0.85rem;
  }
  .city-row a { color: var(--coral); font-weight: 600; text-decoration: none; }
  .city-row a:hover { text-decoration: underline; }
  .city-row-meta { font-size: 0.72rem; color: var(--text-60); }
</style>

<script type="module" define:vars={{ municipalitiesJson }}>
import { dist, normalize } from "../scripts/map-utils.js";
const MUNICIPALITIES = JSON.parse(municipalitiesJson);

const svg          = document.getElementById("landkreis-map");



const tooltip      = document.getElementById("map-tooltip");
const noHint       = document.getElementById("no-selection-hint");
const selBox       = document.getElementById("selected-city-box");
const selName      = document.getElementById("selected-city-name");
const selLink      = document.getElementById("selected-city-link");
const radiusSec    = document.getElementById("radius-section");
const radiusCities = document.getElementById("radius-cities");
const coveredList  = document.getElementById("covered-list");
const slider       = document.getElementById("radius-slider");
const sliderLabel  = document.getElementById("radius-label");
const radiusCityList  = document.getElementById("radius-city-list");
const coveredCitiesEl = document.getElementById("covered-cities");
const searchInput  = document.getElementById("city-search");
const searchClear  = document.getElementById("search-clear");
const suggestions  = document.getElementById("search-suggestions");

const dataMap = Object.fromEntries(MUNICIPALITIES.map(m => [m.id, m]));
let selectedCity = null;


// Default covered list
const covered = MUNICIPALITIES.filter(m => m.covered).sort((a,b) => a.distance_km - b.distance_km);
coveredCitiesEl.innerHTML = covered.map(m =>
  `<div class="city-row"><a href="${m.url}">${m.name}</a><span class="city-row-meta">${m.event_count} Events</span></div>`
).join("");

function selectCity(m) {
  selectedCity = m;
  selName.textContent = m.name;
  if (m.covered && m.url) {
    selLink.href = m.url;
    selLink.textContent = "Alle " + m.event_count + " Events →";
    selLink.hidden = false;
  } else {
    selLink.hidden = true;
  }
  selBox.hidden = false;
  noHint.hidden = true;
  radiusSec.hidden = false;
  coveredList.hidden = false;

  if (svg) {
    // Reset all: remove selection/dim/radius classes, but restore in-range for covered cities
    svg.querySelectorAll(".muni").forEach(p => {
      p.classList.remove("selected", "dimmed", "in-radius");
      // Re-apply in-range to covered cities so their coral border is preserved
      const cityId = p.dataset.cityId;
      const cityData = dataMap[cityId];
      if (cityData && cityData.covered) {
        p.classList.add("in-range");
      } else {
        p.classList.remove("in-range");
      }
    });
    const el = svg.querySelector("[data-city-id=\"" + m.id + "\"]");
    if (el) { el.classList.add("selected"); el.classList.remove("in-range"); }
  }
  updateRadius();
  searchInput.value = "";
  suggestions.hidden = true;
  searchClear.hidden = true;
}

function updateRadius() {
  if (!selectedCity) return;
  const radius = parseInt(slider.value, 10);
  sliderLabel.textContent = radius + " km";
  if (radius === 0) {
    // At 0: only selected city visible, hide radius panel
    if (svg) {
      svg.querySelectorAll(".muni").forEach(p => {
        if (p.classList.contains("selected")) return;
        p.classList.add("dimmed");
        p.classList.remove("dimmed"); // reset then re-apply below
      });
      svg.querySelectorAll(".muni").forEach(p => {
        p.classList.toggle("dimmed", !p.classList.contains("selected"));
      });
    }
    radiusCities.hidden = true;
    radiusCityList.innerHTML = "";
    const combinedLink = document.getElementById("radius-combined-link");
    if (combinedLink) combinedLink.hidden = true;
    if (svg) {
      svg.querySelectorAll(".muni.in-radius").forEach(p => p.classList.remove("in-radius"));
      // At radius=0: dim uncovered cities, keep covered cities visible with their border
      svg.querySelectorAll(".muni").forEach(p => {
        if (p.classList.contains("selected")) return;
        const isCovered = p.classList.contains("covered");
        p.classList.toggle("dimmed", !isCovered);
      });
    }
    return;
  }
  const inRadius = MUNICIPALITIES
    .map(m => ({ ...m, _d: dist(selectedCity.lat, selectedCity.lng, m.lat, m.lng) }))
    .filter(m => m._d <= radius && m.id !== selectedCity.id)
    .sort((a, b) => a._d - b._d);
  if (svg) {
    const inIds = new Set(inRadius.map(m => m.id));
    inIds.add(selectedCity.id);
    svg.querySelectorAll(".muni").forEach(p => {
      if (p.classList.contains("selected")) return;
      p.classList.toggle("dimmed", !inIds.has(p.dataset.cityId));
    });
    // Highlight covered cities within radius with dark border
    svg.querySelectorAll(".muni.covered").forEach(p => {
      const inRange = inIds.has(p.dataset.cityId) && !p.classList.contains("selected");
      p.classList.toggle("in-radius", inRange);
    });
  }
  const covInRadius = inRadius.filter(m => m.covered);
  const combinedLink = document.getElementById("radius-combined-link");
  if (covInRadius.length > 0) {
    radiusCities.hidden = false;
    radiusCityList.innerHTML = covInRadius.map(m =>
      `<div class="city-row"><a href="${m.url}">${m.name}</a><span class="city-row-meta">${m._d.toFixed(1)} km &middot; ${m.event_count} Events</span></div>`
    ).join("");
    // Build combined URL: use first covered city as base, add others as query params
    // For now link to a search-style page listing all covered cities
    if (combinedLink) {
      const allCovered = [selectedCity, ...covInRadius].filter(m => m.url);
      if (allCovered.length > 1) {
        const total = allCovered.reduce((s,m) => s + (m.event_count||0), 0);
        const cityIds = allCovered.map(m => m.id).join(",");
        combinedLink.href = `/ludwigsburg/umkreis?cities=${cityIds}`;
        combinedLink.textContent = `Alle ${total} Events im Umkreis ansehen →`;
        combinedLink.hidden = false;
      } else {
        combinedLink.hidden = true;
      }
    }
  } else {
    radiusCities.hidden = true;
    radiusCityList.innerHTML = "";
    if (combinedLink) combinedLink.hidden = true;
  }
}

slider.addEventListener("input", updateRadius);

if (svg) {
  svg.addEventListener("mousemove", e => {
    const path = e.target.closest(".muni");
    if (!path || !tooltip) { tooltip.hidden = true; return; }
    const m = dataMap[path.dataset.cityId];
    if (!m) { tooltip.hidden = true; return; }
    tooltip.innerHTML = m.covered
      ? "<strong>" + m.name + "</strong><br>" + m.event_count + " Veranstaltungen"
      : "<strong>" + m.name + "</strong><br><em style=\"opacity:.6\">Demnächst</em>";
    tooltip.hidden = false;
    const rect = svg.closest(".map-container").getBoundingClientRect();
    tooltip.style.left = (e.clientX - rect.left + 14) + "px";
    tooltip.style.top  = (e.clientY - rect.top  + 14) + "px";
  });
  svg.addEventListener("mouseleave", () => { if (tooltip) tooltip.hidden = true; });
  svg.addEventListener("click", e => {
    const path = e.target.closest(".muni");
    if (!path) return;
    const m = dataMap[path.dataset.cityId];
    if (!m) return;
    selectCity(m);
  });
}


searchInput.addEventListener("input", () => {
  const q = searchInput.value.trim();
  searchClear.hidden = q.length === 0;
  if (q.length < 1) { suggestions.hidden = true; return; }
  const nq = normalize(q);
  const matches = MUNICIPALITIES
    .filter(m => normalize(m.name).includes(nq))
    .sort((a, b) => {
      const aS = normalize(a.name).startsWith(nq);
      const bS = normalize(b.name).startsWith(nq);
      if (aS !== bS) return aS ? -1 : 1;
      return a.name.localeCompare(b.name);
    })
    .slice(0, 8);
  if (matches.length === 0) { suggestions.hidden = true; return; }
  suggestions.innerHTML = matches.map(m =>
    `<li role="option" data-id="${m.id}">${m.name}${m.covered ? ` <span class="city-badge">${m.event_count} Events</span>` : ` <span style="font-size:.72rem;color:var(--text-60)">Demnächst</span>`}</li>`
  ).join("");
  suggestions.hidden = false;
});

searchInput.addEventListener("keydown", e => {
  if (e.key === "Escape") suggestions.hidden = true;
  if (e.key === "Enter") {
    const first = suggestions.querySelector("li");
    if (first) pickSuggestion(first.dataset.id);
  }
});

suggestions.addEventListener("click", e => {
  const li = e.target.closest("li");
  if (li) pickSuggestion(li.dataset.id);
});

function pickSuggestion(id) {
  const m = dataMap[id];
  if (!m) return;
  suggestions.hidden = true;
  selectCity(m);
}

searchClear.addEventListener("click", () => {
  searchInput.value = "";
  searchClear.hidden = true;
  suggestions.hidden = true;
  searchInput.focus();
});

document.addEventListener("click", e => {
  if (!e.target.closest(".search-wrap")) suggestions.hidden = true;
});
</script>
