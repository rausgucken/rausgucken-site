
---
// src/pages/bietigheim/events/[slug].astro
// SEO: keyword-first title, full Event schema (§10), BreadcrumbList (§10),
//      expired event banner (§5), RelatedPages internal linking (§22)
// UPDATED: resolves all 9 Google Search Console schema warnings:
//   performer, address, validFrom, price format, endDate, offers, image, eventStatus, organizer

import Base from "../../../layouts/Base.astro";
import eventsData from "../../../../public/data/bietigheim/events-current.json";
import tipsData from "../../../../src/data/editorial-tips.json";

export async function getStaticPaths() {
  // Deduplicate by slug — keeps first occurrence when multiple events share the same slug
  // (can happen when two sources produce near-identical slugs after truncation)
  const seen = new Set<string>();
  return eventsData
    .filter(ev => {
      if (seen.has(ev.slug)) return false;
      seen.add(ev.slug);
      return true;
    })
    .map(ev => ({
      params: { slug: ev.slug },
      props:  { event: ev },
    }));
}

const { event: ev } = Astro.props;
const editorialTip: string | undefined = (() => {
  if (!tipsData || typeof tipsData !== "object") return undefined;
  const tips = tipsData as Record<string, unknown>;
  const val = tips[ev.slug];
  if (!val || typeof val !== "object") return undefined;
  const tip = (val as Record<string, unknown>).tip;
  return typeof tip === "string" && tip.length > 0 ? tip : undefined;
})();
const siteUrl = "https://www.rausgucken.de";

// ── Dates & freshness ─────────────────────────────────────────────────────────
function formatDateDE(iso) {
  if (!iso) return "Dauerhaft verfügbar";
  const d = new Date(iso + "T12:00:00");
  return d.toLocaleDateString("de-DE", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
}
function formatDateShort(iso) {
  if (!iso) return null;
  const d = new Date(iso + "T12:00:00");
  return d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" });
}

const today        = new Date().toISOString().slice(0, 10);
const isExpired    = !!(ev.date_start && ev.date_start < today);
const scrapedFormatted = ev.scraped_at
  ? new Date(ev.scraped_at).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })
  : null;

// ── Canonical ─────────────────────────────────────────────────────────────────
const canonical = `${siteUrl}/bietigheim/events/${ev.slug}/`;

// ── OG image ──────────────────────────────────────────────────────────────────
// Falls back to city-level OG if per-event image not yet generated
const ogImage = `/og/bietigheim/${ev.slug}.jpg`;
const detailImage = `/og/detail/bietigheim/${ev.slug}.webp`;

// ── SEO title — keyword-first per §9: "{Event} Ludwigsburg {Date} | rausgucken.de"
const dateLabel = ev.date_start ? formatDateShort(ev.date_start) : "Dauerveranstaltung";
const MAX = 45;
   const truncated = ev.title.length > MAX ? ev.title.slice(0, MAX).trimEnd() + "…" : ev.title;
   const seoTitle = `${truncated} Bietigheim-Bissingen ${dateLabel} | rausgucken.de`;
// ── Meta description ──────────────────────────────────────────────────────────
const metaDesc = ev.description
  ? ev.description.slice(0, 150) + (ev.description.length > 150 ? "…" : "")
  : `${ev.title} – Veranstaltung in Bietigheim-Bissingen${ev.date_start ? ` am ${dateLabel}` : ""}. Alle Details und Originalseite auf rausgucken.de.`;

// ── Tag display labels ────────────────────────────────────────────────────────
const TAG_LABELS = {
  Ausstellung: "Ausstellung", Entertainment: "Entertainment", Familie: "Familie",
  Fest: "Fest", Fuehrung: "Führung", Jugend: "Jugend", Kinder: "Kinder",
  Kulinarik: "Kulinarik", Lesung: "Lesung", Messe: "Messe", Musik: "Musik",
  Outdoor: "Outdoor", Sport: "Sport", Sprache: "Sprache", Tanz: "Tanz",
  Theater: "Theater", Vortrag: "Vortrag", Workshop: "Workshop",
};

// ── Price normaliser — FIX: converts "Erwachsene 13,00 € Ermäßigte 6,50 €"
// to schema.org-valid numeric format. Raw German price strings fail Google validation.
function normalisePrice(priceStr) {
  if (!priceStr) return null;
  const s = String(priceStr).trim().toLowerCase();
  if (["kostenlos", "frei", "eintritt frei", "0", "gratis", "kostenfrei"].includes(s)) {
    return { price: "0", currency: "EUR" };
  }
  // Multi-tier pricing: extract the first (typically lowest) numeric value
  // e.g. "Erwachsene 13,00 € Ermäßigte 6,50 €" → "13.00"
  const m2 = s.match(/(\d+)[,.](\d{2})/);
  if (m2) return { price: `${m2[1]}.${m2[2]}`, currency: "EUR" };
  const m1 = s.match(/(\d+)/);
  if (m1) return { price: `${m1[1]}.00`, currency: "EUR" };
  return null; // unknown price — omit offers block entirely
}

// ── Organizer map — FIX: use proper institution name per source, not ev.location
// Add new sources here as you add more scrapers
const SOURCE_ORGANIZERS = {
  schloss:                      { name: "Schloss Ludwigsburg",         url: "https://www.schloss-ludwigsburg.de" },
  museum:                       { name: "Stadtmuseum Ludwigsburg",     url: "https://www.ludwigsburg.de/stadtmuseum" },
  labyrinth:                    { name: "Kunstschule Labyrinth",       url: "https://kunstschule-labyrinth.ludwigsburg.de" },
  karlskaserne_ausstellungen:   { name: "Kunstzentrum Karlskaserne",   url: "https://karlskaserne.ludwigsburg.de" },
  karlskaserne_veranstaltungen: { name: "Kunstzentrum Karlskaserne",   url: "https://karlskaserne.ludwigsburg.de" },
  kunstverein_ausstellungen:    { name: "Kunstverein Ludwigsburg",     url: "https://www.kunstverein-ludwigsburg.de" },
  kunstverein_veranstaltungen:  { name: "Kunstverein Ludwigsburg",     url: "https://www.kunstverein-ludwigsburg.de" },
  stabi:                        { name: "Stadtbibliothek Ludwigsburg", url: "https://events-stabi.ludwigsburg.de" },
};
const organizer = SOURCE_ORGANIZERS[ev.source] ?? {
  name: ev.location || "Bietigheim-Bissingen",
  url: ev.original_url || siteUrl,
};

// ── Calendar export URLs ─────────────────────────────────────────────────────
function buildGoogleCalendarUrl(ev) {
  const base = 'https://calendar.google.com/calendar/render?action=TEMPLATE';
  const fmt = (iso, time) => {
    if (!iso) return '';
    if (!time) return iso.replace(/-/g, '');
    const m = time.match(/(\d{1,2}):(\d{2})/);
    if (!m) return iso.replace(/-/g, '');
    return iso.replace(/-/g, '') + 'T' + m[1].padStart(2,'0') + m[2] + '00';
  };
  const endM = ev.time ? ev.time.match(/\d{1,2}:\d{2}\s*[-–]\s*(\d{1,2}):(\d{2})/) : null;
  const endTime = endM ? `${endM[1].padStart(2,'0')}${endM[2]}00` : null;
  const start = fmt(ev.date_start, ev.time);
  const endBase = ev.date_end || ev.date_start;
  const end = endTime
    ? endBase.replace(/-/g,'') + 'T' + endTime
    : start;
  const params = new URLSearchParams({
    text: ev.title || '',
    dates: `${start}/${end}`,
    location: ev.location || 'Bietigheim-Bissingen',
    details: [
      ev.description || '',
      ev.location ? `Adresse: ${ev.location}, Bietigheim-Bissingen` : '',
      ev.original_url ? `Originalseite (bitte vor Teilnahme prüfen): ${ev.original_url}` : '',
      'Alle Angaben ohne Gewähr – bitte Originalseite prüfen.',
    ].filter(Boolean).join('\n\n'),
  });
  return `${base}&${params.toString()}`;
}

function buildOutlookUrl(ev) {
  const fmt = (iso, time) => {
    if (!iso) return '';
    const m = time ? time.match(/(\d{1,2}):(\d{2})/) : null;
    if (!m) return iso + 'T00:00:00';
    return `${iso}T${m[1].padStart(2,'0')}:${m[2]}:00`;
  };
  const endM = ev.time ? ev.time.match(/\d{1,2}:\d{2}\s*[-–]\s*(\d{1,2}):(\d{2})/) : null;
  const endTime = endM ? `${endM[1].padStart(2,'0')}:${endM[2]}:00` : null;
  const start = fmt(ev.date_start, ev.time);
  const endBase = ev.date_end || ev.date_start;
  const end = endTime ? `${endBase}T${endTime}` : start;
  const params = new URLSearchParams({
    path: '/calendar/action/compose',
    rru: 'addevent',
    subject: ev.title || '',
    startdt: start,
    enddt: end,
    location: ev.location || 'Bietigheim-Bissingen',
    body: [
      ev.description || '',
      ev.location ? `Adresse: ${ev.location}, Bietigheim-Bissingen` : '',
      ev.original_url ? `Originalseite (bitte vor Teilnahme prüfen): ${ev.original_url}` : '',
      'Alle Angaben ohne Gewähr – bitte Originalseite prüfen.',
    ].filter(Boolean).join('\n\n'),
  });
  return `https://outlook.live.com/calendar/0/action/compose?${params.toString()}`;
}

const googleCalUrl  = buildGoogleCalendarUrl(ev);
const outlookCalUrl = buildOutlookUrl(ev);
const icsUrl        = `/bietigheim/events/${ev.slug}.ics`;

// Share URLs
const shareEventUrl = `https://www.rausgucken.de/bietigheim/events/${ev.slug}/`;
const shareText     = encodeURIComponent(`${ev.title} – ${shareEventUrl}`);
const waShareUrl    = `https://wa.me/?text=${shareText}`;
const tgShareUrl    = `https://t.me/share/url?url=${encodeURIComponent(shareEventUrl)}&text=${encodeURIComponent(ev.title)}`;
const wireShareUrl  = `https://app.wire.com/share?text=${shareText}`;
const tgShareText   = encodeURIComponent(ev.title);

// ── Resolved values used in schema ───────────────────────────────────────────
const priceData = normalisePrice(ev.price);

// ── Full Event schema — SEO §10A ──────────────────────────────────────────────
// FIX: adds performer, postalCode in address, validFrom in offers,
//      numeric price format, proper organizer name
const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": ev.title,
  ...(ev.description ? { "description": ev.description } : {}),
  "inLanguage": "de-DE",
  ...(ev.date_start ? {
    "startDate": ev.time ? `${ev.date_start}T${ev.time}` : ev.date_start,
  } : {}),
  // endDate: use date_end if present, otherwise same as startDate (single-day event)
  ...(ev.date_start ? {
    "endDate": ev.date_end || ev.date_start,
  } : {}),
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  // eventStatus: always EventScheduled — expired events keep this; expired banner handles UI
  "eventStatus": "https://schema.org/EventScheduled",
  // image: required for Google event rich results (§10, §20)
  "image": `${siteUrl}${ogImage}`,
  "url": canonical,
  "location": {
    "@type": "Place",
    "name": ev.location || "Bietigheim-Bissingen",
    // FIX: added postalCode — satisfies "Missing field 'address'" enhancement
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bietigheim-Bissingen",
      "postalCode": "74321",
      "addressRegion": "Baden-Württemberg",
      "addressCountry": "DE",
    },
  },
  // FIX: organizer now uses institution name from SOURCE_ORGANIZERS, not ev.location
  "organizer": {
    "@type": "Organization",
    "name": organizer.name,
    "url": organizer.url,
  },
  // FIX: performer added — required by Google. For non-performance events,
  // the organizer is the correct fallback (standard schema.org practice)
  "performer": {
    "@type": "PerformingGroup",
    "name": organizer.name,
  },
  // FIX: offers only included when price is parseable to a valid number.
  // validFrom uses scraped_at (present on all events). Price is numeric string, not raw German text.
  ...(priceData ? {
    "offers": {
      "@type": "Offer",
      "price": priceData.price,
      "priceCurrency": priceData.currency,
      "validFrom": ev.scraped_at,
      "availability": "https://schema.org/InStock",
      "url": ev.original_url || canonical,
    },
  } : {}),
};

// ── BreadcrumbList schema — SEO §10C ──────────────────────────────────────────
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Bietigheim-Bissingen", "item": `${siteUrl}/bietigheim/` },
    { "@type": "ListItem", "position": 3, "name": ev.title,        "item": canonical },
  ],
};

// ── Related events for expired page — SEO §5: show 3 current alternatives ─────
// BUG FIX: filter must check each candidate's own date, not the outer isExpired flag
const relatedEvents = isExpired
  ? eventsData
      .filter(e =>
        e.slug !== ev.slug &&
        e.date_start && e.date_start >= today &&           // only current events
        Array.isArray(e.tags) && Array.isArray(ev.tags) &&
        e.tags.some(t => ev.tags.includes(t))              // same category
      )
      .slice(0, 3)
  : [];
---

<Base
  title={seoTitle}
  description={metaDesc}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  schema={[eventSchema, breadcrumbSchema]}
>

  <!-- ── Expired event banner — SEO §5 ──────────────────────────────────── -->
  <!-- "Diese Veranstaltung hat bereits stattgefunden." must be shown prominently -->
  {isExpired && (
    <div class="expired-banner" role="alert" aria-live="polite">
      <span class="expired-icon" aria-hidden="true">⏰</span>
      <div>
        <strong>Diese Veranstaltung hat bereits stattgefunden.</strong>
        {relatedEvents.length > 0
          ? " Ähnliche aktuelle Veranstaltungen findest du hier:"
          : " Schau dir aktuelle Veranstaltungen in Bietigheim-Bissingen an."}
      </div>
    </div>
  )}

  <!-- Related events for expired pages (§5) -->
  {isExpired && relatedEvents.length > 0 && (
    <div class="related-events" aria-label="Ähnliche aktuelle Veranstaltungen">
      {relatedEvents.map(r => (
        <a href={`/bietigheim/events/${r.slug}`} class="related-card">
          <div class="related-card-body">
            <span class="related-title">{r.title}</span>
            {r.location && <span class="related-location">{r.location}</span>}
          </div>
          <span class="related-date">{formatDateShort(r.date_start)}</span>
        </a>
      ))}
    </div>
  )}

  {isExpired && relatedEvents.length === 0 && (
    <div class="expired-cta">
      <a href="/bietigheim" class="btn-cta">Alle aktuellen Veranstaltungen →</a>
    </div>
  )}

  <!-- ── Breadcrumb nav — visible + schema-marked (SEO §10C) ───────────── -->
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/bietigheim">Bietigheim-Bissingen</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">{ev.title}</span>
  </nav>

  <article class="event-detail">

    <header class="event-header">
      <!-- Tags row -->
      <div class="event-tags" aria-label="Kategorien">
        {Array.isArray(ev.tags) && ev.tags.map(t => (
          <a href={t === "Kinder" || t === "Familie" ? "/bietigheim" : "/bietigheim"}
             class={`tag${t === "Kinder" || t === "Familie" ? " tag--sage" : ""}`}>
            {TAG_LABELS[t] ?? t}
          </a>
        ))}
        {ev.age_min != null && (
          <span class="tag tag--age">
            ab {ev.age_min} J.{ev.age_max ? ` bis ${ev.age_max} J.` : "+"}
          </span>
        )}
      </div>

      <h1>{ev.title}</h1>
    </header>
    
    <!-- ── Hero image ────────────────────────────────────────────────────── -->
    <div class="event-hero">
      <img
        src={detailImage}
        alt={`${ev.title} – ${ev.location || organizer.name} in Bietigheim-Bissingen`}
        width="720"
        height="380"
        loading="eager"
        decoding="async"
        class="hero-img"
        onerror="this.closest('.event-hero').style.display='none'"
      />
    </div>

        <!-- ── Meta grid ──────────────────────────────────────────────────────── -->
    <dl class="meta-grid">
      <div class="meta-item">
        <dt class="meta-label">Datum</dt>
        <dd class="meta-value" content={ev.date_start ?? ""}>
          {formatDateDE(ev.date_start)}
        </dd>
      </div>
      {ev.date_end && ev.date_end !== ev.date_start && (
        <div class="meta-item">
          <dt class="meta-label">Bis</dt>
          <dd class="meta-value" content={ev.date_end}>
            {formatDateShort(ev.date_end)}
          </dd>
        </div>
      )}
      {ev.time && (
        <div class="meta-item">
          <dt class="meta-label">Uhrzeit</dt>
          <dd class="meta-value">{ev.time} Uhr</dd>
        </div>
      )}
      {ev.location && (
        <div class="meta-item">
          <dt class="meta-label">Ort</dt>
          <dd class="meta-value">
            <span>{ev.location}</span>
          </dd>
        </div>
      )}
      {ev.price != null && (
        <div class="meta-item">
          <dt class="meta-label">Preis</dt>
          <dd class="meta-value">{ev.price || "Kostenlos"}</dd>
        </div>
      )}
    </dl>

    <!-- ── Description ───────────────────────────────────────────────────── -->
    {ev.description && (
      <div class="event-description">
        <h2>Beschreibung</h2>
        <p>{ev.description}</p>
      </div>
    )}

    <!-- ── Editorial tip (SEO §13 / E-E-A-T) ────────────────────── -->
    {editorialTip && (
      <div class="editorial-tip" role="note" aria-label="Redaktionstipp">
        <span class="tip-label" aria-hidden="true">💡 Unser Tipp</span>
        <p class="tip-text">{editorialTip}</p>
      </div>
    )}

    <!--
      ── Source box — SEO §7 (AI Trust Signals) + Design spec Part V §6 (SourceLink)
      Exposes: source name, source URL, data timestamp.
      Design rule: Coral bg → Charcoal text on button. NEVER white text on coral.
      FreshnessStamp: opacity-70 on default text. NEVER coral text.
      This box MUST always be visible — cannot be in accordion.
    -->
    <div class="source-box" aria-label="Quellenangabe">
      <div class="source-info">
        <p class="source-label">Quelle &amp; Aktualität</p>
        <p class="source-name">{organizer.name}</p>
        {scrapedFormatted && (
          <p class="freshness-stamp">Erfasst am: {scrapedFormatted}</p>
        )}
        <p class="source-disclaimer">Alle Angaben ohne Gewähr — bitte Originalseite prüfen.</p>

      </div>
      {ev.original_url && (
        <a
          href={ev.original_url}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-original"
          aria-label={`Originalseite für ${ev.title} in neuem Tab öffnen`}
        >
          Zur Originalseite →
        </a>
      )}
      <details class="share-dropdown">
        <summary class="btn-share" aria-label={`${ev.title} teilen`}>
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Teilen
        </summary>
        <ul class="share-menu" role="list">
          <li><a href={waShareUrl} target="_blank" rel="noopener noreferrer" class="share-item">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a></li>
          <li><a href={tgShareUrl} target="_blank" rel="noopener noreferrer" class="share-item">
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Telegram
          </a></li>
          <li><a href={`https://threema.id/compose?text=${shareText}`} target="_blank" rel="noopener noreferrer" class="share-item">
