---
import Base from "../../layouts/Base.astro";
import FreshnessStamp from '../../components/FreshnessStamp.astro';
import EventCard from "../../components/EventCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import ImportantLinksSidebar from "../../components/ImportantLinksSidebar.astro";

import eventsData from "../../../public/data/ludwigsburg/events-current.json";
import metaData from "../../../public/data/ludwigsburg/meta.json";

const events = eventsData;
const meta = metaData;

const dated    = events.filter(e => e.date_start);
const standing = events.filter(e => !e.date_start);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Veranstaltungen in Ludwigsburg",
  "url": "https://rausgucken.de/ludwigsburg/",
  "numberOfItems": events.length,
};
---

<Base
  title="Veranstaltungen Ludwigsburg 2026 – Alle Events & Ausstellungen | rausgucken.de"
  description={`${events.length} aktuelle Veranstaltungen in Ludwigsburg. Ausstellungen, Kinder-Events, kostenlose Angebote und mehr — täglich aktuell, übersichtlich auf einen Blick.`}
  city="ludwigsburg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-header">
    <h1>Veranstaltungen in Ludwigsburg</h1>
    <p class="page-subtitle">
      <FreshnessStamp scrapedAt={meta.scraped_at} />
    </p>
  </div>

  {meta.sources_failed && meta.sources_failed.length > 0 && (
    <div class="sources-warning" role="alert">
      <strong>⚠ Hinweis:</strong> {meta.sources_failed.length} {meta.sources_failed.length === 1 ? "Quelle" : "Quellen"} derzeit nicht erreichbar — Angaben können unvollständig sein.
    </div>
  )}

  <aside class="disclaimer-box">
    <strong>Hinweis:</strong> {meta.disclaimer_note || "Alle Angaben ohne Gewähr. Bitte prüfen Sie Infos auf der jeweiligen Originalseite."}
    <a href="/about">Mehr Informationen</a>
  </aside>

  <FilterBar />

  <!-- Two-column layout: event list left (720px), sidebar right (260px) -->
  <!-- Sidebar is display:none on mobile via CSS — footer carries the links instead -->
  <div class="city-layout">

    <!-- Left: event content -->
    <div class="city-main">

      <div class="empty-state" id="empty-state" aria-live="polite" hidden>
        <div class="empty-state-inner">
          <p class="empty-headline">Keine Treffer für diese Filter.</p>
          <p class="empty-body">Vielleicht ist heute ein guter Tag, einfach rauszugehen!</p>
          <div class="empty-ctas">
            <a href="https://www.schloss-ludwigsburg.de" target="_blank" rel="noopener noreferrer" class="empty-cta">
              Residenzschloss entdecken →
            </a>
            <a href="https://www.ludwigsburg.de/de/stadtleben/freizeit-sport/" target="_blank" rel="noopener noreferrer" class="empty-cta">
              Freizeit in Ludwigsburg →
            </a>
          </div>
          <button class="empty-reset" id="empty-reset-btn" type="button">
            Filter zurücksetzen
          </button>
        </div>
      </div>

      {dated.length > 0 && (
        <section id="section-dated">
          <h2 class="section-heading">Kommende Veranstaltungen</h2>
          <div class="event-list" id="event-grid">
            {dated.map(ev => (
              <EventCard event={ev} />
            ))}
          </div>
        </section>
      )}

      {standing.length > 0 && (
        <section id="section-standing" style="margin-top: 3rem;">
          <h2 class="section-heading">Dauerveranstaltungen & Führungen</h2>
          <p class="section-note">Diese Angebote finden regelmäßig statt. Termine auf der Originalseite prüfen.</p>
          <div class="event-list">
            {standing.map(ev => (
              <EventCard event={ev} />
            ))}
          </div>
        </section>
      )}

      {events.length === 0 && (
        <div class="empty-state empty-state--visible">
          <div class="empty-state-inner">
            <p class="empty-headline">Aktuell keine Veranstaltungen verfügbar.</p>
            <p class="empty-body">Schau bald wieder vorbei — oder geh einfach schon mal raus!</p>
            <div class="empty-ctas">
              <a href="https://www.schloss-ludwigsburg.de" target="_blank" rel="noopener noreferrer" class="empty-cta">
                Residenzschloss entdecken →
              </a>
              <a href="https://www.ludwigsburg.de/de/stadtleben/freizeit-sport/" target="_blank" rel="noopener noreferrer" class="empty-cta">
                Freizeit in Ludwigsburg →
              </a>
            </div>
          </div>
        </div>
      )}

    </div><!-- /.city-main -->

    <!-- Right: sidebar — hidden on mobile, sticky on desktop -->
    <ImportantLinksSidebar />

  </div><!-- /.city-layout -->

  <script src="/scripts/app.js" is:inline></script>
</Base>

<style>
  /* ── Page header ─────────────────────────────────────────────────────────── */
  .page-header { margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; }

  /* ── Scraper failure alert ───────────────────────────────────────────────── */
  .sources-warning {
    background: var(--coral-light);
    border: 1px solid rgba(255,111,97,0.30);
    border-radius: var(--radius-sm);
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.85;
    margin-bottom: 0.85rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Disclaimer ─────────────────────────────────────────────────────────── */
  .disclaimer-box {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.85rem 1.25rem;
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.70;
    margin-bottom: 1.5rem;
    line-height: 1.5;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .disclaimer-box a { color: var(--text); font-weight: 600; margin-left: 0.35rem; }

    /* ── Layout ─────────────────────────────────────────────────────────────── */
  /* Cards and filterbar stay exactly as-is: max-width 720px, margin auto.
     Sidebar is position:fixed, vertically centered on right side of viewport,
     appearing just outside the 720px content column. No layout impact. */
  .city-layout { display: block; }
  .city-main   { display: block; }

  @media (min-width: 961px) {
    .city-layout :global(.important-links-sidebar) {
      display: block;
      position: fixed;
      top: 160px;
      /* Place sidebar just to the right of the 720px centered content.
         Content right edge = 50vw + 360px.
         Sidebar left edge  = 50vw + 360px + 24px gap. */
      left: calc(50% + 384px);
      width: 200px;
    }
  }

  @media (max-width: 960px) {
    .city-layout :global(.important-links-sidebar) {
      display: none;
    }
  }

  /* ── Section headings ───────────────────────────────────────────────────── */
  .section-heading {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-note {
    font-size: 0.85rem;
    color: var(--text-60);
    margin-bottom: 1rem;
    margin-top: -0.5rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Event list — inherits global .event-list from Base.astro ───────────── */
  /* max-width:720px and margin:0 auto from Base.astro apply naturally — no override needed */

  /* ── Dark mode card shadow ──────────────────────────────────────────────── */
  html.dark .event-card {
    box-shadow: 0 2px 8px rgba(0,0,0,0.22);
  }



  /* ── Empty state ─────────────────────────────────────────────────────────── */
  .empty-state {
    display: none;
    padding: 3rem 1.5rem;
    text-align: center;
  }
  .empty-state:not([hidden]),
  .empty-state--visible { display: block; }
  .empty-state-inner {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-card);
  }
  .empty-headline {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .empty-body {
    font-size: 0.95rem;
    color: var(--text-60);
    margin-bottom: 1.5rem;
  }
  .empty-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .empty-cta {
    background: var(--coral);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 150ms;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .empty-cta:hover { background: var(--coral-dark); text-decoration: none; }
  .empty-cta:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .empty-reset {
    background: transparent;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-60);
    cursor: pointer;
    min-height: 44px;
    transition: border-color 150ms, color 150ms;
  }
  .empty-reset:hover { border-color: var(--coral); color: var(--coral); }
  .empty-reset:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
</style>
