---
import Base from "../../../layouts/Base.astro";
import FreshnessStamp from '../../../components/FreshnessStamp.astro';
import EventCard from "../../../components/EventCard.astro";
import FilterBar from "../../../components/FilterBar.astro";

import subsetData from "../../../../public/data/ludwigsburg/this-weekend.json";
import metaData from "../../../../public/data/ludwigsburg/meta.json";

const events = subsetData.events ?? [];
const meta = metaData;

const siteUrl = "https://www.rausgucken.de";
const city    = "ludwigsburg";

// Weekend date range — computed at build time
const now       = new Date();
const dayOfWeek = now.getDay(); // 0=Sun,1=Mon,...,6=Sat
const daysToSat = dayOfWeek === 0 ? 6 : (6 - dayOfWeek);
const sat       = new Date(now); sat.setDate(now.getDate() + daysToSat);
const sun       = new Date(sat); sun.setDate(sat.getDate() + 1);

const satISO = sat.toISOString().slice(0, 10);
const sunISO = sun.toISOString().slice(0, 10);

const fmtShort = (d: Date) => d.toLocaleDateString("de-DE", { day: "numeric", month: "long" });
const fmtFull  = (d: Date) => d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" });

const satDE  = fmtShort(sat);
const sunDE  = fmtFull(sun);
const rangeDE = `${satDE} – ${sunDE}`;

const canonical = `${siteUrl}/${city}/dieses-wochenende/`;
const seoTitle  = `Events Ludwigsburg Wochenende, ${rangeDE} | rausgucken.de`;
const metaDesc  = `Veranstaltungen in Ludwigsburg dieses Wochenende (${rangeDE}): Ausflüge, Kinder, Kultur, Outdoor – alles auf einen Blick.`;

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Events Ludwigsburg Wochenende – ${rangeDE}`,
  "description": metaDesc,
  "url": canonical,
  "inLanguage": "de-DE",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de",     "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Ludwigsburg",       "item": `${siteUrl}/${city}/` },
    { "@type": "ListItem", "position": 3, "name": "Dieses Wochenende", "item": canonical },
  ],
};
---

<Base
  title={seoTitle}
  description={metaDesc}
  canonical={canonical}
  ogImage="/og/ludwigsburg/dieses-wochenende.jpg"
  schema={[collectionSchema, breadcrumbSchema]}
>
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/ludwigsburg">Ludwigsburg</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">Dieses Wochenende</span>
  </nav>

  <div class="page-header">
    <h1>Events Ludwigsburg dieses Wochenende</h1>
    <p class="page-subtitle">
      {events.length > 0 ? `${events.length} Veranstaltungen · ` : ""}{rangeDE}
      <FreshnessStamp scrapedAt={meta.scraped_at} />
    </p>
  </div>

  <!-- Day tabs: Beide Tage / Sa / So — filter already-rendered DOM, no re-render -->
  <div class="day-tabs" role="tablist" aria-label="Wochenendtag auswählen">
    <button class="day-tab day-tab--active" role="tab" aria-selected="true"  data-day="all" type="button">Beide Tage</button>
    <button class="day-tab"                 role="tab" aria-selected="false" data-day={satISO} type="button">Samstag <span class="tab-date">{satDE}</span></button>
    <button class="day-tab"                 role="tab" aria-selected="false" data-day={sunISO} type="button">Sonntag <span class="tab-date">{sunDE}</span></button>
  </div>

  <FilterBar />

  <div class="empty-state" id="empty-state" aria-live="polite" hidden></div>

  {events.length > 0 ? (
    <div class="event-list" id="event-grid">
      {events.map(ev => (
        <div class="event-day-wrapper" data-date={ev.date_start}>
          <EventCard event={ev} />
        </div>
      ))}
    </div>
  ) : (
    <div class="empty-today">
      <div class="empty-inner">
        <p class="empty-headline">Dieses Wochenende noch keine Einträge.</p>
        <p class="empty-body">Schau nächste Woche nochmal vorbei – neue Veranstaltungen werden laufend ergänzt.</p>
        <div class="empty-ctas">
          <a href="/ludwigsburg/naechste-woche" class="btn-cta">Nächste Woche →</a>
          <a href="/ludwigsburg" class="btn-cta btn-cta--ghost">Alle Veranstaltungen</a>
        </div>
      </div>
    </div>
  )}

  <nav class="temporal-nav" aria-label="Andere Zeiträume in Ludwigsburg">
    <p class="temporal-label">Andere Zeiträume</p>
    <div class="temporal-links">
      <a href="/ludwigsburg/heute">Heute</a>
      <a href="/ludwigsburg/morgen">Morgen</a>
      <a href="/ludwigsburg/naechste-woche">Nächste Woche</a>
      <a href="/ludwigsburg/kinder">Kinder &amp; Familie</a>
      <a href="/ludwigsburg">Alle Veranstaltungen</a>
    </div>
  </nav>

  <script src="/scripts/app.js" is:inline></script>
</Base>

<!-- Day tab filtering — operates on rendered DOM, no fetch, no re-render -->
<script is:inline>
(function () {
  var tabs = document.querySelectorAll('.day-tab');
  var wrappers = document.querySelectorAll('.event-day-wrapper');

  function setActiveTab(dayFilter) {
    tabs.forEach(function (t) {
      var isActive = t.dataset.day === dayFilter;
      t.classList.toggle('day-tab--active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    var visible = 0;
    wrappers.forEach(function (w) {
      var show = dayFilter === 'all' || w.dataset.date === dayFilter;
      w.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Show inline empty if all filtered out
    var emptyEl = document.getElementById('empty-state');
    if (emptyEl) emptyEl.hidden = visible > 0;
  }

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () { setActiveTab(tab.dataset.day); });
  });
})();
</script>

<style>
  .page-header { margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }

  /* Day tabs — Design System §V.7 */
  .day-tabs { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .day-tab {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.35rem;
    min-height: 44px; min-width: 44px; padding: 0 0.875rem;
    border: none; border-radius: var(--radius-sm);
    background: var(--tag-bg); color: var(--text-60);
    font-family: var(--font-body); font-size: 0.875rem; font-weight: 500;
    cursor: pointer; transition: background 200ms, color 200ms;
  }
  .day-tab:hover:not(.day-tab--active) { background: var(--coral-light); color: var(--text); }
  .day-tab--active { background: var(--coral); color: var(--text); font-weight: 600; } /* charcoal on coral — Button Rule */
  .day-tab:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .tab-date { font-size: 0.78rem; opacity: 0.75; }

  html.dark .event-card { box-shadow: 0 2px 8px rgba(0,0,0,0.22); }

  .empty-today { max-width: 720px; padding: 2rem 0; }
  .empty-inner { background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem 2rem; text-align: center; }
  .empty-headline { font-family: var(--font-heading); font-weight: 700; font-size: 1.1rem; margin-bottom: 0.5rem; }
  .empty-body { color: var(--text-60); margin-bottom: 1.5rem; }
  .empty-ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn-cta { display: inline-flex; align-items: center; height: 44px; padding: 0 1.25rem; background: var(--coral); color: var(--text); border-radius: var(--radius-sm); font-weight: 600; font-size: 0.875rem; text-decoration: none; transition: background 150ms; }
  .btn-cta:hover { background: var(--coral-dark); text-decoration: none; }
  .btn-cta--ghost { background: var(--tag-bg); color: var(--text-60); }
  .btn-cta--ghost:hover { background: var(--coral-light); color: var(--coral); }

  .temporal-nav { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); max-width: 720px; }
  .temporal-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); margin-bottom: 0.65rem; }
  .temporal-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .temporal-links a { display: inline-flex; align-items: center; height: 36px; padding: 0 0.85rem; background: var(--tag-bg); color: var(--text-60); border-radius: 20px; font-size: 0.82rem; font-weight: 500; text-decoration: none; transition: background 150ms, color 150ms; }
  .temporal-links a:hover { background: var(--coral-light); color: var(--coral); }

  @media (max-width: 600px) {
    .day-tab { font-size: 0.8rem; padding: 0 0.75rem; }
    .tab-date { display: none; }
  }
</style>
