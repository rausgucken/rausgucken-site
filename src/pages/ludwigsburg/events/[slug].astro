---
import Base from "../../../layouts/Base.astro";
import eventsData from "../../../../public/data/ludwigsburg/events-current.json";

export async function getStaticPaths() {
  return eventsData.map(ev => ({
    params: { slug: ev.slug },
    props:  { event: ev },
  }));
}

const { event: ev } = Astro.props;

function formatDate(iso) {
  if (!iso) return "Dauerhaft verfügbar";
  const d = new Date(iso + "T12:00:00");
  return d.toLocaleDateString("de-DE", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
}

const TAG_LABELS = {
  Ausstellung: "Ausstellung", Entertainment: "Entertainment", Familie: "Familie",
  Fest: "Fest", Fuehrung: "Führung", Jugend: "Jugend", Kinder: "Kinder",
  Kulinarik: "Kulinarik", Lesung: "Lesung", Messe: "Messe", Musik: "Musik",
  Outdoor: "Outdoor", Sport: "Sport", Sprache: "Sprache", Tanz: "Tanz",
  Theater: "Theater", Vortrag: "Vortrag", Workshop: "Workshop",
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": ev.title,
  "description": ev.description || undefined,
  "startDate": ev.date_start || undefined,
  "location": {
    "@type": "Place",
    "name": ev.location || "Ludwigsburg",
    "address": { "@type": "PostalAddress", "addressLocality": "Ludwigsburg", "addressCountry": "DE" }
  },
  "url": `https://rausgucken.de/ludwigsburg/events/${ev.slug}`,
};
---

<Base
  title={`${ev.title} | Ludwigsburg | rausgucken.de`}
  description={ev.description ? ev.description.slice(0, 155) : `${ev.title} — Veranstaltung in Ludwigsburg`}
  city="ludwigsburg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb">
    <a href="/">rausgucken.de</a> ›
    <a href="/ludwigsburg">Ludwigsburg</a> ›
    <span>{ev.title}</span>
  </nav>

  <article class="event-detail">
    <header>
      <div class="event-tags">
        {ev.tags.map(t => <span class="tag">{TAG_LABELS[t] ?? t}</span>)}
        {ev.age_min != null && (
          <span class="tag tag--age">
            ab {ev.age_min} J.{ev.age_max ? ` bis ${ev.age_max} J.` : "+"}
          </span>
        )}
      </div>
      <h1>{ev.title}</h1>
    </header>

    <div class="meta-grid">
      <div class="meta-item">
        <span class="meta-label">Datum</span>
        <span class="meta-value">{formatDate(ev.date_start)}</span>
      </div>
      {ev.time && (
        <div class="meta-item">
          <span class="meta-label">Uhrzeit</span>
          <span class="meta-value">{ev.time} Uhr</span>
        </div>
      )}
      {ev.location && (
        <div class="meta-item">
          <span class="meta-label">Ort</span>
          <span class="meta-value">{ev.location}</span>
        </div>
      )}
      {ev.price && (
        <div class="meta-item">
          <span class="meta-label">Preis</span>
          <span class="meta-value">{ev.price}</span>
        </div>
      )}
    </div>

    {ev.description && (
      <div class="event-description">
        <h2>Beschreibung</h2>
        <p>{ev.description}</p>
      </div>
    )}

    <div class="source-box">
      <p class="disclaimer-text">
        Diese Information wurde automatisch von der Originalseite gesammelt (Stand: {new Date(ev.scraped_at).toLocaleDateString("de-DE")}).
        Bitte prüfen Sie alle Angaben vor der Teilnahme.
      </p>
      <a href={ev.original_url} target="_blank" rel="noopener noreferrer" class="btn-original">
        Zur Originalseite →
      </a>
    </div>

    <a href="/ludwigsburg" class="back-link">← Zurück zu allen Veranstaltungen</a>
  </article>
</Base>

<style>
  .breadcrumb { font-size: 0.82rem; color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-text-muted); }
  .event-detail { max-width: 720px; }
  .event-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.75rem; }
  .tag { background: var(--color-tag-bg); color: var(--color-text-muted); font-size: 0.75rem; padding: 2px 10px; border-radius: 20px; }
  .tag--age { background: var(--color-accent-light); color: var(--color-accent); }
  h1 { font-size: clamp(1.4rem, 4vw, 2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 1.5rem; }
  .meta-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 2rem; }
  .meta-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .meta-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
  .meta-value { font-size: 0.95rem; color: var(--color-text); }
  .event-description h2 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.65rem; }
  .event-description p { line-height: 1.7; color: var(--color-text-muted); }
  .source-box { margin-top: 2rem; background: var(--color-accent-light); border: 1px solid #f0cdb8; border-radius: var(--radius); padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .disclaimer-text { font-size: 0.82rem; color: #7a3b18; line-height: 1.5; flex: 1; }
  .btn-original { display: inline-block; background: var(--color-accent); color: #fff; padding: 0.55rem 1.25rem; border-radius: 6px; font-size: 0.9rem; font-weight: 600; white-space: nowrap; text-decoration: none; }
  .btn-original:hover { background: #a8421a; }
  .back-link { display: inline-block; margin-top: 2rem; font-size: 0.88rem; color: var(--color-text-muted); }
</style>
