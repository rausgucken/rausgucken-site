---
import Base from "../../../layouts/Base.astro";
import EventCard from "../../../components/EventCard.astro";
import { readFileSync } from "fs";
import { resolve } from "path";

const cityIds = ["ludwigsburg", "tamm", "bietigheim"];
const cityNames: Record<string, string> = {
  ludwigsburg: "Ludwigsburg",
  tamm: "Tamm",
  bietigheim: "Bietigheim-Bissingen",
};

type AnyEvent = Record<string, any>;
const allTagged: AnyEvent[] = [];

for (const city of cityIds) {
  try {
    const raw = readFileSync(resolve(`public/data/${city}/events-current.json`), "utf-8");
    const parsed: AnyEvent[] = JSON.parse(raw);
    const arr = Array.isArray(parsed) ? parsed : ((parsed as any).events ?? []);
    for (const ev of arr) {
      allTagged.push({ ...ev, _city: city, _cityName: cityNames[city] });
    }
  } catch (e) {
    // skip
  }
}

allTagged.sort((a, b) => {
  if (!a.date_start && !b.date_start) return 0;
  if (!a.date_start) return 1;
  if (!b.date_start) return -1;
  return a.date_start.localeCompare(b.date_start);
});

const cityNamesJson = JSON.stringify(cityNames);
---

<Base
  title="Events im Umkreis — rausgucken.de"
  description="Alle Events in deinem Umkreis im Landkreis Ludwigsburg"
>
  <div class="page-wrap">
    <a href="/" class="back-link">&#8592; Zurück zur Karte</a>
    <h1 id="page-title">Events im Umkreis</h1>
    <p id="page-sub" class="sub">Lade Events&#8230;</p>
    <div id="city-filters" class="city-filters"></div>
    <div id="events-container">
      {allTagged.map(ev => (
        <div class="event-wrap" data-city={ev._city} data-date={ev.date_start ?? ""}>
          <div class="city-tag">{ev._cityName}</div>
          <EventCard event={ev} />
        </div>
      ))}
    </div>
    <div id="empty-state" class="empty" hidden>Keine Events für diese Auswahl.</div>
  </div>
</Base>

<style>
  .page-wrap { max-width: 760px; margin: 0 auto; padding: 2rem 1rem 4rem; }
  .back-link { font-size: 0.85rem; color: var(--coral); text-decoration: none; display: inline-block; margin-bottom: 1rem; }
  h1 { font-family: var(--font-heading); font-weight: 800; font-size: 2rem; margin: 0 0 0.3rem; }
  .sub { color: var(--text-60); font-size: 0.9rem; margin: 0 0 1.25rem; }
  .city-filters { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .city-chip {
    border: none; border-radius: 20px;
    padding: 0.3rem 0.85rem; font-size: 0.8rem; font-weight: 600;
    cursor: pointer; background: var(--surface-secondary, #444857); color: var(--text-60);
    transition: all 120ms;
  }
  .city-chip.active { background: var(--coral); color: #373F51; }
  .event-wrap { margin-bottom: 0.25rem; }
  .city-tag {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--coral); padding: 0.15rem 0; margin-bottom: 0.15rem;
  }
  .empty { text-align: center; color: var(--text-60); padding: 3rem 0; }
</style>

<script type="module" define:vars={{ cityNamesJson }}>
const CITY_NAMES = JSON.parse(cityNamesJson);

const params = new URLSearchParams(window.location.search);
const cityParam = params.get("cities");
const activeCities = new Set(cityParam ? cityParam.split(",").filter(Boolean) : Object.keys(CITY_NAMES));

const today = new Date().toISOString().slice(0, 10);

function render() {
  const wraps = document.querySelectorAll(".event-wrap");
  let visible = 0;
  wraps.forEach(wrap => {
    const city = wrap.dataset.city;
    const date = wrap.dataset.date;
    const show = activeCities.has(city) && (!date || date >= today);
    wrap.hidden = !show;
    if (show) visible++;
  });
  document.getElementById("empty-state").hidden = visible > 0;
  const names = [...activeCities].map(c => CITY_NAMES[c] || c).join(", ");
  document.getElementById("page-sub").textContent = visible + " Events in: " + names;
  document.querySelectorAll(".city-chip").forEach(chip => {
    chip.classList.toggle("active", activeCities.has(chip.dataset.city));
  });
}

const filtersEl = document.getElementById("city-filters");
const allCities = Object.keys(CITY_NAMES);
filtersEl.innerHTML = allCities.map(city =>
  '<button class="city-chip' + (activeCities.has(city) ? ' active' : '') + '" data-city="' + city + '">' + (CITY_NAMES[city] || city) + '</button>'
).join("");

filtersEl.addEventListener("click", e => {
  const chip = e.target.closest(".city-chip");
  if (!chip) return;
  const city = chip.dataset.city;
  if (activeCities.has(city)) {
    if (activeCities.size > 1) activeCities.delete(city);
  } else {
    activeCities.add(city);
  }
  render();
});

render();
</script>
