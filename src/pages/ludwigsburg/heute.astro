---
import Base from "../../layouts/Base.astro";
import EventCard from "../../components/EventCard.astro";
import FilterBar from "../../components/FilterBar.astro";

import todayData from "../../../public/data/ludwigsburg/today.json";
import metaData from "../../../public/data/ludwigsburg/meta.json";

const events = todayData;
const meta = metaData;

const today = new Date();
const todayFormatted = today.toLocaleDateString("de-DE", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
const todayIso = today.toISOString().slice(0, 10);
---

<Base
  title={`Veranstaltungen in Ludwigsburg heute (${todayFormatted}) | rausgucken.de`}
  description={`${events.length} Veranstaltungen in Ludwigsburg heute – ${todayFormatted}. Kinder, Kultur, kostenlos.`}
  city="ludwigsburg"
>
  <div class="page-header">
    <p class="breadcrumb"><a href="/ludwigsburg">Ludwigsburg</a> › Heute</p>
    <h1>Heute in Ludwigsburg</h1>
    <p class="page-subtitle">{todayFormatted} · {events.length} Veranstaltungen</p>
  </div>

  <aside class="disclaimer-box">
    {meta.disclaimer_note || "Alle Angaben ohne Gewähr. Bitte prüfen Sie Infos auf der jeweiligen Originalseite."}
    <a href="/about">Mehr Informationen</a>
  </aside>

  {events.length > 0 ? (
    <div class="event-list">
      {events.map(ev => <EventCard event={ev} />)}
    </div>
  ) : (
    <div class="empty-state empty-state--visible">
      <div class="empty-state-inner">
        <p class="empty-headline">Heute keine Veranstaltungen gefunden.</p>
        <p class="empty-body">Schau morgen wieder vorbei oder entdecke alle kommenden Events.</p>
        <div class="empty-ctas">
          <a href="/ludwigsburg/morgen" class="empty-cta">Morgen →</a>
          <a href="/ludwigsburg/dieses-wochenende" class="empty-cta">Wochenende →</a>
          <a href="/ludwigsburg" class="empty-cta">Alle Events →</a>
        </div>
      </div>
    </div>
  )}
</Base>

<style>
  .page-header { margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .breadcrumb { font-size: 0.82rem; color: var(--text-60); margin-bottom: 0.4rem; }
  .breadcrumb a { color: var(--text-60); text-decoration: underline; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; }
  .disclaimer-box {
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.85rem 1.25rem; font-size: 0.85rem; color: var(--text);
    opacity: 0.70; margin-bottom: 1.5rem; line-height: 1.5;
    max-width: 720px; margin-left: auto; margin-right: auto;
  }
  .disclaimer-box a { color: var(--text); font-weight: 600; margin-left: 0.35rem; }
  .event-list { display: flex; flex-direction: column; gap: 0.75rem; max-width: 720px; margin: 0 auto; }
  .empty-state { display: none; max-width: 720px; padding: 3rem 1.5rem; text-align: center; }
  .empty-state--visible { display: block; }
  .empty-state-inner { background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem 2rem; }
  .empty-headline { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; }
  .empty-body { font-size: 0.95rem; color: var(--text-60); margin-bottom: 1.5rem; }
  .empty-ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
  .empty-cta { display: inline-flex; align-items: center; background: var(--coral); color: var(--text); font-size: 0.875rem; font-weight: 600; padding: 0.6rem 1.25rem; border-radius: var(--radius-sm); text-decoration: none; min-height: 44px; }
  .empty-cta:hover { background: var(--coral-dark); }
</style>
