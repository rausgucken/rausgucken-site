---
import Base from "../../../layouts/Base.astro";
import EventCard from "../../../components/EventCard.astro";
import FilterBar from "../../../components/FilterBar.astro";
import ImportantLinksSidebar from "../../../components/ImportantLinksSidebar.astro";
import eventsData from "../../../../public/data/ludwigsburg/events-current.json";
import metaData from "../../../../public/data/ludwigsburg/meta.json";

const meta = metaData;
const allEvents = (eventsData as any[]).filter((e: any) => e.source === "museum");
const dated    = allEvents.filter((e: any) => e.date_start);
const standing = allEvents.filter((e: any) => !e.date_start);

const scrapedDate = meta.scraped_at
  ? new Date(meta.scraped_at).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })
  : "\u2013";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Stadtmuseum Ludwigsburg \u2013 Aktuelle Ausstellungen & Veranstaltungen",
  "description": `${allEvents.length} aktuelle Veranstaltungen im Stadtmuseum im MIK Ludwigsburg.`,
  "url": "https://www.rausgucken.de/ludwigsburg/stadtmuseum/",
  "inLanguage": "de-DE",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": "https://www.rausgucken.de/" },
      { "@type": "ListItem", "position": 2, "name": "Ludwigsburg", "item": "https://www.rausgucken.de/ludwigsburg/" },
      { "@type": "ListItem", "position": 3, "name": "Stadtmuseum", "item": "https://www.rausgucken.de/ludwigsburg/stadtmuseum/" }
    ]
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Stadtmuseum im MIK",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Arsenalstra\u00dfe 12",
    "addressLocality": "Ludwigsburg",
    "postalCode": "71638",
    "addressCountry": "DE"
  },
  "url": "https://stadtmuseum.ludwigsburg.de",
  "sameAs": [
    "https://de.wikipedia.org/wiki/Stadtmuseum_Ludwigsburg"
  ]
};
---

<Base
  title={`Stadtmuseum Ludwigsburg \u2013 ${allEvents.length} aktuelle Ausstellungen & Events | rausgucken.de`}
  description={`${allEvents.length} aktuelle Veranstaltungen im Stadtmuseum im MIK Ludwigsburg. Stadtgeschichte, Sonderausstellungen und kulturelle Angebote f\u00fcr alle \u2013 lokal und aktuell.`}
  city="ludwigsburg"
  canonical="https://www.rausgucken.de/ludwigsburg/stadtmuseum/"
  ogImage="/og/ludwigsburg/ausstellungen.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(placeSchema)} />

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">rausgucken.de</a></li>
      <li aria-hidden="true">&#8250;</li>
      <li><a href="/ludwigsburg/">Ludwigsburg</a></li>
      <li aria-hidden="true">&#8250;</li>
      <li aria-current="page">Stadtmuseum</li>
    </ol>
  </nav>

  <div class="page-header">
    <div class="page-header-eyebrow">
      <span class="dot-dual" aria-hidden="true">&#9679; &#183;</span>
      Veranstaltungsort
    </div>
    <h1>Stadtmuseum Ludwigsburg</h1>
    <p class="page-subtitle">
      {allEvents.length} aktuelle Veranstaltungen &middot; Stand: {scrapedDate}
    </p>
  </div>

  <section class="venue-intro" aria-label="Ueber das Stadtmuseum">
    <p>
      Das Stadtmuseum im MIK (Museum, Information, Kultur) erz&auml;hlt die Geschichte
      Ludwigsburgs &ndash; von der Stadtgr&uuml;ndung im 18. Jahrhundert bis in die Gegenwart.
      Neben der Dauerausstellung zur Stadtgeschichte zeigt das Haus regelm&auml;&szlig;ig
      Sonderausstellungen zu lokalen und regionalen Themen sowie ein begleitendes
      Veranstaltungsprogramm mit F&uuml;hrungen, Vortr&auml;gen und Familienangeboten.
    </p>
    <p class="venue-meta">
      <a href="https://stadtmuseum.ludwigsburg.de" target="_blank" rel="noopener noreferrer">stadtmuseum.ludwigsburg.de &#8599;</a>
      &middot; Arsenalstra&szlig;e 12, 71638 Ludwigsburg
    </p>
  </section>

  <aside class="disclaimer-box">
    <strong>Hinweis:</strong> {meta.disclaimer_note || "Alle Angaben ohne Gew&auml;hr. Bitte pr&uuml;fen Sie Infos auf der jeweiligen Originalseite."}
    <a href="/about">Mehr Informationen</a>
  </aside>

  <FilterBar />

  <div class="city-layout">
    <div class="city-main">
      <div class="empty-state" id="empty-state" aria-live="polite" hidden>
        <div class="empty-state-inner">
          <p class="empty-headline">Keine Treffer f&uuml;r diese Filter.</p>
          <p class="empty-body">Vielleicht ist heute ein guter Tag, einfach rauszugehen!</p>
          <div class="empty-ctas">
            <a href="/ludwigsburg/heute/" class="empty-cta">Alle heutigen Events &rarr;</a>
            <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen &rarr;</a>
          </div>
          <button class="empty-reset" id="empty-reset-btn" type="button">Filter zur&uuml;cksetzen</button>
        </div>
      </div>

      {dated.length > 0 && (
        <section id="section-dated">
          <div id="event-grid" class="event-list">
            {dated.map((ev: any) => <EventCard event={ev} />)}
          </div>
        </section>
      )}

      {standing.length > 0 && (
        <section id="section-standing">
          <h2 class="section-heading">Dauerausstellungen &amp; laufende Angebote</h2>
          <div class="event-list">
            {standing.map((ev: any) => <EventCard event={ev} />)}
          </div>
        </section>
      )}

      {allEvents.length === 0 && (
        <div class="empty-state-static">
          <p>Aktuell keine Veranstaltungen aus dem Stadtmuseum gefunden.</p>
          <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen in Ludwigsburg &rarr;</a>
        </div>
      )}

      <nav class="related-pages" aria-label="Weitere Seiten">
        <h2 class="related-heading">Weitere Veranstaltungsorte</h2>
        <ul class="related-links">
          <li><a href="/ludwigsburg/karlskaserne/">Karlskaserne Ludwigsburg</a></li>
          <li><a href="/ludwigsburg/stadtbibliothek/">Stadtbibliothek Ludwigsburg</a></li>
          <li><a href="/ludwigsburg/residenzschloss/">Residenzschloss Ludwigsburg</a></li>
          <li><a href="/ludwigsburg/labyrinth/">Kunstschule Labyrinth</a></li>
          <li><a href="/ludwigsburg/kinder/">Kinderveranstaltungen Ludwigsburg</a></li>
          <li><a href="/ludwigsburg/kostenlos/">Kostenlose Events Ludwigsburg</a></li>
          <li><a href="/ludwigsburg/">Alle Veranstaltungen Ludwigsburg &rarr;</a></li>
        </ul>
      </nav>
    </div>
    <div class="city-sidebar">
      <ImportantLinksSidebar />
    </div>
  </div>

  <script src="/scripts/app.js" is:inline></script>
</Base>

<style>
  .breadcrumbs ol { display: flex; flex-wrap: wrap; gap: 0.25rem 0.5rem; list-style: none; margin: 0 0 1.5rem; padding: 0; font-size: 0.85rem; opacity: 0.7; }
  .breadcrumbs a { text-decoration: underline; text-underline-offset: 2px; }
  .page-header { margin-bottom: 1.5rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .page-header h1 { margin: 0.25rem 0 0.5rem; }
  .page-subtitle { margin: 0; opacity: 0.7; font-size: 0.95rem; }
  .page-header-eyebrow { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.7; margin-bottom: 0.5rem; }
  .dot-dual { color: var(--brand-coral, #FF6F61); font-size: 0.75rem; letter-spacing: 0.15em; }
  .venue-intro { max-width: 720px; margin: 0 auto 1.5rem; padding: 1.25rem 1.5rem; background: var(--surface-card); border: 1px solid var(--border); border-left: 4px solid var(--coral); border-radius: var(--radius); font-size: 0.92rem; line-height: 1.65; }
  .venue-intro p { margin: 0 0 0.75rem; }
  .venue-intro p:last-child { margin-bottom: 0; }
  .venue-meta { font-size: 0.82rem; opacity: 0.7; }
  .venue-meta a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
  .venue-meta a:hover { color: var(--coral); }
  .disclaimer-box { border: 1px solid var(--border); border-radius: var(--radius); padding: 0.85rem 1.25rem; font-size: 0.85rem; color: var(--text); opacity: 0.70; margin-bottom: 1.5rem; line-height: 1.5; max-width: 720px; margin-left: auto; margin-right: auto; }
  .disclaimer-box a { color: var(--text); font-weight: 600; margin-left: 0.35rem; }
  .related-pages { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(0,0,0,0.08); }
  :global(.dark) .related-pages { border-top-color: rgba(255,255,255,0.06); }
  .related-heading { font-size: 0.9rem; font-weight: 600; opacity: 0.6; margin-bottom: 0.75rem; }
  .related-links { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; padding: 0; margin: 0; }
  .related-links a { font-size: 0.875rem; padding: 0.35rem 0.75rem; border-radius: 999px; border: 1px solid currentColor; opacity: 0.65; text-decoration: none; transition: opacity 150ms; }
  .related-links a:hover { opacity: 1; }
  .section-heading { font-size: 1.1rem; font-weight: 600; margin: 2.5rem 0 1rem; opacity: 0.8; }
  .empty-state-static { text-align: center; padding: 3rem 1rem; opacity: 0.7; }
  .empty-state { display: none; padding: 3rem 1.5rem; text-align: center; }
  .empty-state:not([hidden]) { display: block; }
  .empty-state-inner { background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem 2rem; box-shadow: var(--shadow-card); }
  .empty-headline { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .empty-body { font-size: 0.95rem; color: var(--text-60); margin-bottom: 1.5rem; }
  .empty-ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-bottom: 1.25rem; }
  .empty-cta { background: var(--coral); color: var(--text); font-size: 0.875rem; font-weight: 600; padding: 0.6rem 1.25rem; border-radius: var(--radius-sm); text-decoration: none; transition: background 150ms; min-height: 44px; display: inline-flex; align-items: center; }
  .empty-cta:hover { background: var(--coral-dark); }
  .empty-reset { background: transparent; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 0.5rem 1.25rem; font-size: 0.85rem; font-weight: 600; color: var(--text-60); cursor: pointer; min-height: 44px; transition: border-color 150ms, color 150ms; }
  .empty-reset:hover { border-color: var(--coral); color: var(--coral); }
  .city-layout { display: block; }
  .city-main { display: block; }
  @media (min-width: 961px) {
    .city-sidebar { display: block; position: fixed; top: 160px; left: calc(50% + 384px); width: 200px; }
    .city-sidebar :global(.important-links-sidebar) { display: block; }
  }
  @media (max-width: 960px) { .city-sidebar { display: none; } }
</style>
