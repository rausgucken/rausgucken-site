---
import Base from "../../../layouts/Base.astro";
import FreshnessStamp from '../../../components/FreshnessStamp.astro';
import EventCard from "../../../components/EventCard.astro";
import FilterBar from "../../../components/FilterBar.astro";
import QRModal from "../../../components/QRModal.astro";
import ICSButton from "../../../components/ICSButton.astro";
import DaySelector from "../../../components/DaySelector.astro";

import subsetData from "../../../../public/data/landkreis-ludwigsburg/next-week.json";
import metaData from "../../../../public/data/ludwigsburg/meta.json";

const events = subsetData.events ?? [];
const meta = metaData;

const siteUrl = "https://www.rausgucken.de";
const city    = "ludwigsburg";

// Next Monday–Sunday — computed at build time
const now       = new Date();
const dayOfWeek = now.getDay(); // 0=Sun,1=Mon,...,6=Sat
const daysToMon = dayOfWeek === 0 ? 1 : (8 - dayOfWeek);
const mon       = new Date(now); mon.setDate(now.getDate() + daysToMon);
const sun       = new Date(mon); sun.setDate(mon.getDate() + 6);

const fmtShort = (d: Date) => d.toLocaleDateString("de-DE", { day: "numeric", month: "long" });
const fmtFull  = (d: Date) => d.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" });

const rangeDE   = `${fmtShort(mon)} – ${fmtFull(sun)}`;
const pageLabel = "Nächste Woche in Ludwigsburg";
const canonical = `${siteUrl}/${city}/naechste-woche/`;
const seoTitle  = `Events Ludwigsburg nächste Woche, ${rangeDE} | rausgucken.de`;
const metaDesc  = `Veranstaltungen in Ludwigsburg nächste Woche (${rangeDE}): Kultur, Kinder, Ausstellungen, Führungen – jetzt vorplanen.`;

// Helper: ISO date string → JS getDay() value (0=So,1=Mo,...,6=Sa)
function isoToDow(iso: string): number {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).getDay();
}

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Events Ludwigsburg nächste Woche – ${rangeDE}`,
  "description": metaDesc,
  "url": canonical,
  "inLanguage": "de-DE",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Ludwigsburg",   "item": `${siteUrl}/${city}/` },
    { "@type": "ListItem", "position": 3, "name": "Nächste Woche", "item": canonical },
  ],
};

// DaySelector tabs — "Alle" + one per weekday
// data-day stores the JS getDay() value as a string; "all" = show everything
// DaySelector emits dayselector:change with detail.date = this value
const days = [
  { label: "Alle", date: "all" },
  { label: "Mo",   date: "1"   },
  { label: "Di",   date: "2"   },
  { label: "Mi",   date: "3"   },
  { label: "Do",   date: "4"   },
  { label: "Fr",   date: "5"   },
  { label: "Sa",   date: "6"   },
  { label: "So",   date: "0"   },
];
---

<Base
  title={seoTitle}
  description={metaDesc}
  canonical={canonical}
  ogImage="/og/ludwigsburg/naechste-woche.jpg"
  schema={[collectionSchema, breadcrumbSchema]}
>
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/ludwigsburg">Ludwigsburg</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">Nächste Woche</span>
  </nav>

  <div class="page-header">
    <h1>Events Ludwigsburg nächste Woche</h1>
    <p class="page-subtitle">
      {events.length > 0 ? `${events.length} Veranstaltungen · ` : ""}{rangeDE}
      <FreshnessStamp scrapedAt={meta.scraped_at} />
    </p>
  </div>

  <!-- DaySelector component — fires "dayselector:change" on window with detail.date = dow string -->
  <DaySelector days={days} activeDay="all" />


  <div class="collection-actions">
    <QRModal url={canonical} label={pageLabel} />
    <ICSButton events={events} label={pageLabel} />
  </div>

  <FilterBar />

  <div class="empty-state" id="empty-state" aria-live="polite" hidden></div>

  {events.length > 0 ? (
    <div class="event-list" id="event-grid">
      {events.map(ev => (
        <div
          class="event-day-wrapper"
          data-dow={ev.date_start ? String(isoToDow(ev.date_start)) : "all"}
        >
          <EventCard event={ev} />
        </div>
      ))}
    </div>
  ) : (
    <div class="empty-today">
      <div class="empty-inner">
        <p class="empty-headline">Nächste Woche noch keine Einträge.</p>
        <p class="empty-body">Schau dieses Wochenende vorbei oder entdecke alle aktuellen Veranstaltungen.</p>
        <div class="empty-ctas">
          <a href="/ludwigsburg/dieses-wochenende" class="btn-cta">Dieses Wochenende →</a>
          <a href="/ludwigsburg" class="btn-cta btn-cta--ghost">Alle Veranstaltungen</a>
        </div>
      </div>
    </div>
  )}

  <nav class="temporal-nav" aria-label="Andere Zeiträume in Ludwigsburg">
    <p class="temporal-label">Andere Zeiträume</p>
    <div class="temporal-links">
      <a href="/ludwigsburg/heute">Heute</a>
      <a href="/ludwigsburg/morgen">Morgen</a>
      <a href="/ludwigsburg/dieses-wochenende">Dieses Wochenende</a>
      <a href="/ludwigsburg/kinder">Kinder &amp; Familie</a>
      <a href="/ludwigsburg">Alle Veranstaltungen</a>
    </div>
  </nav>

  <script src="/scripts/app.js" is:inline></script>
</Base>

<!-- Listen for DaySelector's custom event — filter .event-day-wrapper by data-dow -->
<script is:inline>
(function () {
  function applyDowFilter(dowFilter) {
    var wrappers = document.querySelectorAll('.event-day-wrapper');
    var visible  = 0;
    wrappers.forEach(function (w) {
      var show = dowFilter === 'all' || w.dataset.dow === dowFilter;
      w.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    var emptyEl = document.getElementById('empty-state');
    if (emptyEl) emptyEl.hidden = visible > 0;
  }

  // DaySelector fires this custom event on window
  window.addEventListener('dayselector:change', function (e) {
    applyDowFilter(e.detail.date);
  });

  // Default on load — show all
  applyDowFilter('all');
})();
</script>

<style>

  .collection-actions {
    max-width: 720px;
    margin: 0 auto 1rem auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 36px;
    padding: 0 0.85rem;
    background: var(--tag-bg);
    color: var(--text-60);
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms, color 150ms;
    font-family: inherit;
    white-space: nowrap;
  }
  .action-btn:hover {
    background: var(--coral-light);
    color: var(--coral);
  }

  .page-header { margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }

  /* DaySelector wrapper spacing */
  :global(.day-selector) { max-width: 720px; margin: 0 auto 1rem; }

  html.dark .event-card { box-shadow: 0 2px 8px rgba(0,0,0,0.22); }

  .empty-today { max-width: 720px; padding: 2rem 0; }
  .empty-inner { background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem 2rem; text-align: center; }
  .empty-headline { font-family: var(--font-heading); font-weight: 700; font-size: 1.1rem; margin-bottom: 0.5rem; }
  .empty-body { color: var(--text-60); margin-bottom: 1.5rem; }
  .empty-ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn-cta { display: inline-flex; align-items: center; height: 44px; padding: 0 1.25rem; background: var(--coral); color: var(--text); border-radius: var(--radius-sm); font-weight: 600; font-size: 0.875rem; text-decoration: none; transition: background 150ms; }
  .btn-cta:hover { background: var(--coral-dark); text-decoration: none; }
  .btn-cta--ghost { background: var(--tag-bg); color: var(--text-60); }
  .btn-cta--ghost:hover { background: var(--coral-light); color: var(--coral); }

  .temporal-nav { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); max-width: 720px; }
  .temporal-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); margin-bottom: 0.65rem; }
  .temporal-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .temporal-links a { display: inline-flex; align-items: center; height: 36px; padding: 0 0.85rem; background: var(--tag-bg); color: var(--text-60); border-radius: 20px; font-size: 0.82rem; font-weight: 500; text-decoration: none; transition: background 150ms, color 150ms; }
  .temporal-links a:hover { background: var(--coral-light); color: var(--coral); }
</style>