---
import Base from "../../layouts/Base.astro";
import FreshnessStamp from '../../components/FreshnessStamp.astro';
import EventCard from "../../components/EventCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import ImportantLinksSidebar from "../../components/ImportantLinksSidebar.astro";
import FeaturedEvent from "../../components/FeaturedEvent.astro";

import eventsData from "../../../public/data/ludwigsburg/events-current.json";
import metaData from "../../../public/data/ludwigsburg/meta.json";

const events = eventsData;
const meta = metaData;

const dated    = events.filter(e => e.date_start);
const standing = events.filter(e => !e.date_start);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Veranstaltungen in Ludwigsburg",
  "url": "https://rausgucken.de/ludwigsburg/",
  "numberOfItems": events.length,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": "https://rausgucken.de" },
    { "@type": "ListItem", "position": 2, "name": "Ludwigsburg", "item": "https://rausgucken.de/ludwigsburg/" },
  ],
};

// Load featured event for "Unser Tipp der Woche"
import tipsRaw from '../../../editorial-tips.json';
const featuredSlug = Object.entries(tipsRaw).find(
  ([, v]) => typeof v === 'object' && v.featured === true
)?.[0] ?? null;
const featuredEvent = featuredSlug
  ? { ...events.find(e => e.slug === featuredSlug), editorial_tip: tipsRaw[featuredSlug]?.tip }
  : null;

---

<Base
  title="Veranstaltungen Ludwigsburg 2026 – Alle Events & Ausstellungen | rausgucken.de"
  description={`${events.length} aktuelle Veranstaltungen in Ludwigsburg. Ausstellungen, Kinder-Events, kostenlose Angebote und mehr — täglich aktuell, übersichtlich auf einen Blick.`}
  city="ludwigsburg"
  schema={[jsonLd, breadcrumbSchema]}
>
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="https://rausgucken.de">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">Ludwigsburg</span>
  </nav>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-header">
    <h1>Veranstaltungen in Ludwigsburg</h1>
    <p class="page-subtitle">
      <FreshnessStamp scrapedAt={meta.scraped_at} />
    </p>
  </div>

  {meta.sources_failed && meta.sources_failed.length > 0 && (
    <div class="sources-warning" role="alert">
      <strong>⚠ Hinweis:</strong> {meta.sources_failed.length} {meta.sources_failed.length === 1 ? "Quelle" : "Quellen"} derzeit nicht erreichbar — Angaben können unvollständig sein.
    </div>
  )}

  <aside class="disclaimer-box">
    <strong>Hinweis:</strong> {meta.disclaimer_note || "Alle Angaben ohne Gewähr. Bitte prüfen Sie Infos auf der jeweiligen Originalseite."}
    <a href="/about">Mehr Informationen</a>
  </aside>


  <!-- Editorial intro — collapsed by default. Named entities for E-E-A-T/SEO.
       Googlebot reads <details> content even when closed. -->
  <details class="editorial-intro" id="editorial-intro">
    <summary class="editorial-intro__toggle">
      Über Ludwigsburg — Kulturorte &amp; Freizeittipps
    </summary>
    <div class="editorial-intro__body">
      <p>
        Ludwigsburg vereint auf engem Raum einige der kulturell interessantesten Orte
        Baden-Württembergs. Das <strong>Residenzschloss</strong> und der angrenzende Park
        <strong>Blühender Barock</strong> zählen zu den meistbesuchten Ausflugszielen der Region —
        mit Führungen, Familienformaten und dem Märchengarten das ganze Jahr über.
        Das <strong>Forum am Schlosspark</strong> direkt nebenan ist die Heimspielstätte des
        Württembergischen Kammerorchesters und Bühne für Konzerte, Lesungen und Gastspiele.
      </p>
      <p>
        Das <strong>Kunstzentrum Karlskaserne</strong> beherbergt wechselnde Ausstellungen,
        offene Ateliers und regelmäßige Veranstaltungsabende — darunter die
        <strong>Kunstschule Labyrinth</strong> mit Kinder- und Jugend-Workshops in Bildender
        Kunst, Theater und Zirkus. Der <strong>Kunstverein Ludwigsburg</strong> zeigt
        zeitgenössische Kunst mit regionalem Bezug; Vernissagen sind meist kostenlos zugänglich.
        Das <strong>Stadtmuseum im MIK</strong> erzählt die Geschichte der Barockplanstadt
        mit interaktivem Mitmachbereich für Familien.
      </p>
      <p>
        Die <strong>Stadtbibliothek Ludwigsburg</strong> bietet weit mehr als Ausleihe:
        Lesestunden, Sprachtreffs, digitale Workshops und Vortragsreihen — viele davon kostenlos.
        Für Konzerte, Comedy und Sport ist die <strong>MHP Arena</strong> das größte
        Live-Entertainment-Venue der Stadt, Heimspielstätte der MHP Riesen Ludwigsburg.
      </p>
      <p class="editorial-intro__erleben-link">
        <a href="/ludwigsburg/erleben/">Alle Kulturorte im Überblick →</a>
      </p>
    </div>
  </details>

  <FilterBar />

  <!-- Two-column layout: event list left (720px), sidebar right (260px) -->
  <!-- Sidebar is display:none on mobile via CSS — footer carries the links instead -->
  <div class="city-layout">

    <!-- Left: event content -->
    <div class="city-main">

      <div class="empty-state" id="empty-state" aria-live="polite" hidden>
        <div class="empty-state-inner">
          <p class="empty-headline">Keine Treffer für diese Filter.</p>
          <p class="empty-body">Vielleicht ist heute ein guter Tag, einfach rauszugehen!</p>
          <div class="empty-ctas">
            <a href="https://www.schloss-ludwigsburg.de" target="_blank" rel="noopener noreferrer" class="empty-cta">
              Residenzschloss entdecken →
            </a>
            <a href="https://www.ludwigsburg.de/de/stadtleben/freizeit-sport/" target="_blank" rel="noopener noreferrer" class="empty-cta">
              Freizeit in Ludwigsburg →
            </a>
          </div>
          <button class="empty-reset" id="empty-reset-btn" type="button">
            Filter zurücksetzen
          </button>
        </div>
      </div>

      {dated.length > 0 && (
        <section id="section-dated">
          <h2 class="section-heading">Kommende Veranstaltungen</h2>
          <div class="event-list" id="event-grid">
            {dated.map(ev => (
              <EventCard event={ev} />
            ))}
          </div>
        </section>
      )}

      {standing.length > 0 && (
        <section id="section-standing" style="margin-top: 3rem;">
          <h2 class="section-heading">Dauerveranstaltungen & Führungen</h2>
          <p class="section-note">Diese Angebote finden regelmäßig statt. Termine auf der Originalseite prüfen.</p>
          <div class="event-list">
            {standing.map(ev => (
              <EventCard event={ev} />
            ))}
          </div>
        </section>
      )}

      {events.length === 0 && (
        <div class="empty-state empty-state--visible">
          <div class="empty-state-inner">
            <p class="empty-headline">Aktuell keine Veranstaltungen verfügbar.</p>
            <p class="empty-body">Schau bald wieder vorbei — oder geh einfach schon mal raus!</p>
            <div class="empty-ctas">
              <a href="https://www.schloss-ludwigsburg.de" target="_blank" rel="noopener noreferrer" class="empty-cta">
                Residenzschloss entdecken →
              </a>
              <a href="https://www.ludwigsburg.de/de/stadtleben/freizeit-sport/" target="_blank" rel="noopener noreferrer" class="empty-cta">
                Freizeit in Ludwigsburg →
              </a>
            </div>
          </div>
        </div>
      )}

    </div><!-- /.city-main -->

    <!-- Right: sidebar — hidden on mobile, sticky on desktop -->
    <div class="city-sidebar">
      <FeaturedEvent event={featuredEvent} />
      <ImportantLinksSidebar />
    </div>

  </div><!-- /.city-layout -->

  <script src="/scripts/app.js" is:inline></script>
</Base>

<style>
  /* ── Page header ─────────────────────────────────────────────────────────── */
  .page-header { margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; }

  /* ── Scraper failure alert ───────────────────────────────────────────────── */
  .sources-warning {
    background: var(--coral-light);
    border: 1px solid rgba(255,111,97,0.30);
    border-radius: var(--radius-sm);
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.85;
    margin-bottom: 0.85rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Disclaimer ─────────────────────────────────────────────────────────── */
  .disclaimer-box {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.85rem 1.25rem;
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.70;
    margin-bottom: 1.5rem;
    line-height: 1.5;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .disclaimer-box a { color: var(--text); font-weight: 600; margin-left: 0.35rem; }

    /* ── Layout ─────────────────────────────────────────────────────────────── */
  /* Cards and filterbar stay exactly as-is: max-width 720px, margin auto.
     Sidebar is position:fixed, vertically centered on right side of viewport,
     appearing just outside the 720px content column. No layout impact. */
  .city-layout { display: block; }
  .city-main   { display: block; }

  @media (min-width: 961px) {
    .city-sidebar {
      display: block;
      position: fixed;
      top: 80px;
      left: calc(50% + 384px);
      width: 210px;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .city-sidebar::-webkit-scrollbar { display: none; }
    .city-sidebar :global(.important-links-sidebar) {
      display: block;
    }
  }

  @media (max-width: 960px) {
    .city-sidebar {
      display: none;
    }
  }

  /* ── Section headings ───────────────────────────────────────────────────── */
  .section-heading {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-note {
    font-size: 0.85rem;
    color: var(--text-60);
    margin-bottom: 1rem;
    margin-top: -0.5rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Event list — inherits global .event-list from Base.astro ───────────── */
  /* max-width:720px and margin:0 auto from Base.astro apply naturally — no override needed */

  /* ── Dark mode card shadow ──────────────────────────────────────────────── */
  html.dark .event-card {
    box-shadow: 0 2px 8px rgba(0,0,0,0.22);
  }



  /* ── Empty state ─────────────────────────────────────────────────────────── */
  .empty-state {
    display: none;
    padding: 3rem 1.5rem;
    text-align: center;
  }
  .empty-state:not([hidden]),
  .empty-state--visible { display: block; }
  .empty-state-inner {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-card);
  }
  .empty-headline {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .empty-body {
    font-size: 0.95rem;
    color: var(--text-60);
    margin-bottom: 1.5rem;
  }
  .empty-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .empty-cta {
    background: var(--coral);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 150ms;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .empty-cta:hover { background: var(--coral-dark); text-decoration: none; }
  .empty-cta:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .empty-reset {
    background: transparent;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-60);
    cursor: pointer;
    min-height: 44px;
    transition: border-color 150ms, color 150ms;
  }
  .empty-reset:hover { border-color: var(--coral); color: var(--coral); }
  .empty-reset:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }

  /* ── Editorial intro (collapsed) ───────────────────────────────────────── */
  .editorial-intro {
    max-width: 720px;
    margin: 0 auto 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-card);
  }
  .editorial-intro__toggle {
    padding: 0.75rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-60);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }
  .editorial-intro__toggle::-webkit-details-marker { display: none; }
  .editorial-intro__toggle::before {
    content: "▸";
    font-size: 0.7rem;
    transition: transform 150ms;
    flex-shrink: 0;
  }
  details.editorial-intro[open] .editorial-intro__toggle::before {
    transform: rotate(90deg);
  }
  .editorial-intro__toggle:hover { color: var(--text); }
  .editorial-intro__toggle:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: -2px;
    border-radius: var(--radius-sm);
  }
  .editorial-intro__body {
    padding: 0 1.1rem 1rem;
    border-top: 1px solid var(--border);
  }
  .editorial-intro__body p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--text);
    opacity: 0.85;
    margin-top: 0.85rem;
    margin-bottom: 0;
  }
  .editorial-intro__body strong { font-weight: 600; opacity: 1; }
  .editorial-intro__erleben-link a {
    color: var(--coral);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .editorial-intro__erleben-link a:hover { text-decoration: underline; }
</style>
