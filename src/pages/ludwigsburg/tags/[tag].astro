---
// src/pages/ludwigsburg/tags/[tag].astro
// Tag landing pages for Ludwigsburg — one static page per approved tag.
// URL: /ludwigsburg/tags/{tag}/  e.g. /ludwigsburg/tags/Kinder/
// Filtered from landkreis events-current.json at build time.

import Base from "../../../layouts/Base.astro";
import EventCard from "../../../components/EventCard.astro";
import FreshnessStamp from "../../../components/FreshnessStamp.astro";
import eventsData from "../../../../public/data/landkreis-ludwigsburg/events-current.json";
import metaData from "../../../../public/data/ludwigsburg/meta.json";

// ── Approved tag vocabulary (must match config/tags.json) ─────────────────────
const TAGS = [
  "Ausstellung", "Entertainment", "Familie", "Fest", "Fuehrung",
  "Jugend", "Kinder", "Kulinarik", "Lesung", "Messe", "Musik",
  "Outdoor", "Sport", "Sprache", "Tanz", "Theater", "Vortrag", "Workshop",
];

// Human-readable display labels (Fuehrung → Führung etc.)
const TAG_LABELS: Record<string, string> = {
  Ausstellung: "Ausstellung",
  Entertainment: "Entertainment",
  Familie: "Familie",
  Fest: "Fest",
  Fuehrung: "Führung",
  Jugend: "Jugend",
  Kinder: "Kinder",
  Kulinarik: "Kulinarik",
  Lesung: "Lesung",
  Messe: "Messe",
  Musik: "Musik",
  Outdoor: "Outdoor",
  Sport: "Sport",
  Sprache: "Sprache",
  Tanz: "Tanz",
  Theater: "Theater",
  Vortrag: "Vortrag",
  Workshop: "Workshop",
};

// ── Static path generation — one path per tag ────────────────────────────────
export function getStaticPaths() {
  return TAGS.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const tagLabel = TAG_LABELS[tag] ?? tag;

const allEvents: any[] = (eventsData as any).events ?? (eventsData as any);
const meta = metaData as any;

// Filter to tag, sort dated first then by date_start
const tagEvents: any[] = allEvents
  .filter((e: any) => Array.isArray(e.tags) && e.tags.includes(tag))
  .sort((a: any, b: any) => {
    if (!a.date_start && !b.date_start) return 0;
    if (!a.date_start) return 1;
    if (!b.date_start) return -1;
    return a.date_start.localeCompare(b.date_start);
  });

const dated    = tagEvents.filter((e: any) => e.date_start);
const standing = tagEvents.filter((e: any) => !e.date_start);

const buildDate = new Date();
const monthDE   = buildDate.toLocaleDateString("de-DE", { month: "long" });
const yearDE    = buildDate.getFullYear();

const siteUrl  = "https://www.rausgucken.de";
const canonical = `${siteUrl}/ludwigsburg/tags/${tag}/`;

// ── Schema.org ────────────────────────────────────────────────────────────────
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${tagLabel} in Ludwigsburg`,
  "description": `${tagEvents.length} aktuelle ${tagLabel}-Veranstaltungen in Ludwigsburg und dem Landkreis Ludwigsburg.`,
  "url": canonical,
  "inLanguage": "de-DE",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de",  "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Ludwigsburg",    "item": `${siteUrl}/ludwigsburg/` },
    { "@type": "ListItem", "position": 3, "name": tagLabel,          "item": canonical },
  ],
};
---

<Base
  title={`${tagLabel} in Ludwigsburg ${monthDE} ${yearDE} | rausgucken.de`}
  description={`${tagEvents.length} aktuelle ${tagLabel}-Veranstaltungen in Ludwigsburg – täglich aktuell von Residenzschloss bis Stadtbibliothek. Jetzt entdecken auf rausgucken.de.`}
  city="ludwigsburg"
  canonical={canonical}
  schema={[jsonLd, breadcrumbSchema]}
>
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/ludwigsburg/">Ludwigsburg</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">{tagLabel}</span>
  </nav>

  <div class="page-header">
    <h1>{tagLabel} in Ludwigsburg</h1>
    <p class="page-subtitle">
      <FreshnessStamp scrapedAt={meta.scraped_at} />
    </p>
  </div>

  {tagEvents.length > 0 ? (
    <div class="tag-page-layout">
      {dated.length > 0 && (
        <section>
          <h2 class="section-heading">Kommende {tagLabel}-Veranstaltungen</h2>
          <div class="event-list">
            {dated.map((ev: any) => <EventCard event={ev} />)}
          </div>
        </section>
      )}

      {standing.length > 0 && (
        <section style="margin-top: 3rem;">
          <h2 class="section-heading">Dauerveranstaltungen</h2>
          <p class="section-note">Diese Angebote finden regelmäßig statt. Termine auf der Originalseite prüfen.</p>
          <div class="event-list">
            {standing.map((ev: any) => <EventCard event={ev} />)}
          </div>
        </section>
      )}
    </div>
  ) : (
    <div class="empty-state">
      <div class="empty-state-inner">
        <p class="empty-headline">Aktuell keine {tagLabel}-Veranstaltungen verfügbar.</p>
        <p class="empty-body">Schau bald wieder vorbei — oder entdecke alle Veranstaltungen in Ludwigsburg.</p>
        <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen in Ludwigsburg →</a>
      </div>
    </div>
  )}

  <!-- Other tags nav — internal linking -->
  <nav class="other-tags" aria-label="Weitere Kategorien">
    <p class="other-tags-label">Weitere Kategorien</p>
    <div class="other-tags-list">
      {TAGS.filter(t => t !== tag).map(t => (
        <a href={`/ludwigsburg/tags/${t}/`} class="tag-chip">
          {TAG_LABELS[t]}
        </a>
      ))}
    </div>
  </nav>

  <a href="/ludwigsburg/" class="back-link">← Alle Veranstaltungen in Ludwigsburg</a>
</Base>

<style>
  .breadcrumb {
    font-size: 0.82rem; color: var(--text-60); margin-bottom: 1.25rem;
    max-width: 720px; margin-left: auto; margin-right: auto;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.1rem;
  }
  .breadcrumb a { color: var(--text-60); text-decoration: none; }
  .breadcrumb a:hover { color: var(--coral); }

  .page-header { margin-bottom: 1rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; }

  .tag-page-layout { max-width: 720px; margin: 0 auto; }

  .section-heading {
    font-size: 1.15rem; font-weight: 600; margin-bottom: 1rem;
    padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
    max-width: 720px; margin-left: auto; margin-right: auto;
  }
  .section-note {
    font-size: 0.85rem; color: var(--text-60); margin-bottom: 1rem;
    margin-top: -0.5rem; max-width: 720px; margin-left: auto; margin-right: auto;
  }

  .empty-state { padding: 3rem 1.5rem; text-align: center; max-width: 720px; margin: 0 auto; }
  .empty-state-inner { background: var(--surface-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem 2rem; box-shadow: var(--shadow-card); }
  .empty-headline { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .empty-body { font-size: 0.95rem; color: var(--text-60); margin-bottom: 1.5rem; }
  .empty-cta { display: inline-flex; align-items: center; background: var(--coral); color: var(--text); font-size: 0.875rem; font-weight: 600; padding: 0.6rem 1.25rem; border-radius: var(--radius-sm); text-decoration: none; min-height: 44px; transition: background 150ms; }
  .empty-cta:hover { background: var(--coral-dark); text-decoration: none; }

  .other-tags { max-width: 720px; margin: 3rem auto 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .other-tags-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-60); margin-bottom: 0.65rem; font-family: var(--font-body); }
  .other-tags-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag-chip { display: inline-flex; align-items: center; padding: 0.35rem 0.85rem; background: var(--tag-bg); color: var(--text-60); border-radius: 20px; font-size: 0.82rem; font-weight: 500; text-decoration: none; min-height: 36px; transition: background 150ms, color 150ms; }
  .tag-chip:hover { background: var(--coral-light); color: var(--coral); text-decoration: none; }

  .back-link { display: inline-block; max-width: 720px; margin: 0 auto 2rem; display: block; font-size: 0.88rem; color: var(--text-60); text-decoration: none; transition: color 150ms; }
  .back-link:hover { color: var(--coral); }
</style>