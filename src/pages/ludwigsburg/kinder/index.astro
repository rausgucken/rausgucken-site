---
import Base from "../../../layouts/Base.astro";
import EventCard from "../../../components/EventCard.astro";
import FilterBar from "../../../components/FilterBar.astro";

import eventsData from "../../../../public/data/ludwigsburg/kinder.json";
import metaData from "../../../../public/data/ludwigsburg/meta.json";

const meta = metaData;

const allKinder = ((eventsData as any).events as any[]).filter((e: any) =>
  // Filter for children's events — tags includes "Kinder" or "Familie"

  Array.isArray(e.tags) &&
  (e.tags.includes("Kinder") || e.tags.includes("Familie"))
);

const dated    = allKinder.filter((e: any) => e.date_start);
const standing = allKinder.filter((e: any) => !e.date_start);

const scrapedDate = meta.scraped_at
  ? new Date(meta.scraped_at).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })
  : "–";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Kinderveranstaltungen in Ludwigsburg",
  "description": `${allKinder.length} Veranstaltungen für Kinder und Familien in Ludwigsburg – Workshops, Ausstellungen, Führungen und mehr.`,
  "url": "https://rausgucken.de/ludwigsburg/kinder/",
  "inLanguage": "de-DE",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": "https://rausgucken.de/" },
      { "@type": "ListItem", "position": 2, "name": "Ludwigsburg", "item": "https://rausgucken.de/ludwigsburg/" },
      { "@type": "ListItem", "position": 3, "name": "Kinder & Familie", "item": "https://rausgucken.de/ludwigsburg/kinder/" }
    ]
  }
};
---

<Base
  title={`Kinderveranstaltungen Ludwigsburg – ${allKinder.length} Events für Kinder & Familien | rausgucken.de`}
  description={`${allKinder.length} aktuelle Veranstaltungen für Kinder und Familien in Ludwigsburg. Workshops, Ausstellungen, Führungen und kostenlose Events – lokal, aktuell, übersichtlich.`}
  city="ludwigsburg"
  canonical="https://rausgucken.de/ludwigsburg/kinder/"
>
  <link rel="canonical" href="https://rausgucken.de/ludwigsburg/kinder/" slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">rausgucken.de</a></li>
      <li aria-hidden="true">›</li>
      <li><a href="/ludwigsburg/">Ludwigsburg</a></li>
      <li aria-hidden="true">›</li>
      <li aria-current="page">Kinder & Familie</li>
    </ol>
  </nav>

  <div class="page-header">
    <div class="page-header-eyebrow">
      <span class="dot-dual" aria-hidden="true">● ·</span>
      Kinder & Familie
    </div>
    <h1>Kinderveranstaltungen in Ludwigsburg</h1>
    <p class="page-subtitle">
      {allKinder.length} Veranstaltungen für Kinder und Familien · Stand: {scrapedDate}
    </p>
  </div>

  {meta.sources_failed && meta.sources_failed.length > 0 && (
    <div class="sources-warning" role="alert">
      <strong>⚠ Hinweis:</strong> {meta.sources_failed.length} {meta.sources_failed.length === 1 ? "Quelle" : "Quellen"} derzeit nicht erreichbar — Angaben können unvollständig sein.
    </div>
  )}

  <aside class="disclaimer-box">
    <strong>Hinweis:</strong> {meta.disclaimer_note || "Alle Angaben ohne Gewähr. Bitte prüfen Sie Infos auf der jeweiligen Originalseite."}
    <a href="/about">Mehr Informationen</a>
  </aside>

  <FilterBar />

  <div class="city-main-content">

  <div class="empty-state" id="empty-state" aria-live="polite" hidden>
    <div class="empty-state-inner">
      <p class="empty-headline">Keine Treffer für diese Filter.</p>
      <p class="empty-body">Vielleicht ist heute ein guter Tag, einfach rauszugehen!</p>
      <div class="empty-ctas">
        <a href="/ludwigsburg/heute/" class="empty-cta">Alle heutigen Events →</a>
        <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen →</a>
      </div>
      <button class="empty-reset" id="empty-reset-btn" type="button">
        Filter zurücksetzen
      </button>
    </div>
  </div>

  {dated.length > 0 && (
    <section id="section-dated">
      <div id="event-grid" class="event-list">
        {dated.map((ev: any) => <EventCard event={ev} />)}
      </div>
    </section>
  )}

  {standing.length > 0 && (
    <section id="section-standing">
      <h2 class="section-heading">Dauerausstellungen & laufende Angebote</h2>
      <div class="event-list">
        {standing.map((ev: any) => <EventCard event={ev} />)}
      </div>
    </section>
  )}

  {allKinder.length === 0 && (
    <div class="empty-state-static">
      <p>Aktuell keine Kinderveranstaltungen gefunden. Schau bald wieder rein!</p>
      <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen in Ludwigsburg →</a>
    </div>
  )}

  <nav class="related-pages" aria-label="Weitere Seiten">
    <h2 class="related-heading">Weitere Seiten</h2>
    <ul class="related-links">
      <li><a href="/ludwigsburg/heute/">Events heute</a></li>
      <li><a href="/ludwigsburg/morgen/">Events morgen</a></li>
      <li><a href="/ludwigsburg/dieses-wochenende/">Dieses Wochenende</a></li>
      <li><a href="/ludwigsburg/naechste-woche/">Nächste Woche</a></li>
      <li><a href="/ludwigsburg/">Alle Veranstaltungen Ludwigsburg</a></li>
    </ul>
  </nav>
  </div><!-- /.city-main-content -->

  <script src="/scripts/app.js" is:inline></script>
</Base>

<style>
  /* ── Breadcrumb ─────────────────────────────────────────────────────────── */
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    font-size: 0.85rem;
    color: var(--text-60);
  }
  .breadcrumbs a { text-decoration: underline; text-underline-offset: 2px; color: var(--text-60); }

  /* ── Page header ─────────────────────────────────────────────────────────── */
  .page-header { margin-bottom: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .page-header h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; margin: 0.25rem 0 0.5rem; }
  .page-subtitle { color: var(--text-60); font-size: 0.95rem; margin-top: 0.35rem; }

  .page-header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-60);
    margin-bottom: 0.5rem;
  }
  .dot-dual { color: var(--coral, #FF6F61); font-size: 0.75rem; letter-spacing: 0.15em; }

  /* ── Scraper failure alert ───────────────────────────────────────────────── */
  .sources-warning {
    background: var(--coral-light);
    border: 1px solid rgba(255,111,97,0.30);
    border-radius: var(--radius-sm);
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.85;
    margin-bottom: 0.85rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Disclaimer ─────────────────────────────────────────────────────────── */
  .disclaimer-box {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.85rem 1.25rem;
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.70;
    margin-bottom: 1.5rem;
    line-height: 1.5;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .disclaimer-box a { color: var(--text); font-weight: 600; margin-left: 0.35rem; }

  /* ── Section headings ───────────────────────────────────────────────────── */
  .section-heading {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Empty states ────────────────────────────────────────────────────────── */
  .empty-state {
    display: none;
    padding: 3rem 1.5rem;
    text-align: center;
  }
  .empty-state:not([hidden]) { display: block; }
  .empty-state-inner {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-card);
  }
  .empty-headline {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .empty-body {
    font-size: 0.95rem;
    color: var(--text-60);
    margin-bottom: 1.5rem;
  }
  .empty-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .empty-cta {
    background: var(--coral);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 150ms;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .empty-cta:hover { background: var(--coral-dark); }
  .empty-reset {
    background: transparent;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-60);
    cursor: pointer;
    min-height: 44px;
    transition: border-color 150ms, color 150ms;
  }
  .empty-reset:hover { border-color: var(--coral); color: var(--coral); }
  .empty-state-static { text-align: center; padding: 3rem 1rem; color: var(--text-60); }

  /* ── Related pages nav ───────────────────────────────────────────────────── */
  .related-pages {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .related-heading { font-size: 0.9rem; font-weight: 600; color: var(--text-60); margin-bottom: 0.75rem; }
  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-links a {
    font-size: 0.875rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text-60);
    text-decoration: none;
    transition: border-color 150ms, color 150ms;
  }
  .related-links a:hover { border-color: var(--coral); color: var(--coral); }

  html.dark .event-card { box-shadow: 0 2px 8px rgba(0,0,0,0.22); }

  /* ── Layout ─────────────────────────────────────────────────────────────── */
  .city-main-content { display: block; max-width: 720px; margin-left: auto; margin-right: auto; }
</style>
