---
// src/pages/ludwigsburg/kinder/index.astro
// SEO §2: Permanent category landing page. Canonical to itself. Never a redirect.
// SEO §9: Keyword-first title with dynamic event count (client-side) and city name.
// SEO §3: Events loaded client-side from kinder.json (Tier 2 daily data swap).
// Design: Dot Doctrine — dual-dot (● ·) motif on Familie tag (design-philosophy v2.0 §I.5).

import Base from "../../../layouts/Base.astro";

const siteUrl = "https://rausgucken.de";
const city    = "ludwigsburg";

const now     = new Date();
const todayDE = now.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" });

const seoTitle  = `Kinderveranstaltungen Ludwigsburg – Kinder & Familie | rausgucken.de`;
const metaDesc  = `Kinderveranstaltungen in Ludwigsburg: Workshops, Ausflüge, Spielangebote, Führungen für Familien. Aktuell, lokal, übersichtlich.`;
const canonical = `${siteUrl}/${city}/kinder/`;

// CollectionPage schema — SEO §10B
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Kinderveranstaltungen Ludwigsburg – Kinder & Familie`,
  "description": metaDesc,
  "url": canonical,
  "inLanguage": "de-DE",
};

// BreadcrumbList schema — SEO §10C
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de",   "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Ludwigsburg",     "item": `${siteUrl}/${city}/` },
    { "@type": "ListItem", "position": 3, "name": "Kinder & Familie","item": canonical },
  ],
};
---

<Base
  title={seoTitle}
  description={metaDesc}
  canonical={canonical}
  ogImage="/og/ludwigsburg/kinder.jpg"
  schema={[collectionSchema, breadcrumbSchema]}
>

  <!-- Breadcrumb — visible + schema-backed (SEO §10C) -->
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/ludwigsburg">Ludwigsburg</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">Kinder &amp; Familie</span>
  </nav>

  <div class="page-header">
    <div class="page-header-top">
      <!-- Dual-dot motif: design-philosophy v2.0 §I.5 — Tier 1 functional UI use -->
      <span class="dual-dot" aria-hidden="true">● ·</span>
      <h1>Kinderveranstaltungen Ludwigsburg</h1>
    </div>
    <p class="page-subtitle">
      <span id="event-count-badge" class="count-badge" hidden></span>
      Kinder, Familie &amp; Entdecken in Ludwigsburg
    </p>
    <p class="page-intro">
      Ausflüge, Workshops, Theateraufführungen und Mitmachaktionen für Kinder und Familien –
      kuratiert aus Ludwigsburger Veranstaltungsquellen, täglich aktuell.
    </p>
  </div>

  <!-- Age-range filter tabs — in-memory, no refetch -->
  <div class="age-tabs" role="tablist" aria-label="Altersgruppe filtern" id="age-tabs">
    <button class="age-tab age-tab--active" role="tab" aria-selected="true"  data-age="alle"    id="tab-alle"    aria-controls="event-list">Alle Altersgruppen</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="kleinkind" id="tab-kleinkind" aria-controls="event-list">Kleinkinder (0–3)</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="kita"    id="tab-kita"    aria-controls="event-list">Kita &amp; Vorschule (3–6)</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="grundschule" id="tab-grundschule" aria-controls="event-list">Grundschule (6–10)</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="familie" id="tab-familie" aria-controls="event-list">Familie ● ·</button>
  </div>

  <!-- Event list — loaded client-side from kinder.json -->
  <div id="events-container" aria-live="polite" aria-label="Kinderveranstaltungen" class="events-container">
    <div class="loading-state" id="loading-state" aria-busy="true">
      <span class="loading-spinner" aria-hidden="true"></span>
      Lade Kinderveranstaltungen…
    </div>
    <ul class="event-list" id="event-list" hidden aria-label="Kinderveranstaltungen in Ludwigsburg"></ul>
    <div class="empty-state" id="empty-state" hidden>
      <div class="empty-inner">
        <p class="empty-icon" aria-hidden="true">🎨</p>
        <p class="empty-headline">Gerade keine Kinderveranstaltungen eingetragen.</p>
        <p class="empty-body">Schau bald wieder vorbei – neue Veranstaltungen werden täglich ergänzt.</p>
        <div class="empty-ctas">
          <a href="/ludwigsburg/heute" class="btn-cta">Was ist heute los? →</a>
          <a href="/ludwigsburg" class="btn-cta btn-cta--ghost">Alle Veranstaltungen</a>
        </div>
      </div>
    </div>
    <div class="empty-state" id="empty-filter-state" hidden>
      <div class="empty-inner empty-inner--slim">
        <p class="empty-body">Keine Veranstaltungen für diese Altersgruppe gefunden.</p>
        <button class="btn-cta btn-cta--ghost" id="reset-filter">Alle Altersgruppen anzeigen</button>
      </div>
    </div>
  </div>

  <!-- Internal linking mesh — SEO §22 -->
  <nav class="temporal-nav" aria-label="Andere Zeiträume in Ludwigsburg">
    <p class="temporal-label">Andere Zeiträume</p>
    <div class="temporal-links">
      <a href="/ludwigsburg/heute">Heute</a>
      <a href="/ludwigsburg/morgen">Morgen</a>
      <a href="/ludwigsburg/dieses-wochenende">Dieses Wochenende</a>
      <a href="/ludwigsburg/naechste-woche">Nächste Woche</a>
      <a href="/ludwigsburg">Alle Veranstaltungen</a>
    </div>
  </nav>

</Base>

<!-- Client-side fetch from kinder.json — Tier 2 daily data swap -->
<script>
(async function () {
  const listEl        = document.getElementById('event-list');
  const emptyEl       = document.getElementById('empty-state');
  const emptyFilterEl = document.getElementById('empty-filter-state');
  const loadingEl     = document.getElementById('loading-state');
  const badgeEl       = document.getElementById('event-count-badge');
  const tabsEl        = document.getElementById('age-tabs');
  const resetBtn      = document.getElementById('reset-filter');

  function escHtml(str) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Age-group keyword mapping — matches tags in the event data
  // Each key corresponds to a data-age attribute on the tab buttons.
  const AGE_KEYWORDS = {
    kleinkind:   ['kleinkind', 'baby', 'krabbeln', '0-3', 'unter 3'],
    kita:        ['kita', 'vorschule', 'kindergarten', '3-6', 'unter 6'],
    grundschule: ['grundschule', 'schulkind', '6-10', 'ab 6', 'ab 7', 'ab 8'],
    familie:     ['familie', 'familien', 'family', 'eltern', 'generationen'],
  };

  let allEvents   = [];
  let activeAge   = 'alle';

  function eventMatchesAge(ev, age) {
    if (age === 'alle') return true;
    const keywords = AGE_KEYWORDS[age] || [];
    const haystack = [
      ...(ev.tags || []),
      ev.title || '',
      ev.description || '',
    ].join(' ').toLowerCase();
    return keywords.some(kw => haystack.includes(kw));
  }

  function renderEvents(events) {
    listEl.innerHTML = '';

    if (events.length === 0) {
      listEl.hidden       = true;
      emptyFilterEl.hidden = activeAge === 'alle';
      emptyEl.hidden      = activeAge !== 'alle';
      return;
    }

    emptyEl.hidden       = true;
    emptyFilterEl.hidden = true;

    events.forEach(ev => {
      const li   = document.createElement('li');
      const card = document.createElement('a');
      card.href      = `/ludwigsburg/events/${escHtml(ev.slug)}`;
      card.className = 'event-row';
      card.setAttribute('aria-label', escHtml(ev.title));

      // Determine a day label if the event has a date
      let dayLabel = '';
      if (ev.date) {
        const d = new Date(ev.date);
        if (!isNaN(d)) {
          const weekday = d.toLocaleDateString('de-DE', { weekday: 'short' });
          const datePart = d.toLocaleDateString('de-DE', { day: 'numeric', month: 'numeric' });
          dayLabel = `${weekday} ${datePart}`;
        }
      }

      // Age-group badge: pick the most relevant matched age group for display
      let ageBadge = '';
      for (const [age, keywords] of Object.entries(AGE_KEYWORDS)) {
        const haystack = [...(ev.tags || []), ev.title || '', ev.description || ''].join(' ').toLowerCase();
        if (keywords.some(kw => haystack.includes(kw))) {
          const labels = { kleinkind: '0–3', kita: '3–6', grundschule: '6–10', familie: 'Familie ● ·' };
          ageBadge = `<span class="age-badge age-badge--${escHtml(age)}">${labels[age]}</span>`;
          break;
        }
      }

      const tagsHtml = (ev.tags || []).slice(0, 2)
        .map(t => `<span class="tag">${escHtml(t)}</span>`).join('');

      card.innerHTML = `
        <div class="event-row-left">
          ${dayLabel || ev.time ? `<span class="event-row-time">${dayLabel ? escHtml(dayLabel) : ''}${ev.time ? ' · ' + escHtml(ev.time) + ' Uhr' : ''}</span>` : ''}
          <span class="event-row-title">${escHtml(ev.title)}</span>
          ${ev.location ? `<span class="event-row-loc">📍 ${escHtml(ev.location)}</span>` : ''}
        </div>
        <div class="event-row-right">
          ${ageBadge}
          ${tagsHtml ? `<div class="event-row-tags" aria-hidden="true">${tagsHtml}</div>` : ''}
        </div>
      `;

      li.appendChild(card);
      listEl.appendChild(li);
    });

    listEl.hidden = false;
  }

  function applyFilter(age) {
    activeAge = age;

    // Update tab states
    document.querySelectorAll('.age-tab').forEach(btn => {
      const isActive = btn.dataset.age === age;
      btn.classList.toggle('age-tab--active', isActive);
      btn.setAttribute('aria-selected', String(isActive));
    });

    const filtered = allEvents.filter(ev => eventMatchesAge(ev, age));
    renderEvents(filtered);

    // Update count badge
    if (badgeEl) {
      const count = filtered.length;
      badgeEl.textContent = count + ' Veranstaltung' + (count !== 1 ? 'en' : '');
      badgeEl.hidden = false;
    }
  }

  // Tab click handler
  if (tabsEl) {
    tabsEl.addEventListener('click', e => {
      const tab = e.target.closest('.age-tab');
      if (!tab) return;
      applyFilter(tab.dataset.age);
    });
  }

  // Reset filter button
  if (resetBtn) {
    resetBtn.addEventListener('click', () => applyFilter('alle'));
  }

  try {
    const res  = await fetch('/data/ludwigsburg/kinder.json');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    allEvents = await res.json();

    loadingEl.hidden = true;

    if (!Array.isArray(allEvents) || allEvents.length === 0) {
      emptyEl.hidden = false;
      return;
    }

    // Show total count badge on initial load
    if (badgeEl) {
      badgeEl.textContent = allEvents.length + ' Veranstaltung' + (allEvents.length !== 1 ? 'en' : '');
      badgeEl.hidden = false;
    }

    renderEvents(allEvents);

  } catch (err) {
    loadingEl.setAttribute('aria-busy', 'false');
    loadingEl.textContent = 'Veranstaltungen konnten nicht geladen werden. Bitte Seite neu laden.';
  }
})();
</script>

<style>
  /* ── Breadcrumb ─────────────────────────────────────────────────────────── */
  .breadcrumb {
    font-size: 0.82rem;
    color: var(--text-60);
    margin-bottom: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.1rem;
  }
  .breadcrumb a { color: var(--text-60); text-decoration: none; }
  .breadcrumb a:hover { color: var(--coral); }

  /* ── Page header ─────────────────────────────────────────────────────────── */
  .page-header { margin-bottom: 1.5rem; max-width: 720px; }

  .page-header-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  /* Dual-dot motif — design-philosophy v2.0 §I.5, Tier 1 functional use */
  .dual-dot {
    display: inline-flex;
    align-items: center;
    font-size: 1.1rem;
    color: var(--coral);
    letter-spacing: -0.05em;
    flex-shrink: 0;
  }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .page-subtitle {
    color: var(--text-60);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .page-intro {
    color: var(--text-60);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 600px;
    margin: 0;
  }

  /* Count badge — Coral bg → Charcoal text — NEVER white on coral */
  .count-badge {
    display: inline-flex;
    align-items: center;
    background: var(--coral);
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── Age filter tabs ─────────────────────────────────────────────────────── */
  .age-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .age-tab {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 0.9rem;
    background: var(--tag-bg);
    color: var(--text-60);
    border: 1.5px solid transparent;
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background 150ms, color 150ms, border-color 150ms;
    white-space: nowrap;
    /* Ensure tap target meets 44px minimum vertically including touch slop */
    min-height: 36px;
  }

  .age-tab:hover {
    background: var(--coral-light, #fff0ee);
    color: var(--coral);
    border-color: var(--coral);
  }

  .age-tab--active {
    background: var(--coral);
    color: var(--text); /* Charcoal — NEVER white on coral */
    border-color: var(--coral);
    font-weight: 700;
  }

  .age-tab--active:hover {
    background: var(--coral-dark, #e85d50);
    color: var(--text);
  }

  /* ── Events container ────────────────────────────────────────────────────── */
  .events-container { max-width: 720px; }

  /* ── Loading state ───────────────────────────────────────────────────────── */
  .loading-state {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-60);
    font-size: 0.95rem;
    padding: 2rem 0;
  }
  .loading-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid var(--border);
    border-top-color: var(--coral);
    border-radius: 50%;
    flex-shrink: 0;
    animation: spin 0.75s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .loading-spinner { animation: none; opacity: 0.5; }
  }

  /* ── Event list ──────────────────────────────────────────────────────────── */
  .event-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0;
    margin: 0;
  }

  .event-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    box-shadow: var(--shadow-card);
    transition: transform 200ms cubic-bezier(0.4,0,0.2,1),
                box-shadow 200ms cubic-bezier(0.4,0,0.2,1),
                border-color 150ms;
  }
  @media (prefers-reduced-motion: no-preference) {
    .event-row:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-hover);
      border-color: var(--coral);
    }
  }
  .event-row-left  { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; flex: 1; }
  .event-row-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; flex-shrink: 0; }
  .event-row-time  { font-size: 0.75rem; font-weight: 700; color: var(--coral); }
  .event-row-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.97rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .event-row-loc   { font-size: 0.78rem; color: var(--text-60); }
  .event-row-tags  { display: flex; gap: 0.3rem; flex-wrap: wrap; justify-content: flex-end; }

  /* Age badge — sage green (design system secondary colour) */
  .age-badge {
    display: inline-flex;
    align-items: center;
    background: var(--sage, #90BE6D);
    color: var(--text); /* Charcoal on Sage */
    font-size: 0.68rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  /* Dual-dot in Familie badge — subtle nod to brand motif */
  .age-badge--familie { background: var(--sage, #90BE6D); }

  .tag {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── Empty states ────────────────────────────────────────────────────────── */
  .empty-state { padding: 1rem 0 2rem; }
  .empty-inner {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    text-align: center;
    box-shadow: var(--shadow-card);
  }
  .empty-inner--slim { padding: 1.25rem 1.5rem; }
  .empty-icon        { font-size: 2rem; margin-bottom: 0.75rem; }
  .empty-headline {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .empty-body  { color: var(--text-60); font-size: 0.92rem; margin-bottom: 1.5rem; line-height: 1.6; }
  .empty-ctas  { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  /* Coral bg → Charcoal text — NEVER white on coral */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 1.25rem;
    background: var(--coral);
    color: var(--text);
    border: none;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.875rem;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    transition: background 150ms;
  }
  .btn-cta:hover { background: var(--coral-dark, #e85d50); text-decoration: none; }
  .btn-cta--ghost { background: var(--tag-bg); color: var(--text-60); }
  .btn-cta--ghost:hover { background: var(--coral-light, #fff0ee); color: var(--coral); }

  /* ── Temporal nav — SEO §22 internal linking mesh ───────────────────────── */
  .temporal-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    max-width: 720px;
  }
  .temporal-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-60);
    margin-bottom: 0.65rem;
    font-family: var(--font-body);
  }
  .temporal-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .temporal-links a {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 0.9rem;
    background: var(--tag-bg);
    color: var(--text-60);
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms, color 150ms;
  }
  .temporal-links a:hover { background: var(--coral-light, #fff0ee); color: var(--coral); }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .event-row         { gap: 0.6rem; }
    .event-row-tags    { display: none; }
    .event-row-title   { white-space: normal; }
    .event-row-right   { align-items: flex-start; }
  }
</style>
