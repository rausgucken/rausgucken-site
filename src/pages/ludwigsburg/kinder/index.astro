---
// src/pages/ludwigsburg/kinder/index.astro
// SEO §2: Permanent category landing page. Canonical to itself. Never a redirect.
// SEO §9: Keyword-first title with dynamic event count (client-side) and city name.
// SEO §3: Events loaded client-side from kinder.json (Tier 2 daily data swap).
// Design: Dot Doctrine — dual-dot (● ·) motif on Familie tag (design-philosophy v2.0 §I.5).

import Base from "../../../layouts/Base.astro";

const siteUrl = "https://rausgucken.de";
const city    = "ludwigsburg";

const now     = new Date();
const todayDE = now.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" });

const seoTitle  = `Kinderveranstaltungen Ludwigsburg – Kinder & Familie | rausgucken.de`;
const metaDesc  = `Kinderveranstaltungen in Ludwigsburg: Workshops, Ausflüge, Spielangebote, Führungen für Familien. Aktuell, lokal, übersichtlich.`;
const canonical = `${siteUrl}/${city}/kinder/`;

// CollectionPage schema — SEO §10B
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Kinderveranstaltungen Ludwigsburg – Kinder & Familie`,
  "description": metaDesc,
  "url": canonical,
  "inLanguage": "de-DE",
};

// BreadcrumbList schema — SEO §10C
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "rausgucken.de",   "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Ludwigsburg",     "item": `${siteUrl}/${city}/` },
    { "@type": "ListItem", "position": 3, "name": "Kinder & Familie","item": canonical },
  ],
};
---

<Base
  title={seoTitle}
  description={metaDesc}
  canonical={canonical}
  ogImage="/og/ludwigsburg/kinder.jpg"
  schema={[collectionSchema, breadcrumbSchema]}
>

  <!-- Breadcrumb — visible + schema-backed (SEO §10C) -->
  <nav class="breadcrumb" aria-label="Brotkrumennavigation">
    <a href="/">rausgucken.de</a>
    <span aria-hidden="true"> › </span>
    <a href="/ludwigsburg">Ludwigsburg</a>
    <span aria-hidden="true"> › </span>
    <span aria-current="page">Kinder &amp; Familie</span>
  </nav>

  <div class="page-header">
    <div class="page-header-top">
      <!-- Dual-dot motif: design-philosophy v2.0 §I.5 — Tier 1 functional UI use -->
      <span class="dual-dot" aria-hidden="true">● ·</span>
      <h1>Kinderveranstaltungen Ludwigsburg</h1>
    </div>
    <p class="page-subtitle">
      <span id="event-count-badge" class="count-badge" hidden></span>
      Kinder, Familie &amp; Entdecken in Ludwigsburg
    </p>
    <p class="page-intro">
      Ausflüge, Workshops, Theateraufführungen und Mitmachaktionen für Kinder und Familien –
      kuratiert aus Ludwigsburger Veranstaltungsquellen, täglich aktuell.
    </p>
  </div>

  <!-- Age-range filter tabs — in-memory, no refetch -->
  <div class="age-tabs" role="tablist" aria-label="Altersgruppe filtern" id="age-tabs">
    <button class="age-tab age-tab--active" role="tab" aria-selected="true"  data-age="alle"    id="tab-alle"    aria-controls="event-list">Alle Altersgruppen</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="kleinkind" id="tab-kleinkind" aria-controls="event-list">Kleinkinder (0–3)</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="kita"    id="tab-kita"    aria-controls="event-list">Kita &amp; Vorschule (3–6)</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="grundschule" id="tab-grundschule" aria-controls="event-list">Grundschule (6–10)</button>
    <button class="age-tab"                 role="tab" aria-selected="false" data-age="familie" id="tab-familie" aria-controls="event-list">Familie ● ·</button>
  </div>

  <!-- Event list — loaded client-side from kinder.json -->
  <div id="events-container" aria-live="polite" aria-label="Kinderveranstaltungen" class="events-container">
    <div class="loading-state" id="loading-state" aria-busy="true">
      <span class="loading-spinner" aria-hidden="true"></span>
      Lade Kinderveranstaltungen…
    </div>
    <div class="event-list" id="event-list" hidden aria-label="Kinderveranstaltungen in Ludwigsburg"></div>
    <div class="empty-state" id="empty-state" hidden>
      <div class="empty-inner">
        <p class="empty-icon" aria-hidden="true">🎨</p>
        <p class="empty-headline">Gerade keine Kinderveranstaltungen eingetragen.</p>
        <p class="empty-body">Schau bald wieder vorbei – neue Veranstaltungen werden täglich ergänzt.</p>
        <div class="empty-ctas">
          <a href="/ludwigsburg/heute" class="btn-cta">Was ist heute los? →</a>
          <a href="/ludwigsburg" class="btn-cta btn-cta--ghost">Alle Veranstaltungen</a>
        </div>
      </div>
    </div>
    <div class="empty-state" id="empty-filter-state" hidden>
      <div class="empty-inner empty-inner--slim">
        <p class="empty-body">Keine Veranstaltungen für diese Altersgruppe gefunden.</p>
        <button class="btn-cta btn-cta--ghost" id="reset-filter">Alle Altersgruppen anzeigen</button>
      </div>
    </div>
  </div>

  <!-- Internal linking mesh — SEO §22 -->
  <nav class="temporal-nav" aria-label="Andere Zeiträume in Ludwigsburg">
    <p class="temporal-label">Andere Zeiträume</p>
    <div class="temporal-links">
      <a href="/ludwigsburg/heute">Heute</a>
      <a href="/ludwigsburg/morgen">Morgen</a>
      <a href="/ludwigsburg/dieses-wochenende">Dieses Wochenende</a>
      <a href="/ludwigsburg/naechste-woche">Nächste Woche</a>
      <a href="/ludwigsburg">Alle Veranstaltungen</a>
    </div>
  </nav>

</Base>


<!-- Client-side fetch from kinder.json — Tier 2 daily data swap -->
<script type="module">
import { renderEventCard, injectEventCardStyles } from '/scripts/renderEventCard.js';

(async function () {
  injectEventCardStyles();

  const listEl      = document.getElementById('event-list');
  const emptyEl     = document.getElementById('empty-state');
  const loadingEl   = document.getElementById('loading-state');
  const badgeEl     = document.getElementById('event-count-badge');
  const tabsEl      = document.getElementById('age-tabs');
  const resetBtn    = document.getElementById('reset-filter');

  let allEvents = [];
  let activeAge = 'alle';

  const AGE_KEYWORDS = {
    kleinkind:   ['kleinkind', 'baby', 'krabbel', '0-3', '0–3', 'ab 0', 'ab 1', 'ab 2'],
    kita:        ['kita', 'kindergarten', 'vorschule', '3-6', '3–6', 'ab 3', 'ab 4', 'ab 5'],
    grundschule: ['grundschule', 'schulkind', '6-12', '6–12', 'ab 6', 'ab 7', 'ab 8', 'ab 9', 'ab 10'],
    familie:     ['familie', 'familien', 'eltern', 'kinder', 'kids'],
  };

  function eventMatchesAge(ev, age) {
    if (age === 'alle') return true;
    const keywords = AGE_KEYWORDS[age] || [];
    const haystack = [
      ...(ev.tags || []),
      ev.title || '',
      ev.description || '',
    ].join(' ').toLowerCase();
    return keywords.some(kw => haystack.includes(kw));
  }

  function renderEvents(events) {
    listEl.innerHTML = '';

    if (events.length === 0) {
      listEl.hidden = true;
      emptyEl.hidden = false;
      return;
    }

    emptyEl.hidden = true;
    events.forEach(ev => listEl.appendChild(renderEventCard(ev)));
    listEl.hidden = false;
    listEl.style.display = "flex";
  }

  function applyFilter(age) {
    activeAge = age;

    document.querySelectorAll('.age-tab').forEach(btn => {
      const isActive = btn.dataset.age === age;
      btn.classList.toggle('age-tab--active', isActive);
      btn.setAttribute('aria-selected', String(isActive));
    });

    const filtered = allEvents.filter(ev => eventMatchesAge(ev, age));
    renderEvents(filtered);

    if (badgeEl) {
      const count = filtered.length;
      badgeEl.textContent = count + ' Veranstaltung' + (count !== 1 ? 'en' : '');
      badgeEl.hidden = false;
    }
  }

  if (tabsEl) {
    tabsEl.addEventListener('click', e => {
      const tab = e.target.closest('.age-tab');
      if (!tab) return;
      applyFilter(tab.dataset.age);
    });
  }

  if (resetBtn) {
    resetBtn.addEventListener('click', () => applyFilter('alle'));
  }

  try {
    const res  = await fetch('/data/ludwigsburg/kinder.json');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    allEvents = await res.json();

    loadingEl.hidden = true;

    if (!Array.isArray(allEvents) || allEvents.length === 0) {
      emptyEl.hidden = false;
      return;
    }

    if (badgeEl) {
      badgeEl.textContent = allEvents.length + ' Veranstaltung' + (allEvents.length !== 1 ? 'en' : '');
      badgeEl.hidden = false;
    }

    renderEvents(allEvents);

  } catch (err) {
    loadingEl.setAttribute('aria-busy', 'false');
    loadingEl.textContent = 'Veranstaltungen konnten nicht geladen werden. Bitte Seite neu laden.';
  }
})();
</script>


<style>
.age-badge {
    display: inline-flex;
    align-items: center;
    background: var(--sage, #90BE6D);
    color: var(--text); /* Charcoal on Sage */
    font-size: 0.68rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  /* Dual-dot in Familie badge — subtle nod to brand motif */
  .age-badge--familie { background: var(--sage, #90BE6D); }

  .tag {
    background: var(--tag-bg);
    color: var(--text-60);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── Empty states ────────────────────────────────────────────────────────── */
  .empty-state { padding: 1rem 0 2rem; }
  .empty-inner {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    text-align: center;
    box-shadow: var(--shadow-card);
  }
  .empty-inner--slim { padding: 1.25rem 1.5rem; }
  .empty-icon        { font-size: 2rem; margin-bottom: 0.75rem; }
  .empty-headline {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .empty-body  { color: var(--text-60); font-size: 0.92rem; margin-bottom: 1.5rem; line-height: 1.6; }
  .empty-ctas  { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  /* Coral bg → Charcoal text — NEVER white on coral */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 1.25rem;
    background: var(--coral);
    color: var(--text);
    border: none;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.875rem;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    transition: background 150ms;
  }
  .btn-cta:hover { background: var(--coral-dark, #e85d50); text-decoration: none; }
  .btn-cta--ghost { background: var(--tag-bg); color: var(--text-60); }
  .btn-cta--ghost:hover { background: var(--coral-light, #fff0ee); color: var(--coral); }

  /* ── Temporal nav — SEO §22 internal linking mesh ───────────────────────── */
  .temporal-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    max-width: 720px;
  }
  .temporal-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-60);
    margin-bottom: 0.65rem;
    font-family: var(--font-body);
  }
  .temporal-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .temporal-links a {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 0.9rem;
    background: var(--tag-bg);
    color: var(--text-60);
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms, color 150ms;
  }
  .temporal-links a:hover { background: var(--coral-light, #fff0ee); color: var(--coral); }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
  }
</style>
