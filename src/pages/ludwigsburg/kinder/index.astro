---
import Base from "../../../layouts/Base.astro";
import EventCard from "../../../components/EventCard.astro";
import FilterBar from "../../../components/FilterBar.astro";
import ImportantLinksSidebar from "../../../components/ImportantLinksSidebar.astro";

import eventsData from "../../../../public/data/ludwigsburg/kinder.json";
import metaData from "../../../../public/data/ludwigsburg/meta.json";

const meta = metaData;

const allKinder = ((eventsData as any).events as any[]).filter((e: any) =>
  Array.isArray(e.tags) &&
  (e.tags.includes("Kinder") || e.tags.includes("Familie"))
);

const dated    = allKinder.filter((e: any) => e.date_start);
const standing = allKinder.filter((e: any) => !e.date_start);

const scrapedDate = meta.scraped_at
  ? new Date(meta.scraped_at).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })
  : "–";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Kinderveranstaltungen in Ludwigsburg",
  "description": `${allKinder.length} Veranstaltungen für Kinder und Familien in Ludwigsburg – Workshops, Ausstellungen, Führungen und mehr.`,
  "url": "https://www.rausgucken.de/ludwigsburg/kinder/",
  "inLanguage": "de-DE",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "rausgucken.de", "item": "https://www.rausgucken.de/" },
      { "@type": "ListItem", "position": 2, "name": "Ludwigsburg", "item": "https://www.rausgucken.de/ludwigsburg/" },
      { "@type": "ListItem", "position": 3, "name": "Kinder & Familie", "item": "https://www.rausgucken.de/ludwigsburg/kinder/" }
    ]
  }
};
---

<Base
  title={`Kinderveranstaltungen Ludwigsburg – ${allKinder.length} Events für Kinder & Familien | rausgucken.de`}
  description={`${allKinder.length} aktuelle Veranstaltungen für Kinder und Familien in Ludwigsburg. Workshops, Ausstellungen, Führungen und kostenlose Events – lokal, aktuell, übersichtlich.`}
  city="ludwigsburg"
  canonical="https://www.rausgucken.de/ludwigsburg/kinder/"
>
  <link rel="canonical" href="https://www.rausgucken.de/ludwigsburg/kinder/" slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">rausgucken.de</a></li>
      <li aria-hidden="true">›</li>
      <li><a href="/ludwigsburg/">Ludwigsburg</a></li>
      <li aria-hidden="true">›</li>
      <li aria-current="page">Kinder & Familie</li>
    </ol>
  </nav>

  <div class="page-header">
    <div class="page-header-eyebrow">
      <span class="dot-dual" aria-hidden="true">● ·</span>
      Kinder & Familie
    </div>
    <h1>Kinderveranstaltungen in Ludwigsburg</h1>
    <p class="page-subtitle">
      {allKinder.length} Veranstaltungen für Kinder und Familien · Stand: {scrapedDate}
    </p>
  </div>

  {meta.sources_failed && meta.sources_failed.length > 0 && (
    <div class="sources-warning" role="alert">
      <strong>⚠ Hinweis:</strong> {meta.sources_failed.length} {meta.sources_failed.length === 1 ? "Quelle" : "Quellen"} derzeit nicht erreichbar — Angaben können unvollständig sein.
    </div>
  )}



  <FilterBar />

  <div class="city-layout">
    <div class="city-main">

      <div class="empty-state" id="empty-state" aria-live="polite" hidden>
        <div class="empty-state-inner">
          <p class="empty-headline">Keine Treffer für diese Filter.</p>
          <p class="empty-body">Vielleicht ist heute ein guter Tag, einfach rauszugehen!</p>
          <div class="empty-ctas">
            <a href="/ludwigsburg/heute/" class="empty-cta">Alle heutigen Events →</a>
            <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen →</a>
          </div>
          <button class="empty-reset" id="empty-reset-btn" type="button">
            Filter zurücksetzen
          </button>
        </div>
      </div>

      {dated.length > 0 && (
        <section id="section-dated">
          <div id="event-grid" class="event-list">
            {dated.map((ev: any) => <EventCard event={ev} />)}
          </div>
        </section>
      )}

      {standing.length > 0 && (
        <section id="section-standing">
          <h2 class="section-heading">Dauerausstellungen & laufende Angebote</h2>
          <div class="event-list">
            {standing.map((ev: any) => <EventCard event={ev} />)}
          </div>
        </section>
      )}

      {allKinder.length === 0 && (
        <div class="empty-state-static">
          <p>Aktuell keine Kinderveranstaltungen gefunden. Schau bald wieder rein!</p>
          <a href="/ludwigsburg/" class="empty-cta">Alle Veranstaltungen in Ludwigsburg →</a>
        </div>
      )}

      <nav class="related-pages" aria-label="Weitere Seiten">
        <h2 class="related-heading">Weitere Seiten</h2>
        <ul class="related-links">
          <li><a href="/ludwigsburg/heute/">Events heute</a></li>
          <li><a href="/ludwigsburg/morgen/">Events morgen</a></li>
          <li><a href="/ludwigsburg/dieses-wochenende/">Dieses Wochenende</a></li>
          <li><a href="/ludwigsburg/naechste-woche/">Nächste Woche</a></li>
          <li><a href="/ludwigsburg/kostenlos/">Kostenlose Events Ludwigsburg</a></li>
          <li><a href="/ludwigsburg/">Alle Veranstaltungen Ludwigsburg</a></li>
        </ul>
      </nav>

    </div><!-- /.city-main -->

    <div class="city-sidebar">
      <ImportantLinksSidebar />
    </div>
  </div><!-- /.city-layout -->

  <script src="/scripts/app.js" is:inline></script>
</Base>

<style>
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    font-size: 0.85rem;
    opacity: 0.7;
  }
  .breadcrumbs a { text-decoration: underline; text-underline-offset: 2px; }

  .page-header { margin-bottom: 1.5rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .page-header h1 { margin: 0.25rem 0 0.5rem; }
  .page-subtitle { margin: 0; opacity: 0.7; font-size: 0.95rem; }

  .page-header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .dot-dual { color: var(--brand-coral, #FF6F61); font-size: 0.75rem; letter-spacing: 0.15em; }

  .sources-warning {
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    border-radius: 6px;
    background: rgba(255, 193, 7, 0.12);
    border: 1px solid rgba(255, 193, 7, 0.3);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .related-pages {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  :global(.dark) .related-pages { border-top-color: rgba(255,255,255,0.06); }
  .related-heading { font-size: 0.9rem; font-weight: 600; opacity: 0.6; margin-bottom: 0.75rem; }
  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-links a {
    font-size: 0.875rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid currentColor;
    opacity: 0.65;
    text-decoration: none;
    transition: opacity 150ms;
  }
  .related-links a:hover { opacity: 1; }
  .section-heading { font-size: 1.1rem; font-weight: 600; margin: 2.5rem 0 1rem; opacity: 0.8; }
  .empty-state-static { text-align: center; padding: 3rem 1rem; opacity: 0.7; }

  .empty-state {
    display: none;
    padding: 3rem 1.5rem;
    text-align: center;
  }
  .empty-state:not([hidden]) { display: block; }
  .empty-state-inner {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-card);
  }
  .empty-headline {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .empty-body {
    font-size: 0.95rem;
    color: var(--text-60);
    margin-bottom: 1.5rem;
  }
  .empty-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .empty-cta {
    background: var(--coral);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 150ms;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .empty-cta:hover { background: var(--coral-dark); }
  .empty-reset {
    background: transparent;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-60);
    cursor: pointer;
    min-height: 44px;
    transition: border-color 150ms, color 150ms;
  }
  .empty-reset:hover { border-color: var(--coral); color: var(--coral); }

  /* ── Sidebar — matches main ludwigsburg page exactly ───────────────────── */
  .city-layout { display: block; }
  .city-main   { display: block; }
  @media (min-width: 961px) {
    .city-sidebar {
      display: block;
      position: fixed;
      top: 160px;
      left: calc(50% + 384px);
      width: 200px;
    }
    .city-sidebar :global(.important-links-sidebar) {
      display: block;
    }
  }
  @media (max-width: 960px) {
    .city-sidebar { display: none; }
  }
</style>
